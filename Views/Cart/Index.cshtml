@inject TMDTStore.Services.Cart.ICartService CartService
@{
    ViewData["Title"] = "Giỏ hàng";
    var items = CartService.GetCart();
    var isEmpty = items.Count == 0;
    var total = CartService.GetCartTotal();
}

<div class="max-w-4xl mx-auto">
    <!-- Breadcrumb -->
    <nav class="text-sm text-brand-500 mb-6 flex items-center gap-2 flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="hover:text-brand-600 transition-colors">Trang chủ</a>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-brand-700 font-medium">Giỏ hàng</span>
    </nav>

    @if (isEmpty)
    {
        <!-- ====== Giỏ hàng trống ====== -->
        <div class="text-center py-16">
            <div class="w-32 h-32 mx-auto mb-6 bg-brand-50 rounded-full flex items-center justify-center">
                <svg class="w-16 h-16 text-brand-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                     stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
            </div>
            <h1 class="text-2xl font-heading font-bold text-brand-800 mb-3">Giỏ hàng trống</h1>
            <p class="text-brand-500 mb-8">Bạn chưa có sản phẩm nào trong giỏ hàng.</p>
            <a asp-controller="Product" asp-action="Index"
               class="inline-flex items-center gap-2 bg-brand-600 text-white px-6 py-3 rounded-xl font-semibold text-sm hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 transition-all duration-200">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <!-- ====== Có hàng ====== -->
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-heading font-bold text-brand-800">Giỏ hàng</h1>
            <form asp-action="Clear" method="post" onsubmit="return confirm('Xoá tất cả sản phẩm trong giỏ?')">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="text-sm text-red-500 hover:text-red-600 font-medium flex items-center gap-1 cursor-pointer">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    Xoá giỏ hàng
                </button>
            </form>
        </div>

        <!-- Cart Items -->
        <div class="space-y-4">
            @foreach (var item in items)
            {
                var itemKey = item.VariantId ?? item.ProductId;
                <div class="bg-white rounded-2xl border border-brand-100 p-4 sm:p-5 flex items-center gap-4">
                    <!-- Ảnh -->
                    <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-xl bg-brand-50 overflow-hidden flex-shrink-0">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center text-brand-200">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                        }
                    </div>

                    <!-- Thông tin -->
                    <div class="flex-1 min-w-0">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                           class="text-sm font-semibold text-brand-800 hover:text-brand-600 transition-colors line-clamp-2">
                            @item.Name
                        </a>
                        @if (!string.IsNullOrEmpty(item.VariantName))
                        {
                            <p class="text-xs text-brand-400 mt-0.5">@item.VariantName</p>
                        }
                        <p class="text-sm font-bold text-red-500 mt-1">@item.Price.ToString("#,###")₫</p>
                    </div>

                    <!-- Số lượng -->
                    <div class="flex items-center gap-1 flex-shrink-0">
                        <form asp-action="Update" method="post" class="flex items-center gap-1" id="form-@itemKey">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <input type="hidden" name="variantId" value="@item.VariantId" />
                            <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                    class="w-8 h-8 rounded-lg border border-brand-200 flex items-center justify-center text-brand-600 hover:bg-brand-50 hover:border-brand-300 transition-all cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
                                @(item.Quantity <= 1 ? "disabled" : "")>
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
                                </svg>
                            </button>
                            <span class="w-10 text-center text-sm font-semibold text-brand-800">@item.Quantity</span>
                            <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                    class="w-8 h-8 rounded-lg border border-brand-200 flex items-center justify-center text-brand-600 hover:bg-brand-50 hover:border-brand-300 transition-all cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
                                @(item.Quantity >= item.MaxQuantity ? "disabled" : "")>
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                                </svg>
                            </button>
                        </form>
                    </div>

                    <!-- Thành tiền -->
                    <div class="text-right flex-shrink-0 min-w-[80px]">
                        <p class="text-sm font-bold text-brand-800">@((item.Price * item.Quantity).ToString("#,###"))₫</p>
                    </div>

                    <!-- Xoá -->
                    <form asp-action="Remove" method="post" onsubmit="return confirm('Xoá @item.Name khỏi giỏ?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@item.ProductId" />
                        <input type="hidden" name="variantId" value="@item.VariantId" />
                        <button type="submit"
                                class="p-2 text-brand-300 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all cursor-pointer flex-shrink-0">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </form>
                </div>
            }
        </div>

        <!-- Tổng cộng -->
        <div class="mt-6 bg-white rounded-2xl border border-brand-100 p-5 sm:p-6">
            <div class="flex items-center justify-between mb-4">
                <span class="text-base font-semibold text-brand-800">Tạm tính</span>
                <span class="text-2xl font-bold text-red-500">@total.ToString("#,###")₫</span>
            </div>
            <p class="text-xs text-brand-400 mb-4">Phí vận chuyển và thuế sẽ được tính ở bước thanh toán.</p>
            <button
                class="w-full bg-orange-500 text-white py-3.5 rounded-xl font-bold text-base hover:bg-orange-600 hover:shadow-lg hover:shadow-orange-500/25 active:scale-[0.98] transition-all duration-200 cursor-pointer">
                Tiến hành đặt hàng
            </button>
            <div class="mt-3 text-center">
                <a asp-controller="Product" asp-action="Index"
                   class="text-sm text-brand-500 hover:text-brand-600 transition-colors">
                    ← Tiếp tục mua sắm
                </a>
            </div>
        </div>
    }
</div>
