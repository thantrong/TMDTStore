@inject TMDTStore.Services.Cart.ICartService CartService
@{
    ViewData["Title"] = "Giỏ hàng";
    var items = CartService.GetCart();
    var isEmpty = items.Count == 0;
    var total = CartService.GetCartTotal();
    var count = CartService.GetCartCount();
}

<div class="max-w-6xl mx-auto">
    <nav class="text-sm text-brand-500 mb-6 flex items-center gap-2 flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="hover:text-brand-600 transition-colors">Trang chủ</a>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-brand-700 font-medium">Giỏ hàng</span>
    </nav>

    @if (isEmpty)
    {
        <div class="text-center py-20">
            <div class="w-40 h-40 mx-auto mb-8 bg-brand-50 rounded-full flex items-center justify-center">
                <svg class="w-20 h-20 text-brand-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
            </div>
            <h1 class="text-3xl font-heading font-bold text-brand-800 mb-3">Giỏ hàng trống</h1>
            <p class="text-brand-400 mb-10 text-lg">Bạn chưa có sản phẩm nào trong giỏ hàng. <br>Hãy thêm sản phẩm vào giỏ để tiếp tục mua sắm.</p>
            <a asp-controller="Product" asp-action="Index"
               class="inline-flex items-center gap-2 bg-brand-600 text-white px-8 py-3.5 rounded-xl font-bold text-base hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 transition-all duration-200">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-heading font-bold text-brand-800">Giỏ hàng <span class="text-brand-400 font-normal text-lg">(@count sản phẩm)</span></h1>
            <form asp-action="Clear" method="post" class="clear-cart-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="text-sm text-red-400 hover:text-red-600 font-medium flex items-center gap-1.5 transition-colors cursor-pointer">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    Xoá tất cả
                </button>
            </form>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 space-y-4">
                @foreach (var item in items)
                {
                    var itemKey = item.VariantId ?? item.ProductId;
                    <div class="bg-white rounded-2xl border border-brand-100 p-4 sm:p-5 flex items-start gap-4 hover:shadow-md transition-shadow duration-200">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                           class="w-24 h-24 sm:w-28 sm:h-28 rounded-xl bg-brand-50 overflow-hidden flex-shrink-0 border border-brand-100">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center text-brand-200">
                                    <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                </div>
                            }
                        </a>

                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-2">
                                <div>
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                                       class="text-sm font-semibold text-brand-800 hover:text-brand-600 transition-colors line-clamp-2 leading-snug">
                                        @item.Name
                                    </a>
                                    @if (!string.IsNullOrEmpty(item.VariantName))
                                    {
                                        <p class="text-xs text-brand-400 mt-1">Phân loại: <span class="font-medium text-brand-500">@item.VariantName</span></p>
                                    }
                                </div>
                                <form asp-action="Remove" method="post" class="hidden sm:block remove-item-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="hidden" name="variantId" value="@item.VariantId" />
                                    <button type="submit" class="p-1.5 text-brand-300 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all cursor-pointer">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                                    </button>
                                </form>
                            </div>

                            <div class="flex items-center justify-between mt-4">
                                <div>
                                    <p class="text-base font-bold text-red-500">@item.Price.ToString("#,###")₫</p>
                                </div>
                                <div class="flex items-center gap-1">
                                    <form asp-action="Update" method="post" class="flex items-center gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <input type="hidden" name="variantId" value="@item.VariantId" />
                                        <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                                class="w-8 h-8 rounded-lg border border-brand-200 flex items-center justify-center text-brand-500 hover:bg-brand-50 hover:border-brand-300 transition-all cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
                                            @(item.Quantity <= 1 ? "disabled" : "")>
                                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" /></svg>
                                        </button>
                                        <span class="w-10 text-center text-sm font-semibold text-brand-800">@item.Quantity</span>
                                        <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                                class="w-8 h-8 rounded-lg border border-brand-200 flex items-center justify-center text-brand-500 hover:bg-brand-50 hover:border-brand-300 transition-all cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed"
                                            @(item.Quantity >= item.MaxQuantity ? "disabled" : "")>
                                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
                                        </button>
                                    </form>
                                </div>
                                <div class="hidden sm:block text-right min-w-[90px]">
                                    <p class="text-base font-bold text-brand-800">@((item.Price * item.Quantity).ToString("#,###"))₫</p>
                                </div>
                            </div>
                            <div class="flex items-center justify-between mt-3 sm:hidden">
                                <form asp-action="Remove" method="post" class="remove-item-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="hidden" name="variantId" value="@item.VariantId" />
                                    <button type="submit" class="text-xs text-red-400 font-medium flex items-center gap-1 cursor-pointer">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                                        Xoá
                                    </button>
                                </form>
                                <p class="text-sm font-bold text-brand-800">@((item.Price * item.Quantity).ToString("#,###"))₫</p>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl border border-brand-100 p-6 sticky top-24">
                    <h2 class="text-base font-bold text-brand-800 mb-5">Thông tin đơn hàng</h2>
                    <div class="space-y-3 pb-4 border-b border-brand-100">
                        <div class="flex items-center justify-between text-sm">
                            <span class="text-brand-500">Tạm tính (@count sản phẩm)</span>
                            <span class="font-semibold text-brand-800">@total.ToString("#,###")₫</span>
                        </div>
                        <div class="flex items-center justify-between text-sm">
                            <span class="text-brand-500">Phí vận chuyển</span>
                            <span class="font-semibold text-brand-400">—</span>
                        </div>
                    </div>
                    <div class="pt-4 mb-6">
                        <div class="flex items-center justify-between">
                            <span class="text-base font-bold text-brand-800">Tổng cộng</span>
                            <span class="text-xl font-bold text-red-500">@total.ToString("#,###")₫</span>
                        </div>
                        <p class="text-xs text-brand-400 mt-1 text-right">(Đã bao gồm VAT)</p>
                    </div>
                    <button class="w-full bg-orange-500 text-white py-3.5 rounded-xl font-bold text-base hover:bg-orange-600 hover:shadow-lg hover:shadow-orange-500/25 active:scale-[0.98] transition-all duration-200 cursor-pointer mb-3">
                        Tiến hành đặt hàng
                    </button>
                    <a asp-controller="Product" asp-action="Index"
                       class="flex items-center justify-center gap-2 w-full py-3 border-2 border-brand-100 text-brand-500 rounded-xl font-semibold text-sm hover:bg-brand-50 hover:border-brand-200 transition-all duration-200">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
                        Tiếp tục mua sắm
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<!-- ====== Confirm Modal ====== -->
<div id="cart-confirm-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl p-6 sm:p-8 max-w-sm w-full mx-4 transform animate-modal-in">
        <div class="text-center">
            <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-red-50 flex items-center justify-center">
                <svg class="w-7 h-7 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
                </svg>
            </div>
            <h3 class="text-lg font-bold text-brand-800 mb-2">Xác nhận xoá</h3>
            <p id="cart-confirm-message" class="text-sm text-brand-500 mb-6">Bạn có chắc chắn muốn xoá sản phẩm này?</p>
            <div class="flex items-center gap-3">
                <button id="cart-confirm-cancel"
                        class="flex-1 py-2.5 border border-brand-200 text-brand-600 rounded-xl font-semibold text-sm hover:bg-brand-50 transition-all duration-200 cursor-pointer">
                    Giữ lại
                </button>
                <button id="cart-confirm-ok"
                        class="flex-1 py-2.5 bg-red-500 text-white rounded-xl font-semibold text-sm hover:bg-red-600 hover:shadow-lg hover:shadow-red-500/25 transition-all duration-200 cursor-pointer">
                    Xoá
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .animate-modal-in {
        animation: modalIn 0.2s ease-out;
    }
    @@keyframes modalIn {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }
</style>

<script>
    (function () {
        var modal = document.getElementById('cart-confirm-modal');
        var msgEl = document.getElementById('cart-confirm-message');
        var cancelBtn = document.getElementById('cart-confirm-cancel');
        var okBtn = document.getElementById('cart-confirm-ok');
        var pendingForm = null;

        function showModal(msg, form) {
            msgEl.textContent = msg;
            pendingForm = form;
            modal.classList.remove('hidden');
        }

        function hideModal() {
            modal.classList.add('hidden');
            pendingForm = null;
        }

        // Remove single item
        document.querySelectorAll('.remove-item-form').forEach(function (form) {
            form.addEventListener('submit', function (e) {
                e.preventDefault();
                var name = this.closest('.flex-1')?.querySelector('.line-clamp-2')?.textContent?.trim() || 'sản phẩm này';
                showModal('Xoá "' + name + '" khỏi giỏ hàng?', this);
            });
        });

        // Clear cart
        var clearForm = document.querySelector('.clear-cart-form');
        if (clearForm) {
            clearForm.addEventListener('submit', function (e) {
                e.preventDefault();
                showModal('Xoá tất cả sản phẩm khỏi giỏ hàng?', this);
            });
        }

        cancelBtn.addEventListener('click', hideModal);
        modal.addEventListener('click', function (e) {
            if (e.target === modal) hideModal();
        });
        okBtn.addEventListener('click', function () {
            if (pendingForm) {
                pendingForm.submit();
            }
            hideModal();
        });
    })();
</script>
