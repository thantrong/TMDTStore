@{
    ViewData["Title"] = "Yêu cầu đặt lại mật khẩu";
}

<div class="min-h-screen flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8 text-center">
        <div class="text-6xl mb-4">📧</div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Đã gửi email</h2>
        <p class="text-gray-600">
            Nếu email tồn tại, chúng tôi đã gửi link đặt lại mật khẩu. Vui lòng kiểm tra hộp thư.
        </p>
        <a asp-action="Login" class="mt-6 inline-block text-indigo-600 hover:text-indigo-800 font-medium">
            Quay lại đăng nhập
        </a>
    </div>
</div>