@model TMDTStore.Models.ViewModels.LoginViewModels

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="min-h-screen flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-8">Đăng nhập</h2>

        <form asp-action="Login" method="post" class="space-y-5">
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Email"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"
                       placeholder="your@email.com" />
                <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Password"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"
                       placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
            </div>

            <div class="flex items-center justify-between">
                <label class="flex items-center">
                    <input asp-for="RememberMe"
                           class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" />
                    <span class="ml-2 text-sm text-gray-600">Ghi nhớ đăng nhập</span>
                </label>
                <a asp-action="ForgotPassword" class="text-sm text-indigo-600 hover:text-indigo-800">Quên mật khẩu?</a>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <button type="submit"
                    class="w-full bg-indigo-600 text-white py-2.5 rounded-lg font-semibold hover:bg-indigo-700 transition">
                Đăng nhập
            </button>
        </form>

        <p class="text-center text-sm text-gray-500 mt-6">
            Chưa có tài khoản?
            <a asp-action="Register" class="text-indigo-600 hover:text-indigo-800 font-medium">Đăng ký ngay</a>
        </p>
    </div>
</div>