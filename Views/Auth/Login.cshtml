@model TMDTStore.Models.ViewModels.LoginViewModels

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="min-h-screen flex items-center justify-center py-12 px-4 bg-slate-50">
    <!-- Back link -->
    <a asp-area="" asp-controller="Home" asp-action="Index"
       class="fixed top-4 left-4 sm:left-6 z-10 inline-flex items-center gap-1.5 text-sm font-medium text-brand-600 hover:text-brand-700 bg-white/80 backdrop-blur-sm px-3 py-2 rounded-xl shadow-sm border border-brand-100 transition-all">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại trang chủ
    </a>

    <div class="w-full max-w-4xl lg:max-w-5xl bg-white rounded-3xl shadow-xl border border-brand-100 overflow-hidden flex flex-col lg:flex-row">

        <!-- Left: Brand Panel -->
        <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-brand-600 via-brand-700 to-brand-900 p-10 xl:p-12 flex-col justify-between relative overflow-hidden">
            <div class="absolute inset-0 opacity-10">
                <div class="absolute top-10 left-10 w-72 h-72 bg-white rounded-full blur-3xl"></div>
                <div class="absolute bottom-10 right-10 w-96 h-96 bg-brand-300 rounded-full blur-3xl"></div>
            </div>
            <div class="relative">
                <div class="flex items-center gap-2.5">
                    <div class="w-12 h-12 rounded-xl bg-white/15 flex items-center justify-center backdrop-blur-sm">
                        <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <span class="font-heading text-2xl font-bold text-white">TVT PC</span>
                </div>
                <h2 class="font-heading text-3xl xl:text-4xl font-bold text-white leading-tight mt-10">
                    Chào mừng<br />trở lại!
                </h2>
                <p class="text-brand-100 text-base mt-4 max-w-sm leading-relaxed">
                    Đăng nhập để tiếp tục mua sắm, theo dõi đơn hàng và nhận ưu đãi thành viên từ TVT PC.
                </p>
            </div>

            <div class="relative space-y-3 mt-10">
                <div class="flex items-center gap-3 text-brand-100">
                    <span class="w-9 h-9 rounded-lg bg-white/15 flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                        </svg>
                    </span>
                    <span class="text-sm">Freeship đơn từ 500K toàn quốc</span>
                </div>
                <div class="flex items-center gap-3 text-brand-100">
                    <span class="w-9 h-9 rounded-lg bg-white/15 flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A12 12 0 113.982 4.984" />
                        </svg>
                    </span>
                    <span class="text-sm">Bảo hành chính hãng 36 tháng</span>
                </div>
                <div class="flex items-center gap-3 text-brand-100">
                    <span class="w-9 h-9 rounded-lg bg-white/15 flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m4 0h1M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z" />
                        </svg>
                    </span>
                    <span class="text-sm">Thanh toán an toàn, bảo mật</span>
                </div>
            </div>
        </div>

        <!-- Right: Form -->
        <div class="w-full lg:w-1/2 p-8 sm:p-10 xl:p-12">
            <div class="flex items-center justify-center gap-2.5 mb-6 lg:hidden">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-600 to-brand-800 flex items-center justify-center shadow-lg shadow-brand-600/20">
                    <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                </div>
                <span class="font-heading text-2xl font-bold text-brand-800">TVT<span class="text-brand-600"> PC</span></span>
            </div>
            <h2 class="font-heading text-2xl font-bold text-brand-800 text-center lg:text-left mb-8">Đăng nhập</h2>

            <form asp-action="Login" method="post" class="space-y-5">
                <div>
                    <label asp-for="Email" class="block text-sm font-medium text-brand-700 mb-1"></label>
                    <input asp-for="Email"
                           class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                           placeholder="your@email.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-medium text-brand-700 mb-1"></label>
                    <input asp-for="Password"
                           class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                           placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
                </div>

                <div class="flex items-center justify-between">
                    <label class="flex items-center">
                        <input asp-for="RememberMe"
                               class="h-4 w-4 text-brand-600 focus:ring-brand-500 border-brand-300 rounded" />
                        <span class="ml-2 text-sm text-brand-600">Ghi nhớ đăng nhập</span>
                    </label>
                    <a asp-action="ForgotPassword" class="text-sm text-brand-600 hover:text-brand-700 font-medium">Quên mật khẩu?</a>
                </div>

                <input type="hidden" asp-for="ReturnUrl" />

                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

                <button type="submit"
                        class="w-full bg-brand-600 text-white py-2.5 rounded-xl font-semibold hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 active:scale-[0.98] transition-all duration-200">
                    Đăng nhập
                </button>
            </form>

            <p class="text-center text-sm text-brand-500 mt-6">
                Chưa có tài khoản?
                <a asp-action="Register" class="text-brand-600 hover:text-brand-700 font-semibold">Đăng ký ngay</a>
            </p>
        </div>
    </div>
</div>