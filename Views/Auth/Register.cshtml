@model TMDTStore.Models.ViewModels.RegisterViewModels

@{
    ViewData["Title"] = "Đăng ký";
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-5 lg:gap-6 items-stretch">
    <!-- Left: 2/3 -->
    <div class="lg:col-span-2 rounded-2xl bg-gradient-to-br from-brand-600 via-brand-700 to-brand-900 p-8 lg:p-10 text-white relative overflow-hidden flex flex-col justify-center gap-8">
        <div class="absolute inset-0 opacity-10 pointer-events-none" aria-hidden="true">
            <div class="absolute top-6 left-6 w-48 h-48 bg-white rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 right-0 w-64 h-64 bg-brand-300 rounded-full blur-3xl"></div>
        </div>
        <div class="relative">
            <p class="text-sm font-medium text-brand-100 uppercase tracking-wide">TVT PC</p>
            <h2 class="font-heading text-3xl font-bold leading-tight mt-2">
                Tạo tài khoản mới
            </h2>
            <p class="text-brand-100 text-sm mt-3 max-w-md leading-relaxed">
                Đăng ký để lưu giỏ hàng, theo dõi đơn và nhận ưu đãi dành riêng cho thành viên.
            </p>
        </div>
        <ul class="relative space-y-2.5 text-sm text-brand-50">
            <li class="flex items-center gap-3">
                <span class="size-8 rounded-lg bg-white/15 flex items-center justify-center shrink-0">
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" /></svg>
                </span>
                Freeship đơn từ 500K toàn quốc
            </li>
            <li class="flex items-center gap-3">
                <span class="size-8 rounded-lg bg-white/15 flex items-center justify-center shrink-0">
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                </span>
                Bảo hành chính hãng lên đến 36 tháng
            </li>
            <li class="flex items-center gap-3">
                <span class="size-8 rounded-lg bg-white/15 flex items-center justify-center shrink-0">
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m4 0h1M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z" /></svg>
                </span>
                Thanh toán an toàn, hỗ trợ VietQR
            </li>
        </ul>
    </div>

    <!-- Right: 1/3 form -->
    <div class="lg:col-span-1 bg-white rounded-2xl shadow-lg border border-brand-100 p-6 sm:p-7 flex flex-col justify-center">
        <h1 class="font-heading text-xl font-bold text-brand-800 mb-5">Đăng ký</h1>

        <form asp-action="Register" method="post" class="space-y-3.5">
            <div>
                <label asp-for="FullName" class="block text-sm font-medium text-brand-700 mb-1"></label>
                <input asp-for="FullName"
                       class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                       placeholder="Nguyễn Văn A" />
                <span asp-validation-for="FullName" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-medium text-brand-700 mb-1"></label>
                <input asp-for="Email"
                       class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                       placeholder="your@email.com" />
                <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="PhoneNumber" class="block text-sm font-medium text-brand-700 mb-1"></label>
                <input asp-for="PhoneNumber"
                       class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                       placeholder="0123456789" />
                <span asp-validation-for="PhoneNumber" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-medium text-brand-700 mb-1"></label>
                <input asp-for="Password"
                       class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                       placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-medium text-brand-700 mb-1"></label>
                <input asp-for="ConfirmPassword"
                       class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                       placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="text-red-500 text-sm"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <button type="submit"
                    class="w-full bg-brand-600 text-white py-2.5 rounded-xl font-semibold hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 active:scale-[0.98] transition-all duration-200 cursor-pointer">
                Đăng ký
            </button>
        </form>

        <p class="text-center text-sm text-brand-500 mt-5">
            Đã có tài khoản?
            <a asp-action="Login" class="text-brand-600 hover:text-brand-700 font-semibold cursor-pointer transition-colors">Đăng nhập</a>
        </p>
    </div>
</div>
