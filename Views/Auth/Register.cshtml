@model TMDTStore.Models.ViewModels.RegisterViewModels

@{
    ViewData["Title"] = "Đăng ký";
}

<div class="min-h-screen flex items-center justify-center py-12 px-4 bg-slate-50">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-lg border border-brand-100 p-8">
        <div class="flex items-center justify-center gap-2.5 mb-6">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-600 to-brand-800 flex items-center justify-center shadow-lg shadow-brand-600/20">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
            </div>
            <span class="font-heading text-2xl font-bold text-brand-800">TVT<span class="text-brand-600"> PC</span></span>
        </div>
        <h2 class="font-heading text-2xl font-bold text-brand-800 text-center mb-8">Đăng ký tài khoản</h2>

        <form asp-action="Register" method="post" class="space-y-5">
            <div>
                <label asp-for="FullName" class="block text-sm font-medium text-brand-700 mb-1"></label>
                <input asp-for="FullName"
                       class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                       placeholder="Nguyễn Văn A" />
                <span asp-validation-for="FullName" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-medium text-brand-700 mb-1"></label>
                <input asp-for="Email"
                       class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                       placeholder="your@email.com" />
                <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="PhoneNumber" class="block text-sm font-medium text-brand-700 mb-1"></label>
                <input asp-for="PhoneNumber"
                       class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                       placeholder="0123456789" />
                <span asp-validation-for="PhoneNumber" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-medium text-brand-700 mb-1"></label>
                <input asp-for="Password"
                       class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                       placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-medium text-brand-700 mb-1"></label>
                <input asp-for="ConfirmPassword"
                       class="w-full px-4 py-2.5 border border-brand-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition text-brand-800"
                       placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="text-red-500 text-sm"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <button type="submit"
                    class="w-full bg-brand-600 text-white py-2.5 rounded-xl font-semibold hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 active:scale-[0.98] transition-all duration-200">
                Đăng ký
            </button>
        </form>

        <p class="text-center text-sm text-brand-500 mt-6">
            Đã có tài khoản?
            <a asp-action="Login" class="text-brand-600 hover:text-brand-700 font-semibold">Đăng nhập</a>
        </p>
    </div>
</div>
