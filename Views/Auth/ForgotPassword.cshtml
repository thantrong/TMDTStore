@model TMDTStore.Models.ViewModels.ForgotPasswordViewModels

@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="min-h-screen flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-8">Quên mật khẩu</h2>
        <p class="text-gray-600 text-center mb-6">Nhập email của bạn, chúng tôi sẽ gửi link đặt lại mật khẩu.</p>

        <form asp-action="ForgotPassword" method="post" class="space-y-5">
            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Email"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"
                       placeholder="your@email.com" />
                <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <button type="submit"
                    class="w-full bg-indigo-600 text-white py-2.5 rounded-lg font-semibold hover:bg-indigo-700 transition">
                Gửi yêu cầu
            </button>
        </form>

        <p class="text-center text-sm text-gray-500 mt-6">
            Nhớ mật khẩu?
            <a asp-action="Login" class="text-indigo-600 hover:text-indigo-800 font-medium">Đăng nhập</a>
        </p>
    </div>
</div>
