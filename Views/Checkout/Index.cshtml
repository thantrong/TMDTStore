@inject TMDTStore.Services.Cart.ICartService CartService
@{
    ViewData["Title"] = "Thanh toán";
    var items = CartService.GetCart();
    var total = CartService.GetCartTotal();
    var count = CartService.GetCartCount();
}

<div class="max-w-4xl mx-auto">
    <nav class="text-sm text-brand-500 mb-6 flex items-center gap-2 flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="hover:text-brand-600">Trang chủ</a>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <a asp-controller="Cart" asp-action="Index" class="hover:text-brand-600">Giỏ hàng</a>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        <span class="text-brand-700 font-medium">Thanh toán</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">
        <!-- FORM -->
        <div class="lg:col-span-3">
            <div class="bg-white rounded-2xl border border-brand-100 p-6">
                <h1 class="text-xl font-heading font-bold text-brand-800 mb-6">Thông tin giao hàng</h1>

                <form asp-action="PlaceOrder" method="post" id="checkout-form">
                    @Html.AntiForgeryToken()

                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-brand-700 mb-1">Họ tên *</label>
                            <input type="text" name="fullName" required
                                   class="w-full px-4 py-2.5 border border-brand-200 rounded-xl text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                                   placeholder="Nguyễn Văn A" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-brand-700 mb-1">Số điện thoại *</label>
                            <input type="tel" name="phone" required
                                   class="w-full px-4 py-2.5 border border-brand-200 rounded-xl text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                                   placeholder="090xxxxxxx" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-brand-700 mb-1">Địa chỉ *</label>
                            <textarea name="address" required rows="3"
                                      class="w-full px-4 py-2.5 border border-brand-200 rounded-xl text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                                      placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-brand-700 mb-1">Ghi chú</label>
                            <textarea name="note" rows="2"
                                      class="w-full px-4 py-2.5 border border-brand-200 rounded-xl text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                                      placeholder="Ghi chú cho đơn hàng (không bắt buộc)"></textarea>
                        </div>
                    </div>

                    <hr class="my-6 border-brand-100" />

                    <h2 class="text-base font-bold text-brand-800 mb-4">Phương thức thanh toán</h2>
                    <div class="space-y-3">
                        <label class="flex items-center gap-3 p-4 border border-brand-200 rounded-xl cursor-pointer hover:border-brand-400 transition-all has-[:checked]:border-brand-600 has-[:checked]:bg-brand-50">
                            <input type="radio" name="paymentMethod" value="COD" checked
                                   class="h-4 w-4 text-brand-600 focus:ring-brand-500" />
                            <div>
                                <p class="text-sm font-semibold text-brand-800">Thanh toán khi nhận hàng (COD)</p>
                                <p class="text-xs text-brand-400">Nhận hàng và thanh toán tại nhà</p>
                            </div>
                        </label>
                        <label class="flex items-center gap-3 p-4 border border-brand-200 rounded-xl cursor-pointer hover:border-brand-400 transition-all has-[:checked]:border-brand-600 has-[:checked]:bg-brand-50">
                            <input type="radio" name="paymentMethod" value="Banking"
                                   class="h-4 w-4 text-brand-600 focus:ring-brand-500" />
                            <div>
                                <p class="text-sm font-semibold text-brand-800">Chuyển khoản ngân hàng (VietQR)</p>
                                <p class="text-xs text-brand-400">Quét mã QR để thanh toán ngay</p>
                            </div>
                        </label>
                    </div>

                    <button type="submit"
                            class="w-full mt-6 bg-orange-500 text-white py-3.5 rounded-xl font-bold text-base hover:bg-orange-600 hover:shadow-lg hover:shadow-orange-500/25 active:scale-[0.98] transition-all duration-200 cursor-pointer">
                        Đặt hàng (@total.ToString("#,###")₫)
                    </button>
                </form>
            </div>
        </div>

        <!-- SUMMARY -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-2xl border border-brand-100 p-6 sticky top-24">
                <h2 class="text-base font-bold text-brand-800 mb-4">Đơn hàng (@count sản phẩm)</h2>
                <div class="space-y-3">
                    @foreach (var item in items)
                    {
                        <div class="flex items-start gap-3 pb-3 border-b border-brand-100 last:border-0">
                            <div class="w-14 h-14 rounded-lg bg-brand-50 overflow-hidden flex-shrink-0 border border-brand-100">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="" class="w-full h-full object-cover" />
                                }
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-xs font-medium text-brand-800 line-clamp-2">@item.Name</p>
                                @if (!string.IsNullOrEmpty(item.VariantName))
                                {
                                    <p class="text-xs text-brand-400">@item.VariantName</p>
                                }
                                <p class="text-xs text-brand-500 mt-0.5">x@item.Quantity</p>
                            </div>
                            <p class="text-xs font-semibold text-brand-800 flex-shrink-0">@((item.Price * item.Quantity).ToString("#,###"))₫</p>
                        </div>
                    }
                </div>

                <div class="border-t border-brand-100 pt-4 mt-4">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-sm text-brand-500">Tạm tính</span>
                        <span class="text-sm font-semibold text-brand-800">@total.ToString("#,###")₫</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-sm font-bold text-brand-800">Tổng cộng</span>
                        <span class="text-lg font-bold text-red-500">@total.ToString("#,###")₫</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
