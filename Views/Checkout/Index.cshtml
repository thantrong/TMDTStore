@inject TMDTStore.Services.Cart.ICartService CartService
@{
    ViewData["Title"] = "Thanh toán";
    var items = CartService.GetCart();
    var total = CartService.GetCartTotal();
    var count = CartService.GetCartCount();
}

<div class="w-full">
    <nav class="text-sm text-brand-500 mb-5 flex items-center gap-2 flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="hover:text-brand-600">Trang chủ</a>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <a asp-controller="Cart" asp-action="Index" class="hover:text-brand-600">Giỏ hàng</a>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-brand-700 font-medium">Thanh toán</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- FORM -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-2xl border border-brand-100 p-6 sm:p-8">
                <h1 class="text-xl font-heading font-bold text-brand-800 mb-6">Thông tin giao hàng</h1>

                <form asp-action="PlaceOrder" method="post" id="checkout-form">
                    @Html.AntiForgeryToken()

                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-brand-700 mb-1">Họ tên *</label>
                            <input type="text" name="fullName" required
                                   class="w-full px-4 py-2.5 border border-brand-200 rounded-xl text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                                   placeholder="Nguyễn Văn A" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-brand-700 mb-1">Số điện thoại *</label>
                            <input type="tel" name="phone" required
                                   class="w-full px-4 py-2.5 border border-brand-200 rounded-xl text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                                   placeholder="090xxxxxxx" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-brand-700 mb-1">Địa chỉ *</label>
                            <textarea name="address" required rows="3"
                                      class="w-full px-4 py-2.5 border border-brand-200 rounded-xl text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                                      placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-brand-700 mb-1">Ghi chú</label>
                            <textarea name="note" rows="2"
                                      class="w-full px-4 py-2.5 border border-brand-200 rounded-xl text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                                      placeholder="Ghi chú cho đơn hàng (không bắt buộc)"></textarea>
                        </div>
                    </div>

                    <hr class="my-6 border-brand-100" />

                    <!-- Mã giảm giá -->
                    <div class="mb-6" id="voucher-section">
                        <h2 class="text-base font-bold text-brand-800 mb-3">Mã giảm giá</h2>
                        <div class="flex items-center gap-2">
                            <input type="text" id="voucher-input"
                                   class="flex-1 px-4 py-2.5 border border-brand-200 rounded-xl text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition uppercase disabled:bg-brand-50 disabled:text-brand-600"
                                   placeholder="Nhập mã giảm giá..." />
                            <button type="button" id="voucher-apply-btn"
                                    class="px-5 py-2.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 hover:shadow-lg transition-all duration-200 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap"
                                    onclick="applyVoucher()">
                                Áp dụng
                            </button>
                            <button type="button" id="voucher-remove-btn"
                                    class="hidden px-4 py-2.5 border border-red-200 text-red-600 rounded-xl font-semibold text-sm hover:bg-red-50 transition-all duration-200 cursor-pointer whitespace-nowrap"
                                    onclick="removeVoucher()">
                                Gỡ mã
                            </button>
                        </div>
                        <div id="voucher-message" class="text-sm mt-2 hidden"></div>
                        <input type="hidden" name="voucherCode" id="voucher-code-input" value="" />
                    </div>

                    <h2 class="text-base font-bold text-brand-800 mb-4">Phương thức thanh toán</h2>
                    <div class="space-y-3">
                        <label
                            class="flex items-center gap-3 p-4 border border-brand-200 rounded-xl cursor-pointer hover:border-brand-400 transition-all has-[:checked]:border-brand-600 has-[:checked]:bg-brand-50">
                            <input type="radio" name="paymentMethod" value="COD" checked
                                   class="h-4 w-4 text-brand-600 focus:ring-brand-500" />
                            <div>
                                <p class="text-sm font-semibold text-brand-800">Thanh toán khi nhận hàng (COD)</p>
                                <p class="text-xs text-brand-400">Nhận hàng và thanh toán tại nhà</p>
                            </div>
                        </label>
                        <label
                            class="flex items-center gap-3 p-4 border border-brand-200 rounded-xl cursor-pointer hover:border-brand-400 transition-all has-[:checked]:border-brand-600 has-[:checked]:bg-brand-50">
                            <input type="radio" name="paymentMethod" value="Banking"
                                   class="h-4 w-4 text-brand-600 focus:ring-brand-500" />
                            <div>
                                <p class="text-sm font-semibold text-brand-800">Chuyển khoản ngân hàng (VietQR)</p>
                                <p class="text-xs text-brand-400">Quét mã QR để thanh toán ngay</p>
                            </div>
                        </label>
                    </div>

                    <button type="submit" id="place-order-btn"
                            class="w-full mt-6 bg-orange-500 text-white py-3.5 rounded-xl font-bold text-base hover:bg-orange-600 hover:shadow-lg hover:shadow-orange-500/25 active:scale-[0.98] transition-all duration-200 cursor-pointer">
                        Đặt hàng (@((total + 30000).ToString("#,###"))₫)
                    </button>
                </form>
            </div>
        </div>

        <!-- SUMMARY -->
        <div class="lg:col-span-1">
            <div class="bg-white rounded-2xl border border-brand-100 p-6 sticky top-24 space-y-5">
                <h2 class="text-base font-bold text-brand-800">Đơn hàng (@count sản phẩm)</h2>
                <div class="space-y-3">
                    @foreach (var item in items)
                    {
                        var hasDiscount = item.ListPrice.HasValue && item.ListPrice > item.Price;
                        var discountPercent = hasDiscount ? (int)(((item.ListPrice.Value - item.Price) / item.ListPrice.Value) * 100) : 0;
                        <div class="flex items-start gap-3 pb-3 border-b border-brand-100 last:border-0">
                            <div
                                class="w-14 h-14 rounded-lg bg-brand-50 overflow-hidden flex-shrink-0 border border-brand-100">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="" loading="lazy" class="w-full h-full object-cover" />
                                }
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-xs font-medium text-brand-800 line-clamp-2">@item.Name</p>
                                @if (!string.IsNullOrEmpty(item.VariantName))
                                {
                                    <p class="text-xs text-brand-400">@item.VariantName</p>
                                }
                                <div class="flex items-center gap-1.5 mt-0.5">
                                    <span class="text-xs font-semibold text-red-500">@item.Price.ToString("#,###")₫</span>
                                    @if (hasDiscount)
                                    {
                                        <span class="text-xs text-brand-400 line-through">@item.ListPrice?.ToString("#,###")₫</span>
                                        <span class="text-[10px] font-bold text-green-600 bg-green-50 px-1.5 py-0.5 rounded-full">-@discountPercent%</span>
                                    }
                                </div>
                                <p class="text-xs text-brand-500">x@(item.Quantity)</p>
                            </div>
                            <p class="text-xs font-semibold text-brand-800 flex-shrink-0">@((item.Price *
                                                            item.Quantity).ToString("#,###"))₫</p>
                            </div>
                        }
                    </div>

                    <div class="border-t border-brand-100 pt-4">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm text-brand-500">Tạm tính</span>
                            <span class="text-sm font-semibold text-brand-800">@total.ToString("#,###")₫</span>
                        </div>
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-sm text-brand-500">Phí vận chuyển</span>
                            <span class="text-sm font-semibold text-brand-800">30.000₫</span>
                        </div>
                        <div class="flex items-center justify-between mb-2 hidden" id="voucher-discount-row">
                            <span class="text-sm text-brand-500">Giảm giá</span>
                            <span class="text-sm font-semibold text-red-500" id="voucher-discount-amount">-0₫</span>
                        </div>
                        <div class="flex items-center justify-between pt-3 border-t border-brand-100">
                            <span class="text-sm font-bold text-brand-800">Tổng cộng</span>
                            <span class="text-lg font-bold text-red-500" id="order-total-display">@((total + 30000).ToString("#,###"))₫</span>
                        </div>
                    </div>

                    <div class="rounded-xl bg-brand-50 border border-brand-100 p-4 space-y-2.5 text-xs text-brand-600">
                        <p class="font-semibold text-brand-800 text-sm">Cam kết khi đặt hàng</p>
                        <p class="flex items-start gap-2">
                            <svg class="size-4 text-brand-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                            Sản phẩm chính hãng, hoá đơn VAT đầy đủ
                        </p>
                        <p class="flex items-start gap-2">
                            <svg class="size-4 text-brand-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                            Đổi trả trong 30 ngày nếu lỗi nhà sản xuất
                        </p>
                        <p class="flex items-start gap-2">
                            <svg class="size-4 text-brand-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                            Hỗ trợ kỹ thuật trước và sau bán
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var checkoutTotal = @(total + 30000);
        var checkoutCount = @count;
        var checkoutSubtotal = @total;
        var applyBtnClass = 'px-5 py-2.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 hover:shadow-lg transition-all duration-200 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed whitespace-nowrap';
        var appliedBtnClass = 'px-5 py-2.5 bg-green-600 text-white rounded-xl font-semibold text-sm cursor-not-allowed whitespace-nowrap';

        function formatVnd(amount) {
            return Math.round(amount).toLocaleString('vi-VN') + '₫';
        }

        function setOrderTotals(discountAmount) {
            var discount = discountAmount || 0;
            var newTotal = checkoutSubtotal + 30000 - discount;
            if (newTotal < 0) newTotal = 0;
            document.getElementById('order-total-display').textContent = formatVnd(newTotal);
            document.getElementById('place-order-btn').textContent = 'Đặt hàng (' + formatVnd(newTotal) + ')';
        }

        function setAppliedState(code, discountAmount, discountFormatted, message) {
            var input = document.getElementById('voucher-input');
            var btn = document.getElementById('voucher-apply-btn');
            var removeBtn = document.getElementById('voucher-remove-btn');
            var msg = document.getElementById('voucher-message');
            var discountRow = document.getElementById('voucher-discount-row');

            input.value = code;
            input.disabled = true;
            document.getElementById('voucher-code-input').value = code;

            btn.textContent = 'Đã áp dụng';
            btn.disabled = true;
            btn.className = appliedBtnClass;
            removeBtn.classList.remove('hidden');

            discountRow.classList.remove('hidden');
            document.getElementById('voucher-discount-amount').textContent = '-' + discountFormatted;
            setOrderTotals(discountAmount);

            msg.className = 'text-sm mt-2 text-green-600 font-medium';
            msg.textContent = message || ('Đã áp dụng mã ' + code + '. Bạn có thể gỡ mã để nhập mã khác.');
            msg.classList.remove('hidden');
        }

        function removeVoucher() {
            var input = document.getElementById('voucher-input');
            var btn = document.getElementById('voucher-apply-btn');
            var removeBtn = document.getElementById('voucher-remove-btn');
            var msg = document.getElementById('voucher-message');
            var discountRow = document.getElementById('voucher-discount-row');

            document.getElementById('voucher-code-input').value = '';
            input.value = '';
            input.disabled = false;
            input.focus();

            btn.textContent = 'Áp dụng';
            btn.disabled = false;
            btn.className = applyBtnClass;
            removeBtn.classList.add('hidden');

            discountRow.classList.add('hidden');
            document.getElementById('voucher-discount-amount').textContent = '-0₫';
            setOrderTotals(0);

            msg.className = 'text-sm mt-2 text-brand-500';
            msg.textContent = 'Đã gỡ mã giảm giá. Bạn có thể nhập mã khác.';
            msg.classList.remove('hidden');
        }

        function applyVoucher() {
            var input = document.getElementById('voucher-input');
            var code = input.value.trim().toUpperCase();
            var msg = document.getElementById('voucher-message');
            var btn = document.getElementById('voucher-apply-btn');

            if (!code) {
                msg.className = 'text-sm mt-2 text-red-500';
                msg.textContent = 'Vui lòng nhập mã giảm giá.';
                msg.classList.remove('hidden');
                return;
            }

            btn.disabled = true;
            btn.textContent = 'Đang kiểm tra...';
            msg.className = 'text-sm mt-2 hidden';

            fetch('/Checkout/ApplyVoucher', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: 'code=' + encodeURIComponent(code)
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    setAppliedState(code, data.discountAmount, data.discountFormatted, data.message);
                } else {
                    btn.disabled = false;
                    btn.textContent = 'Áp dụng';
                    btn.className = applyBtnClass;
                    msg.className = 'text-sm mt-2 text-red-500';
                    msg.textContent = data.message;
                    msg.classList.remove('hidden');
                    document.getElementById('voucher-code-input').value = '';
                }
            })
            .catch(function() {
                btn.disabled = false;
                btn.textContent = 'Áp dụng';
                btn.className = applyBtnClass;
                msg.className = 'text-sm mt-2 text-red-500';
                msg.textContent = 'Lỗi kết nối, vui lòng thử lại.';
                msg.classList.remove('hidden');
            });
        }

        document.getElementById('voucher-input').addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                if (!this.disabled) applyVoucher();
            }
        });
    </script>
}
