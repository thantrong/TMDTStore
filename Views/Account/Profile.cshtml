@model TMDTStore.Models.ViewModels.ProfileViewModels

@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="max-w-2xl mx-auto py-8">
    <a asp-action="Index" class="inline-flex items-center text-sm text-indigo-600 hover:text-indigo-800 mb-6">
        <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại
    </a>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
        <h1 class="text-2xl font-bold text-gray-900 mb-8">Thông tin cá nhân</h1>

        <form asp-action="Profile" method="post" class="space-y-6">
            <div class="flex flex-col items-center mb-6">
                <div
                    class="w-24 h-24 rounded-full bg-indigo-100 flex items-center justify-center text-4xl font-bold text-indigo-600 overflow-hidden mb-3">
                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="@Model.AvatarUrl" alt="Avatar" class="w-full h-full object-cover" id="avatar-preview" />
                    }
                    else
                    {
                        <span id="avatar-placeholder">@Model.FullName[..1].ToUpper()</span>
                    }
                </div>
            </div>

            <div>
                <label asp-for="FullName" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="FullName"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" />
                <span asp-validation-for="FullName" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Email" disabled
                       class="w-full px-4 py-2 border border-gray-200 rounded-lg bg-gray-50 text-gray-500 cursor-not-allowed" />
                <p class="text-xs text-gray-400 mt-1">Email không thể thay đổi.</p>
            </div>

            <div>
                <label asp-for="PhoneNumber" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="PhoneNumber"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"
                       placeholder="0123456789" />
                <span asp-validation-for="PhoneNumber" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="AvatarUrl" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="AvatarUrl" id="avatar-input"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"
                       placeholder="https://example.com/avatar.jpg" />
                <span asp-validation-for="AvatarUrl" class="text-red-500 text-sm"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <button type="submit"
                    class="w-full bg-indigo-600 text-white py-2.5 rounded-lg font-semibold hover:bg-indigo-700 transition">
                Lưu thay đổi
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('avatar-input')?.addEventListener('input', function () {
            var url = this.value;
            var preview = document.getElementById('avatar-preview');
            var placeholder = document.getElementById('avatar-placeholder');
            if (url && preview) {
                preview.src = url;
                preview.style.display = 'block';
                if (placeholder) placeholder.style.display = 'none';
            }
        });
    </script>
}
