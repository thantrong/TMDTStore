@model TMDTStore.Models.ViewModels.ChangePasswordViewModels

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="max-w-2xl mx-auto py-8">
    <a asp-action="Index" class="inline-flex items-center text-sm text-indigo-600 hover:text-indigo-800 mb-6">
        <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại
    </a>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
        <h1 class="text-2xl font-bold text-gray-900 mb-8">Đổi mật khẩu</h1>

        <form asp-action="ChangePassword" method="post" class="space-y-6">
            <div>
                <label asp-for="CurrentPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="CurrentPassword"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"
                       placeholder="••••••••" />
                <span asp-validation-for="CurrentPassword" class="text-red-500 text-sm"></span>
            </div>

            <div>
                <label asp-for="NewPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="NewPassword"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"
                       placeholder="••••••••" />
                <span asp-validation-for="NewPassword" class="text-red-500 text-sm"></span>
                <p class="text-xs text-gray-400 mt-1">Mật khẩu phải có ít nhất 6 ký tự.</p>
            </div>

            <div>
                <label asp-for="ConfirmNewPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ConfirmNewPassword"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition"
                       placeholder="••••••••" />
                <span asp-validation-for="ConfirmNewPassword" class="text-red-500 text-sm"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <button type="submit"
                    class="w-full bg-indigo-600 text-white py-2.5 rounded-lg font-semibold hover:bg-indigo-700 transition">
                Đổi mật khẩu
            </button>
        </form>
    </div>
</div>
