@model TMDTStore.Models.User
@{
    ViewData["Title"] = "Tài khoản của tôi";
    var orders = ViewBag.RecentOrders as List<TMDTStore.Models.Order> ?? new();
    var reviews = ViewBag.RecentReviews as List<TMDTStore.Models.Review> ?? new();
    var totalOrders = ViewBag.TotalOrders as int? ?? 0;
    var totalReviews = ViewBag.TotalReviews as int? ?? 0;

    var statusLabels = new Dictionary<string, string>
    {
        { "Pending", "Chờ xử lý" }, { "WaitingPayment", "Chờ thanh toán" },
        { "Confirmed", "Đã xác nhận" }, { "Shipping", "Đang giao" },
        { "Delivered", "Đã giao" }, { "Cancelled", "Đã huỷ" }
    };
    var statusColors = new Dictionary<string, string>
    {
        { "Pending", "bg-amber-50 text-amber-700" }, { "WaitingPayment", "bg-yellow-50 text-yellow-700" },
        { "Confirmed", "bg-blue-50 text-blue-700" }, { "Shipping", "bg-purple-50 text-purple-700" },
        { "Delivered", "bg-emerald-50 text-emerald-700" }, { "Cancelled", "bg-red-50 text-red-700" }
    };
}

<div class="max-w-5xl mx-auto py-6 sm:py-8 px-4">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-5 mb-8">
        <div
            class="w-20 h-20 rounded-full bg-gradient-to-br from-brand-100 to-brand-200 flex items-center justify-center text-3xl font-bold text-brand-700 overflow-hidden flex-shrink-0 ring-4 ring-brand-50 shadow-md">
            @if (!string.IsNullOrEmpty(Model.AvatarUrl))
            {
                <img src="@Model.AvatarUrl" alt="Avatar" class="w-full h-full object-cover" />
            }
            else
            {
                @Model.FullName[..1].ToUpper()
            }
        </div>
        <div class="flex-1">
            <h1 class="text-2xl font-bold text-brand-800">Xin chào, @Model.FullName</h1>
            <p class="text-brand-400 flex items-center gap-1.5 mt-0.5">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                @Model.Email
            </p>
        </div>
        <span class="px-3 py-1 bg-brand-50 text-brand-600 rounded-full text-xs font-semibold border border-brand-100">
            Thành viên từ @(Model.CreatedAt?.ToString("MM/yyyy") ?? "---")
        </span>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white rounded-xl border border-brand-100 p-4 sm:p-5">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-brand-50 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                         stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-brand-800">@totalOrders</p>
                    <p class="text-xs text-brand-400">Đơn hàng</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl border border-brand-100 p-4 sm:p-5">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-yellow-50 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                         stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-brand-800">@totalReviews</p>
                    <p class="text-xs text-brand-400">Đánh giá</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl border border-brand-100 p-4 sm:p-5">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-green-50 flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                         stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-bold text-brand-800">@(Model.EmailConfirmed ? "Đã XN" : "Chưa XN")</p>
                    <p class="text-xs text-brand-400">Email</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-xl border border-brand-100 p-4 sm:p-5">
            <div class="flex items-center gap-3">
                <div
                    class="w-10 h-10 rounded-lg @(Model.IsActive == true ? "bg-emerald-50" : "bg-red-50") flex items-center justify-center flex-shrink-0">
                    <span
                    class="w-3 h-3 rounded-full @(Model.IsActive == true ? "bg-emerald-500" : "bg-red-500")"></span>
                </div>
                <div>
                    <p class="text-2xl font-bold text-brand-800">@(Model.IsActive == true ? "Hoạt động" : "Đã khoá")</p>
                    <p class="text-xs text-brand-400">Trạng thái</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <a asp-action="Profile"
           class="group bg-white rounded-xl border border-brand-100 p-5 hover:border-brand-300 hover:shadow-lg hover:shadow-brand-100/50 transition-all duration-200">
            <div class="flex items-center gap-4">
                <div
                    class="w-12 h-12 rounded-xl bg-brand-50 flex items-center justify-center group-hover:bg-brand-100 transition-colors">
                    <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                         stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                </div>
                <div>
                    <h3 class="font-semibold text-brand-800 group-hover:text-brand-600">Thông tin cá nhân</h3>
                    <p class="text-xs text-brand-400 mt-0.5">Họ tên, SĐT, ảnh đại diện</p>
                </div>
                <svg class="w-5 h-5 text-brand-300 ml-auto group-hover:text-brand-500 transition-colors" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
            </div>
        </a>
        <a asp-action="ChangePassword"
           class="group bg-white rounded-xl border border-brand-100 p-5 hover:border-brand-300 hover:shadow-lg hover:shadow-brand-100/50 transition-all duration-200">
            <div class="flex items-center gap-4">
                <div
                    class="w-12 h-12 rounded-xl bg-brand-50 flex items-center justify-center group-hover:bg-brand-100 transition-colors">
                    <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                         stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </div>
                <div>
                    <h3 class="font-semibold text-brand-800 group-hover:text-brand-600">Đổi mật khẩu</h3>
                    <p class="text-xs text-brand-400 mt-0.5">Thay đổi mật khẩu đăng nhập</p>
                </div>
                <svg class="w-5 h-5 text-brand-300 ml-auto group-hover:text-brand-500 transition-colors" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
            </div>
        </a>
        <a asp-controller="Order" asp-action="History"
           class="group bg-white rounded-xl border border-brand-100 p-5 hover:border-brand-300 hover:shadow-lg hover:shadow-brand-100/50 transition-all duration-200">
            <div class="flex items-center gap-4">
                <div
                    class="w-12 h-12 rounded-xl bg-brand-50 flex items-center justify-center group-hover:bg-brand-100 transition-colors">
                    <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                         stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                    </svg>
                </div>
                <div>
                    <h3 class="font-semibold text-brand-800 group-hover:text-brand-600">Đơn hàng của tôi</h3>
                    <p class="text-xs text-brand-400 mt-0.5">Xem lịch sử mua hàng</p>
                </div>
                <svg class="w-5 h-5 text-brand-300 ml-auto group-hover:text-brand-500 transition-colors" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
            </div>
        </a>
    </div>

    <!-- Recent Orders -->
    <div class="bg-white rounded-xl border border-brand-100 overflow-hidden mb-6">
        <div class="flex items-center justify-between px-5 py-4 border-b border-brand-100">
            <h2 class="font-bold text-brand-800">Đơn hàng gần đây</h2>
            <a asp-controller="Order" asp-action="History"
               class="text-sm font-medium text-brand-600 hover:text-brand-700 transition-colors">Xem tất cả →</a>
        </div>
        @if (orders.Count > 0)
        {
            <div class="divide-y divide-brand-100">
                @foreach (var order in orders)
                {
                    var sc = statusColors.ContainsKey(order.Status) ? statusColors[order.Status] : "bg-gray-50 text-gray-700";
                    var sl = statusLabels.ContainsKey(order.Status) ? statusLabels[order.Status] : order.Status;
                    <a asp-controller="Order" asp-action="Details" asp-route-id="@order.Id"
                       class="flex items-center justify-between px-5 py-3.5 hover:bg-brand-50 transition-colors">
                        <div>
                            <p class="text-sm font-medium text-brand-800">#@order.Id</p>
                            <p class="text-xs text-brand-400 mt-0.5">@order.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="text-right">
                            <p class="text-sm font-bold text-brand-800">@order.TotalPrice.ToString("#,###")₫</p>
                            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium mt-1 @sc">@sl</span>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="px-5 py-8 text-center">
                <svg class="w-12 h-12 mx-auto text-brand-200 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                     stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                <p class="text-sm text-brand-400">Chưa có đơn hàng nào</p>
                <a asp-controller="Product" asp-action="Index"
                   class="mt-2 inline-block text-sm font-medium text-brand-600 hover:underline">Mua sắm ngay</a>
            </div>
        }
    </div>

    <!-- Recent Reviews -->
    <div class="bg-white rounded-xl border border-brand-100 overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-brand-100">
            <h2 class="font-bold text-brand-800">Đánh giá gần đây</h2>
        </div>
        @if (reviews.Count > 0)
        {
            <div class="divide-y divide-brand-100">
                @foreach (var review in reviews)
                {
                    <div class="px-5 py-3.5">
                        <div class="flex items-center gap-2 flex-wrap">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@review.ProductId"
                               class="text-sm font-medium text-brand-700 hover:text-brand-600 line-clamp-1">@(review.Product?.Name
                                                       ?? "---")</a>
                                <span class="text-xs text-brand-400">· @review.CreatedAt?.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="flex items-center gap-0.5 mt-1">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="text-xs @(i <= (review.Rating ?? 0) ? "text-yellow-400" : "text-brand-200")">★</span>
                                }
                            </div>
                            <p class="text-xs text-brand-500 mt-1 line-clamp-1">@review.Comment</p>
                        </div>
                    }
                </div>
            }
        else
            {
                <div class="px-5 py-8 text-center">
                    <svg class="w-12 h-12 mx-auto text-brand-200 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                         stroke-width="1">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                    </svg>
                    <p class="text-sm text-brand-400">Chưa có đánh giá nào</p>
                </div>
            }
        </div>
    </div>

    <!-- Test Email -->
    <div class="bg-white rounded-xl border border-brand-100 overflow-hidden">
        <div class="px-5 py-4 border-b border-brand-100">
            <h2 class="font-bold text-brand-800">Kiểm tra gửi email</h2>
            <p class="text-xs text-brand-400 mt-0.5">Gửi thử email kiểm tra hệ thống SMTP</p>
        </div>
        <form asp-action="TestMail" method="post" class="p-5 flex items-center gap-3">
            @Html.AntiForgeryToken()
            <input type="email" name="email" value="@Model.Email" required
                   class="flex-1 px-4 py-2 border border-brand-200 rounded-xl text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                   placeholder="Nhập email nhận thử..." />
            <button type="submit"
                    class="px-5 py-2 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 transition-all duration-200 cursor-pointer whitespace-nowrap flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                Gửi thử
            </button>
        </form>
    </div>
</div>
