@{
    ViewData["Title"] = "Truy cập bị từ chối";
}

<div class="min-h-[60vh] flex items-center justify-center px-4">
    <div class="text-center max-w-md">
        <div class="w-20 h-20 rounded-full bg-red-50 flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M12 15v2m0 0v3m0-3h3m-3 0H9m11.9-5.5a9.01 9.01 0 00-4.4-4.4M15 9a3 3 0 11-6 0 3 3 0 016 0zM12 2a10 10 0 100 20 10 10 0 000-20z" />
            </svg>
        </div>
        <h1 class="text-2xl font-bold text-brand-800 mb-2">🔒 Truy cập bị từ chối</h1>
        <p class="text-brand-500 mb-2">Bạn không có quyền truy cập vào trang này.</p>
        <p class="text-sm text-brand-400 mb-8">Vui lòng liên hệ quản trị viên nếu bạn cần quyền truy cập.</p>
        <div class="flex items-center justify-center gap-3">
            <a asp-controller="Home" asp-action="Index"
               class="inline-flex items-center gap-2 px-6 py-2.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 transition-all duration-200">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Về trang chủ
            </a>
            <a asp-controller="Auth" asp-action="Login"
               class="inline-flex items-center gap-2 px-6 py-2.5 border border-brand-200 text-brand-600 rounded-xl font-semibold text-sm hover:bg-brand-50 transition-all duration-200">
                Đăng nhập
            </a>
        </div>
    </div>
</div>
