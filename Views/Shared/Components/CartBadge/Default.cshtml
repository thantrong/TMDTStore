@model int

<a asp-controller="Cart" asp-action="Index"
   class="relative p-2.5 text-brand-500 hover:text-brand-600 hover:bg-brand-50 rounded-xl transition-all duration-200 cursor-pointer"
   aria-label="Giỏ hàng">
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
    </svg>
    @if (Model > 0)
    {
        <span
            class="absolute -top-1 -right-1 w-5 h-5 bg-orange-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center shadow-lg shadow-orange-500/30">
            @(Model > 99 ? "99+" : Model.ToString())
        </span>
    }
</a>
