@{
    var productId = ViewBag.ProductId as string ?? "";
    var ragEndpoint = ViewBag.RagEndpoint as string ?? "http://localhost:8001/api/rag/chat/stream";
    var hasProduct = !string.IsNullOrEmpty(productId);
}

<style>
  #chatbot-widget { font-family: inherit; }
  #chatbot-panel {
    box-shadow: 0 25px 50px -12px rgba(15, 23, 42, 0.25), 0 0 0 1px rgba(15, 23, 42, 0.04);
  }
  #chatbot-messages { scrollbar-width: thin; scrollbar-color: #cbd5e1 transparent; }
  #chatbot-messages::-webkit-scrollbar { width: 5px; }
  #chatbot-messages::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 999px; }
  .chatbot-message { animation: chatbotIn 0.28s ease-out; }
  @@keyframes chatbotIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .chatbot-product-card {
    display: block;
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .chatbot-product-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px -8px rgba(15, 23, 42, 0.18);
    border-color: #94a3b8;
  }
  .chatbot-answer a { word-break: break-all; }
</style>

<div id="chatbot-widget"
     data-product-id="@productId"
     data-rag-endpoint="@ragEndpoint"
     class="fixed bottom-5 right-5 z-[60] sm:bottom-6 sm:right-6">

    <button id="chatbot-toggle"
            class="relative w-14 h-14 rounded-2xl bg-brand-800 text-white
                   shadow-lg shadow-brand-900/25
                   hover:bg-brand-700 hover:shadow-xl hover:-translate-y-0.5
                   active:scale-95 transition-all duration-200
                   flex items-center justify-center cursor-pointer"
            aria-label="Mở chat tư vấn">
        <svg id="chatbot-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <svg id="chatbot-close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
        <span class="absolute -top-0.5 -right-0.5 w-3 h-3 rounded-full bg-emerald-400 ring-2 ring-white"></span>
    </button>

    <div id="chatbot-panel"
         class="absolute bottom-[4.25rem] right-0 w-[min(400px,calc(100vw-1.5rem))]
                bg-white rounded-2xl flex flex-col overflow-hidden
                transition-all duration-300 origin-bottom-right
                opacity-0 scale-95 pointer-events-none"
         style="height: min(620px, calc(100vh - 7rem));">

        <div class="px-4 py-3.5 flex items-center gap-3 flex-shrink-0 bg-brand-900 text-white">
            <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
            </div>
            <div class="flex-1 min-w-0">
                <h3 class="font-heading font-semibold text-sm tracking-tight">TVT PC Assistant</h3>
                <p class="text-white/60 text-[11px] mt-0.5 flex items-center gap-1.5">
                    <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                    @(hasProduct ? "Đang tư vấn sản phẩm này" : "Tư vấn mua sắm trực tuyến")
                </p>
            </div>
            <button id="chatbot-minimize"
                    class="text-white/50 hover:text-white p-1.5 rounded-lg hover:bg-white/10 transition-colors cursor-pointer"
                    aria-label="Thu nhỏ">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
            </button>
        </div>

        <div id="chatbot-messages" class="flex-1 overflow-y-auto px-4 py-4 space-y-4 bg-[#f7f8fa]">
            <div class="flex items-end gap-2.5 chatbot-message bot">
                <div class="w-7 h-7 rounded-lg bg-brand-900 text-white flex items-center justify-center flex-shrink-0 text-[10px] font-bold">AI</div>
                <div class="bg-white rounded-2xl rounded-bl-md px-3.5 py-3 shadow-sm border border-slate-100/80 max-w-[88%]">
                    <p class="text-[13px] text-slate-700 leading-relaxed">
                        @(hasProduct
                            ? "Xin chào! Mình có thể giải đáp thông số, giá và đánh giá về sản phẩm này."
                            : "Xin chào! Bạn đang tìm laptop, linh kiện hay phụ kiện nào? Mình sẽ gợi ý phù hợp.")
                    </p>
                </div>
            </div>
        </div>

        <div id="chatbot-loading" class="hidden px-4 py-2 bg-[#f7f8fa]">
            <div class="inline-flex items-center gap-2 text-slate-400 text-[11px] bg-white border border-slate-100 rounded-full px-3 py-1.5 shadow-sm">
                <span class="flex gap-1">
                    <span class="w-1.5 h-1.5 bg-brand-500 rounded-full animate-bounce" style="animation-delay:0ms"></span>
                    <span class="w-1.5 h-1.5 bg-brand-500 rounded-full animate-bounce" style="animation-delay:150ms"></span>
                    <span class="w-1.5 h-1.5 bg-brand-500 rounded-full animate-bounce" style="animation-delay:300ms"></span>
                </span>
                Đang soạn câu trả lời…
            </div>
        </div>

        <div class="border-t border-slate-100 p-3 bg-white flex-shrink-0">
            <form id="chatbot-form" class="flex items-end gap-2">
                <input id="chatbot-input" type="text"
                       class="flex-1 bg-slate-50 rounded-xl px-3.5 py-2.5 text-[13px] text-slate-800
                              placeholder-slate-400 outline-none border border-slate-200
                              focus:border-brand-400 focus:bg-white focus:ring-2 focus:ring-brand-100 transition-all"
                       placeholder="Hỏi về sản phẩm, giá, cấu hình…"
                       autocomplete="off" />
                <button type="submit"
                        class="bg-brand-800 text-white p-2.5 rounded-xl hover:bg-brand-700
                               active:scale-95 transition-all disabled:opacity-40
                               disabled:cursor-not-allowed flex-shrink-0 cursor-pointer"
                        aria-label="Gửi">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                </button>
            </form>
        </div>
    </div>
</div>

<script src="~/js/chatbot.js" asp-append-version="true"></script>
