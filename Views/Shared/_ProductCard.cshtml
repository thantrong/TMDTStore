@model TMDTStore.Models.Product

@{
    var hasPrice = Model.Price.HasValue;
    var hasDiscount = hasPrice && Model.ListPrice.HasValue && Model.ListPrice > Model.Price.Value;
    var discountPercent = hasDiscount ? (int)(((Model.ListPrice.Value - Model.Price.Value) / Model.ListPrice.Value) * 100) :
0;
    var hasVariantsLoaded = Model.ProductVariants != null && Model.ProductVariants.Count > 0;
}

<a asp-controller="Product" asp-action="Details" asp-route-slug="@Model.Slug"
   class="group bg-white rounded-xl border border-brand-100 overflow-hidden hover:border-brand-300 hover:shadow-lg hover:shadow-brand-100/50 transition-all duration-200 cursor-pointer flex flex-col">

    @{
        var totalStock = 0;
        var hasStockInfo = false;
        if (hasVariantsLoaded)
        {
            totalStock = Model.ProductVariants.Sum(v => v.StockQuantity);
            hasStockInfo = true;
        }
        else if (Model.Inventory != null)
        {
            totalStock = Model.Inventory.StockQuantity;
            hasStockInfo = true;
        }
        var isOutOfStock = hasStockInfo && totalStock <= 0;
    }

    <!-- Image -->
    <div class="aspect-square bg-brand-50 overflow-hidden relative">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" loading="lazy"
                 class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300 @(isOutOfStock ? "opacity-40" : "")" />
        }
        else if (hasVariantsLoaded && Model.ProductVariants.Any(v => !string.IsNullOrEmpty(v.ImageUrl)))
        {
            var cheapest = Model.ProductVariants.Where(v => !string.IsNullOrEmpty(v.ImageUrl)).OrderBy(v =>
        v.Price).First();
            var firstImg = cheapest.ImageUrl;
            <img src="@firstImg" alt="@Model.Name" loading="lazy"
                 class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300 @(isOutOfStock ? "opacity-40" : "")" />
        }
        else
        {
            <div class="w-full h-full flex items-center justify-center text-brand-200">
                <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>
        }

        <!-- Out of stock overlay -->
        @if (isOutOfStock)
        {
            <div class="absolute inset-0 flex items-center justify-center">
                <span class="bg-red-500/80 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-lg">
                    Hết hàng
                </span>
            </div>
        }

        <!-- Badge -->
        @if (hasDiscount)
        {
            <span
                class="absolute top-2 left-2 bg-orange-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full shadow-lg shadow-orange-500/30">
                -@discountPercent%
            </span>
        }
        @if (Model.ProductBadges.Count > 0)
        {
            <span class="absolute top-2 right-2 bg-amber-500 text-white text-[10px] font-bold px-2 py-0.5 rounded-full">
                @Model.ProductBadges.First().Label
            </span>
        }
    </div>

    <!-- Info -->
    <div class="p-3 sm:p-4 flex flex-col flex-1">
        @if (!string.IsNullOrEmpty(Model.Brand?.Name))
        {
            <p class="text-xs text-brand-400 mb-0.5">@Model.Brand.Name</p>
        }
        <h3 class="text-sm font-medium text-brand-800 line-clamp-2 mb-2 flex-1 min-h-[2.5rem] leading-snug">
            @Model.Name
        </h3>

        <!-- Rating -->
        @if (Model.RatingCount > 0)
        {
            <div class="flex items-center gap-1 mb-1.5">
                <span class="text-yellow-400 text-xs">★</span>
                <span class="text-xs font-medium text-brand-600">@Model.RatingAvg.ToString("F1")</span>
                <span class="text-xs text-brand-400">(@Model.RatingCount)</span>
            </div>
        }

        <!-- Price -->
        <div class="flex items-baseline gap-2 flex-wrap">
            @if (hasPrice)
            {
                <span class="text-base sm:text-lg font-bold text-red-500">@Model.Price.Value.ToString("#,###")₫</span>
                if (hasDiscount)
                {
                    <span class="text-xs text-brand-400 line-through">@Model.ListPrice?.ToString("#,###")₫</span>
                }
            }
            else if (hasVariantsLoaded)
            {
                var minPrice = Model.ProductVariants.Min(v => v.Price);
                var maxPrice = Model.ProductVariants.Max(v => v.Price);
                <span class="text-base sm:text-lg font-bold text-red-500">
                    @(minPrice.ToString("#,###"))₫
                    @if (maxPrice > minPrice)
                    {
                        <span class="text-sm font-normal text-brand-400"> - @(maxPrice.ToString("#,###"))₫</span>
                    }
                </span>
            }
            else
            {
                <span class="text-base sm:text-lg font-semibold text-brand-400">Liên hệ</span>
            }
        </div>

        <!-- Stock -->
        @if (hasStockInfo)
        {
            <div class="mt-1.5 text-xs @(totalStock > 0 ? "text-emerald-600" : "text-red-400")">
                @(totalStock > 0 ? "Còn " + totalStock + " sản phẩm" : "Hết hàng")
            </div>
        }
        else if (Model.Inventory != null)
        {
            <div class="mt-1.5 text-xs @(Model.Inventory.StockQuantity > 0 ? "text-emerald-600" : "text-red-400")">
                @(Model.Inventory.StockQuantity > 0 ? "Còn " + Model.Inventory.StockQuantity + " sản phẩm" : "Hết hàng")
            </div>
        }
    </div>
</a>
