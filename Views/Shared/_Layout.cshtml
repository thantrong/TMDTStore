<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TVT PC</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
    rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <script>
        tailwind.config = {
        theme: {
        extend: {
        colors: {
        brand: {
        50: '#ECFDF5',
        100: '#D1FAE5',
        200: '#A7F3D0',
        300: '#6EE7B7',
        400: '#34D399',
        500: '#10B981',
        600: '#059669',
        700: '#047857',
        800: '#065F46',
        900: '#064E3B',
        }
        },
        fontFamily: {
        heading: ['Space Grotesk', 'sans-serif'],
        body: ['DM Sans', 'sans-serif'],
        }
        }
        }
        }
    </script>
    <style>
        body {
        font-family: 'DM Sans', sans-serif;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
        font-family: 'Space Grotesk', sans-serif;
        }
    </style>
</head>

<body class="flex flex-col min-h-screen bg-brand-50 text-brand-900 font-body">

    @await Html.PartialAsync("_ToastNotification")

    <!-- ====== HEADER ====== -->
    <header class="sticky top-0 z-50 pt-2 px-2 sm:px-4">
        <nav
            class="max-w-7xl mx-auto bg-white/90 backdrop-blur-md rounded-2xl shadow-lg border border-white/20 px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16 lg:h-20">

                <!-- Logo -->
                <a class="flex items-center gap-2.5 group" asp-area="" asp-controller="Home" asp-action="Index">
                    <div
                        class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-600 to-brand-800 flex items-center justify-center shadow-lg shadow-brand-600/20 group-hover:shadow-brand-600/40 transition-shadow duration-300">
                        <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                             stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <div>
                        <span class="font-heading text-xl lg:text-2xl font-bold text-brand-800">TVT</span>
                        <span class="font-heading text-xl lg:text-2xl font-bold text-brand-600"> PC</span>
                    </div>
                </a>

                <!-- Desktop Navigation -->
                <div class="hidden lg:flex items-center gap-1">
                    <a class="px-4 py-2 text-sm font-medium text-brand-700 hover:text-brand-600 hover:bg-brand-50 rounded-xl transition-all duration-200"
                       asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                    <a class="px-4 py-2 text-sm font-medium text-brand-700 hover:text-brand-600 hover:bg-brand-50 rounded-xl transition-all duration-200"
                       href="#">Sản phẩm</a>
                    <a class="px-4 py-2 text-sm font-medium text-brand-700 hover:text-brand-600 hover:bg-brand-50 rounded-xl transition-all duration-200"
                       href="#">Danh mục</a>
                    <a class="px-4 py-2 text-sm font-medium text-brand-700 hover:text-brand-600 hover:bg-brand-50 rounded-xl transition-all duration-200"
                       href="#">Khuyến mãi</a>
                </div>

                <!-- Right Section -->
                <div class="flex items-center gap-2 sm:gap-3">

                    <!-- Search button -->
                    <button
                        class="hidden sm:flex items-center gap-2 px-4 py-2 bg-brand-50 text-brand-500 rounded-xl hover:bg-brand-100 hover:text-brand-600 transition-all duration-200 cursor-pointer"
                        aria-label="Tìm kiếm">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                        <span class="text-sm hidden xl:inline">Tìm kiếm</span>
                    </button>

                    <!-- Cart icon -->
                    <button
                        class="relative p-2.5 text-brand-500 hover:text-brand-600 hover:bg-brand-50 rounded-xl transition-all duration-200 cursor-pointer"
                        aria-label="Giỏ hàng">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                        </svg>
                        <span
                        class="absolute -top-1 -right-1 w-5 h-5 bg-orange-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center shadow-lg shadow-orange-500/30">0</span>
                    </button>

                    <!-- Auth / User -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="relative" id="user-dropdown-container">
                            <button id="user-dropdown-btn"
                                    class="flex items-center gap-2 px-3 py-2 text-brand-700 hover:text-brand-600 hover:bg-brand-50 rounded-xl transition-all duration-200 cursor-pointer"
                                    aria-label="Menu tài khoản">
                                <span
                                    class="w-8 h-8 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 text-white flex items-center justify-center text-sm font-bold shadow-md">
                                    @(User.Identity?.Name?.Length > 0 ? User.Identity.Name[..1].ToUpper() : "?")
                                </span>
                                <span
                                    class="text-sm font-medium max-w-[100px] truncate hidden sm:inline">@(User.Identity?.Name
                                                                                                        ?? "User")</span>
                                    <svg class="w-4 h-4 text-brand-400 hidden sm:block" fill="none" viewBox="0 0 24 24"
                                         stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                                <div id="user-dropdown-menu"
                                     class="absolute right-0 mt-2 w-56 bg-white rounded-2xl shadow-xl border border-brand-100 py-2 hidden z-50 overflow-hidden">
                                    <div
                                        class="px-4 py-3 bg-gradient-to-r from-brand-50 to-brand-100/50 border-b border-brand-100">
                                        <p class="text-sm font-semibold text-brand-800">@(User.Identity?.Name ?? "User")</p>
                                        @{
                                            var userEmail = User.Claims.FirstOrDefault(c => c.Type ==
                                    System.Security.Claims.ClaimTypes.Email)?.Value;
                                        }
                                        @if (!string.IsNullOrEmpty(userEmail))
                                        {
                                            <p class="text-xs text-brand-500 truncate">@userEmail</p>
                                        }
                                    </div>
                                    <a class="flex items-center gap-3 px-4 py-2.5 text-sm text-brand-700 hover:bg-brand-50 hover:text-brand-600 transition-colors duration-150 cursor-pointer"
                                       asp-controller="Account" asp-action="Index">
                                        <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24"
                                             stroke="currentColor" stroke-width="1.5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                        </svg>
                                        Tài khoản của tôi
                                    </a>
                                    <a class="flex items-center gap-3 px-4 py-2.5 text-sm text-brand-700 hover:bg-brand-50 hover:text-brand-600 transition-colors duration-150 cursor-pointer"
                                       asp-controller="Account" asp-action="Profile">
                                        <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24"
                                             stroke="currentColor" stroke-width="1.5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        </svg>
                                        Thông tin cá nhân
                                    </a>
                                    <a class="flex items-center gap-3 px-4 py-2.5 text-sm text-brand-700 hover:bg-brand-50 hover:text-brand-600 transition-colors duration-150 cursor-pointer"
                                       asp-controller="Account" asp-action="ChangePassword">
                                        <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24"
                                             stroke="currentColor" stroke-width="1.5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                        </svg>
                                        Đổi mật khẩu
                                    </a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a class="flex items-center gap-3 px-4 py-2.5 text-sm text-brand-700 hover:bg-brand-50 hover:text-brand-600 transition-colors duration-150 cursor-pointer"
                                           asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                            <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24"
                                                 stroke="currentColor" stroke-width="1.5">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                            </svg>
                                            Quản trị
                                        </a>
                                    }
                                    <hr class="my-1 border-brand-100" />
                                    <form asp-controller="Auth" asp-action="Logout" method="post">
                                        <button type="submit"
                                                class="flex items-center gap-3 w-full px-4 py-2.5 text-sm text-red-500 hover:bg-red-50 transition-colors duration-150 cursor-pointer">
                                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                                 stroke-width="1.5">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                            </svg>
                                            Đăng xuất
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    else
                        {
                            <a class="hidden sm:inline-flex text-sm font-medium text-brand-700 hover:text-brand-600 px-4 py-2 rounded-xl hover:bg-brand-50 transition-all duration-200 cursor-pointer"
                               asp-controller="Auth" asp-action="Register">Đăng ký</a>
                            <a class="inline-flex items-center gap-2 bg-brand-600 text-white px-4 sm:px-5 py-2 rounded-xl font-semibold hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 active:scale-[0.97] transition-all duration-200 cursor-pointer text-sm"
                               asp-controller="Auth" asp-action="Login">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                                </svg>
                                <span class="hidden sm:inline">Đăng nhập</span>
                            </a>
                        }

                        <!-- Mobile menu button -->
                        <button id="menu-toggle" type="button"
                                class="lg:hidden p-2.5 text-brand-500 hover:text-brand-600 hover:bg-brand-50 rounded-xl transition-all duration-200 cursor-pointer"
                                aria-label="Mở menu">
                            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                            </svg>
                        </button>
                    </div>
                </div>

                <!-- Mobile Menu -->
                <div id="mobile-menu" class="hidden lg:hidden pb-5 space-y-1 border-t border-brand-100 pt-4 mt-1">
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-brand-700 hover:text-brand-600 hover:bg-brand-50 font-medium transition-colors duration-150 cursor-pointer"
                       asp-area="" asp-controller="Home" asp-action="Index">
                        <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                             stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                        Trang chủ
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-brand-700 hover:text-brand-600 hover:bg-brand-50 font-medium transition-colors duration-150 cursor-pointer"
                       href="#">
                        <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                             stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                        Sản phẩm
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-brand-700 hover:text-brand-600 hover:bg-brand-50 font-medium transition-colors duration-150 cursor-pointer"
                       href="#">
                        <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                             stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                        </svg>
                        Danh mục
                    </a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <hr class="border-brand-100 my-2" />
                        <a class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-brand-700 hover:text-brand-600 hover:bg-brand-50 font-medium transition-colors duration-150 cursor-pointer"
                           asp-controller="Account" asp-action="Index">
                            <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            Tài khoản
                        </a>
                        <a class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-brand-700 hover:text-brand-600 hover:bg-brand-50 font-medium transition-colors duration-150 cursor-pointer"
                           asp-controller="Account" asp-action="ChangePassword">
                            <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            Đổi mật khẩu
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-brand-700 hover:text-brand-600 hover:bg-brand-50 font-medium transition-colors duration-150 cursor-pointer"
                               asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                     stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Quản trị
                            </a>
                        }
                        <form asp-controller="Auth" asp-action="Logout" method="post">
                            <button type="submit"
                                    class="flex items-center gap-3 w-full px-3 py-2.5 rounded-xl text-red-500 hover:bg-red-50 font-medium transition-colors duration-150 cursor-pointer">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                </svg>
                                Đăng xuất
                            </button>
                        </form>
                    }
                    else
                    {
                        <hr class="border-brand-100 my-2" />
                        <a class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-brand-700 hover:text-brand-600 hover:bg-brand-50 font-medium transition-colors duration-150 cursor-pointer"
                           asp-controller="Auth" asp-action="Register">
                            <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                 stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
                            </svg>
                            Đăng ký
                        </a>
                        <a class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-brand-600 bg-brand-50 font-medium transition-colors duration-150 cursor-pointer"
                           asp-controller="Auth" asp-action="Login">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
                            </svg>
                            Đăng nhập
                        </a>
                    }
                </div>
            </nav>
        </header>

        <!-- ====== MAIN CONTENT ====== -->
        <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 lg:py-10">
            @RenderBody()
        </main>

        <!-- ====== FOOTER ====== -->
        <footer class="bg-brand-900 text-brand-100">
            <!-- Main footer -->
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

                    <!-- Column 1: About -->
                    <div class="sm:col-span-2 lg:col-span-1">
                        <div class="flex items-center gap-2.5 mb-4">
                            <div
                                class="w-9 h-9 rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center">
                                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                     stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <span class="font-heading text-lg font-bold text-white">TVT PC</span>
                        </div>
                        <p class="text-brand-300 text-sm leading-relaxed mb-4">
                            TVT PC - Hệ thống bán lẻ linh kiện máy tính, laptop & thiết bị công nghệ chính hãng hàng đầu
                            Việt Nam.
                        </p>
                        <div class="space-y-2 text-sm text-brand-300">
                            <div class="flex items-center gap-2">
                                <svg class="w-4 h-4 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24"
                                     stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                <span>123 Nguyễn Huệ, Quận 1, TP.HCM</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <svg class="w-4 h-4 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24"
                                     stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                </svg>
                                <span>1900 9999 88</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <svg class="w-4 h-4 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24"
                                     stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                                <span>support@tvtpc.vn</span>
                            </div>
                        </div>
                    </div>

                    <!-- Column 2: Customer Service -->
                    <div>
