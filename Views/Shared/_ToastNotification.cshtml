@{
    // Hỗ trợ cả TempData (sau redirect) và ViewBag (trong cùng request)
    var toastType = TempData["ToastType"] as string ?? ViewBag.ToastType as string;
    var toastMessage = TempData["ToastMessage"] as string ?? ViewBag.ToastMessage as string;
    var toastDuration = TempData["ToastDuration"] as int? ?? ViewBag.ToastDuration as int? ?? 4000;
}

@if (!string.IsNullOrEmpty(toastMessage) && !string.IsNullOrEmpty(toastType))
{
    var bgColor = toastType switch
    {
        "success" => "bg-green-50 border-green-400 text-green-800",
        "error" => "bg-red-50 border-red-400 text-red-800",
        "warning" => "bg-yellow-50 border-yellow-400 text-yellow-800",
        "info" => "bg-blue-50 border-blue-400 text-blue-800",
        _ => "bg-gray-50 border-gray-400 text-gray-800"
    };
    var iconColor = toastType switch
    {
        "success" => "text-green-500",
        "error" => "text-red-500",
        "warning" => "text-yellow-500",
        "info" => "text-blue-500",
        _ => "text-gray-500"
    };
    var icon = toastType switch
    {
        "success" => "✓",
        "error" => "✕",
        "warning" => "⚠",
        "info" => "ℹ",
        _ => ""
    };
    var barColor = toastType switch
    {
        "success" => "bg-green-500",
        "error" => "bg-red-500",
        "warning" => "bg-yellow-500",
        "info" => "bg-blue-500",
        _ => "bg-gray-500"
    };

    <div id="toast-notification"
         class="fixed top-4 right-4 z-[100] max-w-sm w-full border rounded-xl shadow-lg @bgColor overflow-hidden animate-slide-in"
         data-duration="@toastDuration">
        <div class="flex items-start gap-3 p-4">
            <span class="text-lg font-bold @iconColor flex-shrink-0">@icon</span>
            <p class="text-sm flex-1">@toastMessage</p>
            <button type="button" onclick="dismissToast()" class="text-gray-400 hover:text-gray-600 flex-shrink-0">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <div class="h-1 w-full bg-black/10">
            <div id="toast-progress" class="h-full @barColor rounded-full" style="width: 100%"></div>
        </div>
    </div>

    <style>
        @@keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        .animate-slide-in {
            animation: slideIn 0.3s ease-out forwards;
        }
    </style>

    <script>
        (function() {
            var toast = document.getElementById('toast-notification');
            var progress = document.getElementById('toast-progress');
            var duration = parseInt(toast.getAttribute('data-duration')) || 4000;
            var startTime = Date.now();

            function updateProgress() {
                var elapsed = Date.now() - startTime;
                var remaining = Math.max(0, 1 - elapsed / duration);
                if (progress) progress.style.width = (remaining * 100) + '%';

                if (elapsed >= duration) {
                    dismissToast();
                } else {
                    requestAnimationFrame(updateProgress);
                }
            }

            window.dismissToast = function() {
                if (toast) {
                    toast.style.transition = 'transform 0.3s ease-out, opacity 0.3s ease-out';
                    toast.style.transform = 'translateX(100%)';
                    toast.style.opacity = '0';
                    setTimeout(function() {
                        if (toast.parentNode) toast.parentNode.removeChild(toast);
                    }, 300);
                }
            };

            // Bắt đầu animation khi DOM sẵn sàng
            if (document.readyState === 'complete' || document.readyState === 'interactive') {
                setTimeout(updateProgress, 100);
            } else {
                document.addEventListener('DOMContentLoaded', function() {
                    setTimeout(updateProgress, 100);
                });
            }
        })();
    </script>
}
