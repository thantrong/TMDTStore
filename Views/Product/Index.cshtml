@model TMDTStore.Models.ViewModels.Product.ProductListViewModels

@{
    ViewData["Title"] = "Sản phẩm";
}

<!-- Breadcrumb -->
<div class="text-sm text-brand-500 mb-6">
    <a asp-controller="Home" asp-action="Index" class="hover:text-brand-600">Trang chủ</a>
    <span class="mx-2">/</span>
    <span class="text-brand-700 font-medium">Sản phẩm</span>
</div>

<div class="flex flex-col lg:flex-row gap-8">

    <!-- ====== SIDEBAR FILTER ====== -->
    <aside class="w-full lg:w-64 flex-shrink-0">

        <!-- Danh mục -->
        <div class="bg-white rounded-xl shadow-sm border border-brand-100 p-5 mb-4">
            <h3 class="font-heading font-bold text-brand-800 mb-3">Danh mục</h3>
            <ul class="space-y-2">
                <li>
                    <a asp-action="Index"
                       class="text-sm text-brand-600 hover:text-brand-700 @(string.IsNullOrEmpty(Model.CategoryId) ? "font-semibold text-brand-700" : "")">
                        Tất cả sản phẩm
                    </a>
                </li>
                @foreach (var cat in Model.Categories)
                {
                    <li>
                        <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-sortBy="@Model.SortBy"
                           class="text-sm text-brand-600 hover:text-brand-700 @(Model.CategoryId == cat.Id ? "font-semibold text-brand-700" : "")">
                            @cat.Name
                        </a>
                    </li>
                }
            </ul>
        </div>

        <!-- Sắp xếp -->
        <div class="bg-white rounded-xl shadow-sm border border-brand-100 p-5">
            <h3 class="font-heading font-bold text-brand-800 mb-3">Sắp xếp</h3>
            <div class="space-y-2">
                @{
                    var sorts = new[] {
                        ("newest", "Mới nhất"),
                        ("price_asc", "Giá: Thấp → Cao"),
                        ("price_desc", "Giá: Cao → Thấp"),
                        ("rating", "Đánh giá cao nhất")
                    };
                }
                @foreach (var (key, label) in sorts)
                {
                    <a asp-action="Index" asp-route-sortBy="@key" asp-route-categoryId="@Model.CategoryId"
                       class="block text-sm text-brand-600 hover:text-brand-700 @(Model.SortBy == key || (string.IsNullOrEmpty(Model.SortBy) && key == "newest") ? "font-semibold text-brand-700" : "")">
                        @label
                    </a>
                }
            </div>
        </div>
    </aside>

    <!-- ====== PRODUCT GRID ====== -->
    <div class="flex-1">

        <!-- Header: số lượng + keyword -->
        <div class="flex items-center justify-between mb-6">
            <p class="text-sm text-brand-500">
                @Model.TotalItems sản phẩm
                @if (!string.IsNullOrEmpty(Model.SearchQuery))
                {
                    <span>cho "<strong class="text-brand-700">@Model.SearchQuery</strong>"</span>
                }
            </p>
        </div>

        <!-- Grid -->
        @if (Model.Products.Count == 0)
        {
            <div class="text-center py-16 text-brand-400">
                <p class="text-lg">Không tìm thấy sản phẩm nào.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6">
                @foreach (var product in Model.Products)
                {
                    <!-- Product Card -->
                    <div
                        class="bg-white rounded-xl shadow-sm border border-brand-100 overflow-hidden hover:shadow-lg hover:border-brand-200 transition-all duration-200 group">
                        <a href="#" class="block">
                            <!-- Ảnh -->
                            <div class="aspect-square bg-brand-50 overflow-hidden">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.Name"
                                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center text-brand-300">
                                        <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                                                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                }
                            </div>

                            <!-- Thông tin -->
                            <div class="p-4">
                                <p class="text-xs text-brand-400 mb-1">@product.BrandName</p>
                                <h3 class="text-sm font-medium text-brand-800 line-clamp-2 mb-2 min-h-[2.5rem]">
                                    @product.Name
                                </h3>

                                <!-- Rating -->
                                @if (product.RatingCount > 0)
                                {
                                    <div class="flex items-center gap-1 mb-2">
                                        <span class="text-yellow-400 text-sm">★</span>
                                        <span class="text-sm font-medium text-brand-700">@product.RatingAvg.ToString("F1")</span>
                                        <span class="text-xs text-brand-400">(@product.RatingCount)</span>
                                    </div>
                                }

                                <!-- Giá -->
                                <div class="flex items-baseline gap-2">
                                    <span class="text-lg font-bold text-red-500">
                                        @product.Price.ToString("#,###")₫
                                    </span>
                                    @if (product.ListPrice > product.Price)
                                    {
                                        <span class="text-sm text-brand-400 line-through">
                                            @product.ListPrice?.ToString("#,###")₫
                                        </span>
                                    }
                                </div>
                            </div>
                        </a>

                        <!-- Nút thêm giỏ hàng -->
                        <div class="px-4 pb-4">
                            <button
                                class="w-full py-2 bg-brand-600 text-white text-sm font-semibold rounded-lg hover:bg-brand-700 transition-all duration-200 cursor-pointer active:scale-[0.98]">
                                Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- ====== PHÂN TRANG ====== -->
        @if (Model.TotalPages > 1)
        {
            <div class="flex items-center justify-center gap-2 mt-10">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-action="Index" asp-route-page="@i" asp-route-categoryId="@Model.CategoryId"
                       asp-route-sortBy="@Model.SortBy" asp-route-searchQuery="@Model.SearchQuery" class="px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200
                        @(i == Model.Page
                           ? "bg-brand-600 text-white shadow-md"
                           : "bg-white text-brand-600 hover:bg-brand-50 border border-brand-200")">
                        @i
                    </a>
                }
            </div>
        }

    </div>
</div>