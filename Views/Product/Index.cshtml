@model TMDTStore.Models.ViewModels.Product.ProductListViewModels

@{
    ViewData["Title"] = "Sản phẩm";

    var allCats = Model.Categories;
    var selectedCat = allCats.FirstOrDefault(c => c.Id == Model.CategoryId);
    var categoryTree = ViewBag.CategoryTree as List<(TMDTStore.Models.Category Cat, int Level)> ?? new();
}

<!-- Breadcrumb -->
<div class="text-sm text-brand-500 mb-6 flex items-center gap-2 flex-wrap">
    <a asp-controller="Home" asp-action="Index" class="hover:text-brand-600">Trang chủ</a>
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
    @if (selectedCat != null)
    {
        // Breadcrumb từ gốc đến hiện tại
        var breadcrumbCats = new List<Category>();
        var bc = selectedCat;
        while (bc != null) { breadcrumbCats.Insert(0, bc); bc = allCats.FirstOrDefault(c => c.Id == bc.ParentId); }
        for (int i = 0; i < breadcrumbCats.Count; i++)
        {
            var b = breadcrumbCats[i];
            if (i < breadcrumbCats.Count - 1)
            {
                <a asp-action="Index" asp-route-category="@b.Slug" class="hover:text-brand-600">@b.Name</a>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
            }
            else
            {
                <span class="text-brand-700 font-medium">@b.Name</span>
            }
        }
    }
    else
    {
        <span class="text-brand-700 font-medium">Tất cả sản phẩm</span>
    }
</div>

<div class="flex flex-col lg:flex-row gap-8">

    <!-- ====== SIDEBAR FILTER ====== -->
    <aside class="w-full lg:w-64 flex-shrink-0">

        <!-- Danh mục dạng hover dropdown -->
        <div class="bg-white rounded-xl shadow-sm border border-brand-100 mb-4">
            <h3 class="font-heading font-bold text-brand-800 px-5 pt-5 pb-3 border-b border-brand-100">Danh mục</h3>
            <ul class="py-2">
                <li>
                    <a asp-action="Index"
                       class="flex items-center gap-2 px-5 py-2.5 text-sm transition-colors @(string.IsNullOrEmpty(Model.CategoryId) ? "text-brand-700 font-semibold bg-brand-50 border-r-2 border-brand-600" : "text-brand-600 hover:text-brand-700 hover:bg-brand-50")">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                        Tất cả sản phẩm
                    </a>
                </li>
                @foreach (var item in categoryTree.Where(t => t.Level == 0))
                {
                    var cat = item.Cat;
                    var isActive = Model.CategoryId == cat.Id;
                    var children = categoryTree.Where(t => t.Cat.ParentId == cat.Id).OrderBy(t => t.Cat.Name).ToList();
                    var grandchildren = children.SelectMany(c => categoryTree.Where(t => t.Cat.ParentId ==
                c.Cat.Id)).ToList();

                    <li class="relative group">
                        <a asp-action="Index" asp-route-category="@cat.Slug"
                           class="flex items-center justify-between px-5 py-2.5 text-sm transition-colors @(isActive ? "text-brand-700 font-semibold bg-brand-50 border-r-2 border-brand-600" : "text-brand-600 hover:text-brand-700 hover:bg-brand-50")">
                            <span>@cat.Name</span>
                            @if (children.Count > 0)
                            {
                                <svg class="w-3.5 h-3.5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                     stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                </svg>
                            }
                        </a>

                        @if (children.Count > 0)
                        {
                            <div
                                class="absolute left-full top-0 ml-2 w-64 bg-white rounded-xl shadow-xl border border-brand-100 py-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-20">
                                <div class="px-4 pb-2 mb-1 border-b border-brand-100">
                                    <p class="text-xs font-semibold text-brand-400 uppercase tracking-wider">@cat.Name</p>
                                </div>
                                <ul class="space-y-0.5 px-2">
                                    @foreach (var child in children)
                                    {
                                        var isChildActive = Model.CategoryId == child.Cat.Id;
                                        var childGrandchildren = categoryTree.Where(t => t.Cat.ParentId == child.Cat.Id).OrderBy(t
                            => t.Cat.Name).ToList();

                                        <li class="relative group/sub">
                                            <a asp-action="Index" asp-route-category="@child.Cat.Slug"
                                               class="flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors @(isChildActive ? "text-brand-700 font-semibold bg-brand-50" : "text-brand-600 hover:text-brand-700 hover:bg-brand-50")">
                                                <span>@child.Cat.Name</span>
                                                @if (childGrandchildren.Count > 0)
                                                {
                                                    <svg class="w-3 h-3 text-brand-400" fill="none" viewBox="0 0 24 24"
                                                         stroke="currentColor" stroke-width="2">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                                    </svg>
                                                }
                                            </a>

                                            @if (childGrandchildren.Count > 0)
                                            {
                                                <div
                                                    class="absolute left-full top-0 ml-2 w-56 bg-white rounded-xl shadow-xl border border-brand-100 py-2 opacity-0 invisible group-hover/sub:opacity-100 group-hover/sub:visible transition-all duration-200 z-30">
                                                    <div class="px-3 pb-1.5 mb-1 border-b border-brand-100">
                                                        <p class="text-xs font-semibold text-brand-400">@child.Cat.Name</p>
                                                    </div>
                                                    <ul class="space-y-0.5 px-2">
                                                        @foreach (var gc in childGrandchildren)
                                                        {
                                                            var isGcActive = Model.CategoryId == gc.Cat.Id;
                                                            <li>
                                                                <a asp-action="Index" asp-route-category="@gc.Cat.Slug"
                                                                   class="block px-3 py-2 text-sm rounded-md transition-colors @(isGcActive ? "text-brand-700 font-semibold bg-brand-50" : "text-brand-500 hover:text-brand-700 hover:bg-brand-50")">
                                                                    @gc.Cat.Name
                                                                </a>
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            }
                                        </li>
                                    }
                                </ul>
                                <a asp-action="Index" asp-route-category="@cat.Slug"
                                   class="block px-4 pt-2 mt-1 text-xs font-medium text-brand-500 hover:text-brand-600 border-t border-brand-100">
                                    Xem tất cả @cat.Name →
                                </a>
                            </div>
                        }
                    </li>
                }
            </ul>
        </div>

        <!-- Sắp xếp -->
        <div class="bg-white rounded-xl shadow-sm border border-brand-100 p-5">
            <h3 class="font-heading font-bold text-brand-800 mb-3">Sắp xếp</h3>
            <div class="space-y-2">
                @{
                    var sorts = new[] {
                        ("newest", "Mới nhất"),
                        ("price_asc", "Giá: Thấp → Cao"),
                        ("price_desc", "Giá: Cao → Thấp"),
                        ("rating", "Đánh giá cao nhất")
                    };
                }
                @foreach (var (key, label) in sorts)
                {
                    <a asp-action="Index" asp-route-sortBy="@key" asp-route-category="@Model.CategorySlug"
                       class="block text-sm text-brand-600 hover:text-brand-700 @(Model.SortBy == key || (string.IsNullOrEmpty(Model.SortBy) && key == "newest") ? "font-semibold text-brand-700" : "")">
                        @label
                    </a>
                }
            </div>
        </div>
    </aside>

    <!-- ====== PRODUCT GRID ====== -->
    <div class="flex-1">

        <!-- Header: số lượng + keyword -->
        <div class="flex items-center justify-between mb-6">
            <p class="text-sm text-brand-500">
                @Model.TotalItems sản phẩm
                @if (!string.IsNullOrEmpty(Model.SearchQuery))
                {
                    <span>cho "<strong class="text-brand-700">@Model.SearchQuery</strong>"</span>
                }
            </p>
        </div>

        <!-- Grid -->
        @if (Model.Products.Count == 0)
        {
            <div class="text-center py-16 text-brand-400">
                <p class="text-lg">Không tìm thấy sản phẩm nào.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5 gap-4 sm:gap-6">
                @foreach (var product in Model.Products)
                {
                    <!-- Product Card -->
                    <div
                        class="bg-white rounded-xl shadow-sm border border-brand-100 overflow-hidden hover:shadow-lg hover:border-brand-200 transition-all duration-200 group">
                        <a asp-controller="Product" asp-action="Details" asp-route-slug="@product.Slug" class="block">
                            <!-- Ảnh -->
                            <div class="aspect-square bg-brand-50 overflow-hidden">
                                @{
                                    var prodImgUrl = product.ImageUrl;
                                    if (string.IsNullOrEmpty(prodImgUrl) && product.ProductVariants != null &&
                        product.ProductVariants.Any(v => !string.IsNullOrEmpty(v.ImageUrl)))
                                    {
                                        var cheapestVariant = product.ProductVariants.Where(v =>
                        !string.IsNullOrEmpty(v.ImageUrl)).OrderBy(v => v.Price).First();
                                        prodImgUrl = cheapestVariant.ImageUrl;
                                    }
                                }
                                @if (!string.IsNullOrEmpty(prodImgUrl))
                                {
                                    <img src="@prodImgUrl" alt="@product.Name"
                                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center text-brand-300">
                                        <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                                                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                }
                            </div>

                            <!-- Thông tin -->
                            <div class="p-4">
                                <p class="text-xs text-brand-400 mb-1">@(product.Brand?.Name ?? "")</p>
                                <h3 class="text-sm font-medium text-brand-800 line-clamp-2 mb-2 min-h-[2.5rem]">
                                    @product.Name
                                </h3>

                                <!-- Rating -->
                                @if (product.RatingCount > 0)
                                {
                                    <div class="flex items-center gap-1 mb-2">
                                        <span class="text-yellow-400 text-sm">★</span>
                                        <span class="text-sm font-medium text-brand-700">@product.RatingAvg.ToString("F1")</span>
                                        <span class="text-xs text-brand-400">(@product.RatingCount)</span>
                                    </div>
                                }

                                <!-- Giá -->
                                <div class="flex items-baseline gap-2">
                                    <span class="text-lg font-bold text-red-500">
                                        @(product.Price.HasValue ? product.Price.Value.ToString("#,###") + "₫" : "Liên hệ")
                                    </span>
                                    @if (product.Price.HasValue && product.ListPrice > product.Price.Value)
                                    {
                                        <span class="text-sm text-brand-400 line-through">
                                            @product.ListPrice?.ToString("#,###")₫
                                        </span>
                                    }
                                </div>
                            </div>
                        </a>

                        <!-- Nút thêm giỏ hàng -->
                        <div class="px-4 pb-4">
                            <button
                                class="w-full py-2 bg-brand-600 text-white text-sm font-semibold rounded-lg hover:bg-brand-700 transition-all duration-200 cursor-pointer active:scale-[0.98]">
                                Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- ====== PHÂN TRANG ====== -->
        @if (Model.PagingInfo.TotalPages > 1)
        {
            <div page-model="@Model.PagingInfo" page-action="Index" page-url-category="@Model.CategorySlug"
                 page-url-sortBy="@Model.SortBy" page-url-searchQuery="@Model.SearchQuery">
            </div>
        }

    </div>
</div>