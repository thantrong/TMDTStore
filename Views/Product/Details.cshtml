@model TMDTStore.Models.Product
@using System.Text.Json;

@{
    ViewData["Title"] = Model.Name;

    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var hasVariants = Model.ProductVariants != null && Model.ProductVariants.Count > 0;
    var imageList = new List<string>();
    if (!string.IsNullOrEmpty(Model.ImageUrls))
    {
        try { imageList = JsonSerializer.Deserialize<List<string>>(Model.ImageUrls); } catch { }
    }
    if (!string.IsNullOrEmpty(Model.ImageUrl) && !imageList.Contains(Model.ImageUrl))
    {
        imageList.Insert(0, Model.ImageUrl);
    }

    // Nếu sản phẩm không có ảnh nhưng có biến thể → lấy ảnh từ biến thể
    if (imageList.Count == 0 && hasVariants)
    {
        foreach (var v in Model.ProductVariants!)
        {
            // Lấy từ ImageUrls (JSON array) của từng variant
            if (!string.IsNullOrEmpty(v.ImageUrls))
            {
                try
                {
                    var variantUrls = JsonSerializer.Deserialize<List<string>>(v.ImageUrls);
                    if (variantUrls != null)
                    {
                        foreach (var url in variantUrls)
                        {
                            if (!string.IsNullOrEmpty(url) && !imageList.Contains(url))
                                imageList.Add(url);
                        }
                    }
                }
                catch { }
            }
            // Lấy từ ImageUrl (1 ảnh chính) của variant
            if (!string.IsNullOrEmpty(v.ImageUrl) && !imageList.Contains(v.ImageUrl))
                imageList.Add(v.ImageUrl);
        }
    }

    var hasMultipleImages = imageList.Count > 1;
    var hasPrice = Model.Price.HasValue;
    var hasDiscount = hasPrice && Model.ListPrice.HasValue && Model.ListPrice > Model.Price.Value;
    var discountPercent = hasDiscount ? (int)(((Model.ListPrice.Value - Model.Price.Value) / Model.ListPrice.Value) * 100) : 0;

    // Serialize variants cho JavaScript — dùng camelCase
    var variantsJson = hasVariants
        ? JsonSerializer.Serialize(Model.ProductVariants.Select(v => new
        {
            v.Name,
            v.Sku,
            v.Price,
            v.ListPrice,
            v.SalePrice,
            v.StockQuantity,
            v.ImageUrl,
            v.ImageUrls,
            v.Attributes,
            v.Description
        }), jsonOpts)
        : "[]";

    // Danh sách tất cả ảnh của từng variant cho JS
    var allVariantImagesJson = hasVariants
        ? JsonSerializer.Serialize(Model.ProductVariants!.Select(v =>
        {
            var urls = new List<string>();
            if (!string.IsNullOrEmpty(v.ImageUrls))
            {
                try
                {
                    var parsed = JsonSerializer.Deserialize<List<string>>(v.ImageUrls);
                    if (parsed != null) urls.AddRange(parsed);
                }
                catch { }
            }
            if (!string.IsNullOrEmpty(v.ImageUrl) && !urls.Contains(v.ImageUrl))
                urls.Insert(0, v.ImageUrl);
            return urls;
        }).ToList(), jsonOpts)
        : "[]";

    // Parse attributes từ variant đầu để lấy danh sách attribute keys
    var attrKeys = new List<string>();
    if (hasVariants && !string.IsNullOrEmpty(Model.ProductVariants!.First().Attributes))
    {
        try
        {
            var firstAttrs = JsonSerializer.Deserialize<List<Dictionary<string, string>>>(Model.ProductVariants!.First().Attributes);
            if (firstAttrs != null)
                attrKeys = firstAttrs.Select(a => a.GetValueOrDefault("key", "")).Where(k => !string.IsNullOrEmpty(k)).ToList();
        }
        catch { }
    }

    // Build lookup: attribute key → danh sách các giá trị có thể có
    var attrValues = new Dictionary<string, List<string>>();
    if (hasVariants && attrKeys.Count > 0)
    {
        foreach (var v in Model.ProductVariants!)
        {
            if (string.IsNullOrEmpty(v.Attributes)) continue;
            try
            {
                var attrs = JsonSerializer.Deserialize<List<Dictionary<string, string>>>(v.Attributes);
                if (attrs == null) continue;
                foreach (var a in attrs)
                {
                    var key = a.GetValueOrDefault("key", "");
                    var val = a.GetValueOrDefault("value", "");
                    if (string.IsNullOrEmpty(key) || string.IsNullOrEmpty(val)) continue;
                    if (!attrValues.ContainsKey(key))
                        attrValues[key] = new List<string>();
                    if (!attrValues[key].Contains(val))
                        attrValues[key].Add(val);
                }
            }
            catch { }
        }
    }

    // Số lượng thuộc tính từ biến thể đầu (để đánh dấu row trong bảng specs)
    var firstVariantAttrCount = 0;
    var firstVariantAttrs = new List<Dictionary<string, string>>();
    if (hasVariants && !string.IsNullOrEmpty(Model.ProductVariants!.First().Attributes))
    {
        try
        {
            firstVariantAttrs = JsonSerializer.Deserialize<List<Dictionary<string, string>>>(Model.ProductVariants!.First().Attributes) ?? new();
            firstVariantAttrCount = firstVariantAttrs.Count;
        }
        catch { }
    }

    // Tất cả attributes của các biến thể — để JS cập nhật specs động
    var allVariantAttrsJson = hasVariants
        ? JsonSerializer.Serialize(Model.ProductVariants!.Select(v =>
        {
            if (string.IsNullOrEmpty(v.Attributes)) return new List<Dictionary<string, string>>();
            try { return JsonSerializer.Deserialize<List<Dictionary<string, string>>>(v.Attributes) ?? new(); }
            catch { return new List<Dictionary<string, string>>(); }
        }).ToList(), jsonOpts)
        : "[]";
}

<!-- Breadcrumb -->
<nav class="text-sm text-brand-500 mb-6 flex items-center gap-2 flex-wrap">
    <a asp-controller="Home" asp-action="Index" class="hover:text-brand-600 transition-colors">Trang chủ</a>
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
    @if (Model.Category != null)
    {
        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@Model.CategoryId"
           class="hover:text-brand-600 transition-colors">@Model.Category.Name</a>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
    }
    <span class="text-brand-700 font-medium truncate">@Model.Name</span>
</nav>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10">

    <!-- ====== LEFT: Images ====== -->
    <div>
        <div class="bg-white rounded-2xl border border-brand-100 overflow-hidden mb-3">
            <div class="aspect-square relative group">
                @if (imageList.Count > 0)
                {
                    <img id="main-image" src="@imageList[0]" alt="@Model.Name"
                         class="w-full h-full object-contain p-6 sm:p-10 transition-all duration-300" />
                    @if (hasDiscount)
                    {
                        <span
                        class="absolute top-3 left-3 bg-orange-500 text-white text-xs font-bold px-2.5 py-1 rounded-full shadow-lg shadow-orange-500/30">-@discountPercent%</span>
                    }
                    <div
                        class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm text-brand-600 text-xs font-medium px-2.5 py-1 rounded-full shadow-sm @(hasMultipleImages ? "" : "hidden")" id="slide-counter">
                        <span id="slide-current">1</span>/@(imageList.Count > 0 ? imageList.Count : 1)
                    </div>
                    <button type="button" id="slide-prev"
                            class="absolute left-2 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white/90 backdrop-blur-sm shadow-lg flex items-center justify-center text-brand-600 hover:bg-white transition-all @(hasMultipleImages ? "" : "hidden") opacity-0 group-hover:opacity-100 cursor-pointer">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                        </svg>
                    </button>
                    <button type="button" id="slide-next"
                            class="absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white/90 backdrop-blur-sm shadow-lg flex items-center justify-center text-brand-600 hover:bg-white transition-all @(hasMultipleImages ? "" : "hidden") opacity-0 group-hover:opacity-100 cursor-pointer">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                        </svg>
                    </button>
                }
                else
                {
                    <div class="w-full h-full flex flex-col items-center justify-center text-brand-200 p-10">
                        <svg class="w-24 h-24 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        <span class="text-base">Chưa có ảnh</span>
                    </div>
                }
            </div>
        </div>
        @if (hasMultipleImages)
        {
            <div class="flex gap-2 overflow-x-auto pb-1" id="thumbnails-container">
                @for (int i = 0; i < imageList.Count; i++)
                {
                    <button type="button" data-index="@i"
                            class="slide-thumb w-16 h-16 rounded-xl overflow-hidden border-2 flex-shrink-0 @(i == 0 ? "border-brand-500" : "border-brand-100") hover:border-brand-300 transition-all cursor-pointer">
                        <img src="@imageList[i]" alt="" class="w-full h-full object-cover" />
                    </button>
                }
            </div>
        }
    </div>

    <!-- ====== RIGHT: Info ====== -->
    <div>
        @if (Model.Brand != null)
        {
            <p class="text-sm font-medium text-brand-500 mb-1">@Model.Brand.Name</p>
        }
        <h1 class="text-2xl sm:text-3xl font-heading font-bold text-brand-900 leading-tight mb-3">@Model.Name</h1>
        <div class="flex items-center gap-4 text-sm text-brand-400 mb-5">
            @if (hasVariants)
            {
                <span>SKU: <span id="variant-sku" class="font-medium text-brand-600">@Model.ProductVariants!.First().Sku</span></span>
            }
            else
            {
                <span>SKU: <span class="font-medium text-brand-600">@Model.Id</span></span>
            }
            @if (Model.RatingCount > 0)
            {
                <span class="flex items-center gap-1"><span class="text-yellow-400">★</span> <span
                    class="font-medium text-brand-700">@Model.RatingAvg.ToString("F1")</span> (@Model.RatingCount đánh
                    giá)</span>
                }
            </div>
            <div class="bg-brand-50 rounded-2xl p-5 mb-5">
                <div class="flex items-baseline gap-3 flex-wrap">
                    <span id="variant-price" class="text-3xl sm:text-4xl font-bold text-red-500">
                        @if (hasVariants)
                        {
                            @(Model.ProductVariants!.First().Price.ToString("#,###") + "₫")
                        }
                        else
                        {
                            @(Model.Price.HasValue ? Model.Price.Value.ToString("#,###") + "₫" : "Liên hệ")
                        }
                    </span>
                    @if (hasVariants)
                    {
                        var firstListPrice = Model.ProductVariants!.First().ListPrice;
                        var firstPrice = Model.ProductVariants!.First().Price;
                        if (firstListPrice.HasValue && firstListPrice > firstPrice)
                        {
                            <span id="variant-list-price" class="text-lg text-brand-400 line-through">@firstListPrice?.ToString("#,###")₫</span>
                            <span id="variant-discount-badge"
                                  class="text-sm font-bold text-green-600 bg-green-50 px-2.5 py-0.5 rounded-full">-@((int)(((firstListPrice.Value - firstPrice) / firstListPrice.Value) * 100))%</span>
                        }
                        else
                        {
                            <span id="variant-list-price" class="text-lg text-brand-400 line-through hidden"></span>
                            <span id="variant-discount-badge" class="hidden"></span>
                        }
                    }
                    else if (hasDiscount)
                    {
                        <span class="text-lg text-brand-400 line-through">@Model.ListPrice?.ToString("#,###")₫</span>
                        <span class="text-sm font-bold text-green-600 bg-green-50 px-2.5 py-0.5 rounded-full">-@discountPercent%</span>
                    }
                    else if (!hasPrice)
                    {
                        <span class="text-sm font-bold text-brand-500 bg-brand-50 px-3 py-1 rounded-full">Liên hệ để biết giá</span>
                    }
                </div>
                @if (hasVariants)
                {
                    <div class="mt-3 flex items-center gap-2 text-sm">
                        <span class="text-brand-400">Tình trạng:</span>
                        <span id="variant-stock" class="font-medium text-green-600">
                            @(Model.ProductVariants!.First().StockQuantity > 0 ? "Còn hàng" : "Hết hàng")
                        </span>
                    </div>
                }
            </div>
            @if (!string.IsNullOrEmpty(Model.ShortDescription))
            {
                <div class="mb-4">
                    <h3 class="text-sm font-semibold text-brand-700 mb-2">Đặc điểm nổi bật:</h3>
                    <p class="text-sm text-brand-600 leading-relaxed">@Model.ShortDescription</p>
                </div>
            }

            @if (hasVariants)
            {
                <div class="mb-5" id="variant-section">
                    <h3 class="text-sm font-semibold text-brand-700 mb-2">Tùy chọn sản phẩm:</h3>

                    @if (attrKeys.Count > 0)
                    {
                        <!-- Attribute groups (like PhongVu: color, config) -->
                        <div class="space-y-3">
                            @foreach (var key in attrKeys)
                            {
                                var vals = attrValues.GetValueOrDefault(key, new List<string>());
                                <div>
                                    <p class="text-xs font-medium text-brand-500 mb-1.5">@key</p>
                                    <div class="flex flex-wrap gap-2" data-attr-key="@key">
                                        @foreach (var val in vals)
                                        {
                                            <button type="button"
                                                    class="attr-chip px-3 py-1.5 rounded-lg border text-sm font-medium transition-all duration-200 cursor-pointer"
                                                    data-attr-key="@key" data-attr-value="@val">
                                                @val
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Chip này ẩn, dùng để hiển thị variant đã chọn -->
                        <div class="mt-3 p-3 bg-brand-50 rounded-xl border border-brand-100 hidden" id="selected-variant-info">
                            <p class="text-sm text-brand-700">
                                Đã chọn: <span id="selected-variant-name" class="font-semibold text-brand-800"></span>
                            </p>
                        </div>
                    }
                    else
                    {
                        <!-- Fallback: flat chips nếu không có attributes -->
                        <div class="flex flex-wrap gap-2" id="variant-list">
                            @for (int i = 0; i < Model.ProductVariants!.Count; i++)
                            {
                                var v = Model.ProductVariants.ToList()[i];
                                <button type="button" data-index="@i"
                                        class="variant-chip px-4 py-2.5 rounded-xl border-2 text-sm font-medium transition-all duration-200 cursor-pointer
                                        @(i == 0 ? "border-brand-500 bg-brand-50 text-brand-700" : "border-brand-200 bg-white text-brand-600 hover:border-brand-300")">
                                    @v.Name
                                </button>
                            }
                        </div>
                    }
                </div>
            }

            @if (Model.WarrantyMonths.HasValue && Model.WarrantyMonths > 0)
            {
                <div
                    class="flex items-center gap-2 text-sm text-brand-600 bg-brand-50 px-3 py-2 rounded-xl inline-flex mb-3 mr-2">
                    <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                         stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                    Bảo hành @Model.WarrantyMonths tháng
                </div>
            }
            @if (Model.ReturnDays.HasValue && Model.ReturnDays > 0)
            {
                <div class="flex items-center gap-2 text-sm text-brand-600 bg-brand-50 px-3 py-2 rounded-xl inline-flex mb-5">
                    <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                         stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                    Đổi trả @Model.ReturnDays ngày
                </div>
            }
            <div class="flex flex-col sm:flex-row gap-3 mb-6">
                <button
                    class="flex-1 bg-brand-600 text-white py-3.5 rounded-xl font-bold text-base hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 active:scale-[0.98] transition-all duration-200 cursor-pointer">
                    <svg class="w-5 h-5 inline mr-2 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                         stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
                    </svg>
                    Thêm vào giỏ hàng
                </button>
                <button
                    class="flex-1 bg-orange-500 text-white py-3.5 rounded-xl font-bold text-base hover:bg-orange-600 hover:shadow-lg hover:shadow-orange-500/25 active:scale-[0.98] transition-all duration-200 cursor-pointer">
                    Mua ngay
                </button>
            </div>
            @if (Model.ProductBadges.Count > 0)
            {
                <div class="flex flex-wrap gap-2">
                    @foreach (var badge in Model.ProductBadges)
                    {
                        <span
                        class="px-3 py-1 bg-amber-50 text-amber-700 text-xs font-medium rounded-lg border border-amber-200">@badge.Label</span>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Tabs -->
    @{
        var specGroups = Model.GetGroupedTechnicalSpecs();
        var hasSpecGroups = specGroups.Count > 0;
    }
    <div class="mt-10">
        <div class="flex border-b border-brand-200">
            @if (hasSpecGroups)
            {
                <button type="button" onclick="switchTab('specs')"
                        class="tab-btn px-5 py-3 text-sm font-semibold text-brand-700 border-b-2 border-brand-600 -mb-[1px] transition-colors cursor-pointer" id="tab-specs-btn">
                    Thông số kỹ thuật
                </button>
            }
            <button type="button" onclick="switchTab('description')"
                    class="tab-btn px-5 py-3 text-sm font-semibold text-brand-400 border-b-2 border-transparent hover:text-brand-600 transition-colors cursor-pointer" id="tab-description-btn">
                Mô tả sản phẩm
            </button>
        </div>
        <div class="py-6">
            @if (hasSpecGroups)
            {
                <div id="tab-specs" class="tab-content space-y-6">
                    @foreach (var group in specGroups)
                    {
                        <div>
                            <h3 class="text-sm font-bold text-brand-700 mb-3 flex items-center gap-2">
                                <span class="w-1 h-4 bg-brand-500 rounded-full inline-block"></span>
                                @group.Name
                            </h3>
                            <div class="bg-brand-50 rounded-2xl overflow-hidden max-w-2xl">
                                <table class="w-full text-sm">
                                    <tbody>
                                        @{
                                            var isDetailGroup = group.Name == "Cấu hình chi tiết";
                                            var specIdx = 0;
                                        }
                                        @foreach (var item in group.Specs)
                                        {
                                            var isVariantRow = isDetailGroup && specIdx < firstVariantAttrCount;
                                            <tr class="border-b border-brand-100 last:border-0 @(isVariantRow ? "spec-variant-row" : "")"
                                                @if (isVariantRow) { <text>data-key="@item["key"]"</text> }>
                                                <td class="py-3 px-4 font-medium text-brand-500 w-1/3 bg-brand-50/50">@item["key"]</td>
                                                <td class="py-3 px-4 text-brand-800 spec-value">@item["value"]</td>
                                            </tr>
                                            specIdx++;
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            }
            <div id="tab-description" class="tab-content @(hasSpecGroups ? "hidden" : "")">
                @if (!string.IsNullOrEmpty(Model.Description) || hasVariants)
                {
                    <div class="relative" id="desc-wrapper">
                        <div id="desc-content" class="text-sm text-brand-700 leading-relaxed overflow-hidden transition-all duration-300 [&_img]:max-w-full [&_img]:rounded-lg [&_a]:text-brand-600 [&_a]:underline [&_ul]:list-disc [&_ul]:pl-5 [&_ol]:list-decimal [&_ol]:pl-5" style="max-height: 180px;">
                            @if (hasVariants && Model.ProductVariants!.First().Description != null)
                            {
                                @Html.Raw(Model.ProductVariants!.First().Description)
                            }
                            else
                            {
                                @Html.Raw(Model.Description ?? "")
                            }
                        </div>
                        <button id="desc-toggle" type="button"
                                class="mt-3 text-sm font-semibold text-brand-600 hover:text-brand-700 transition-colors cursor-pointer"
                                onclick="toggleDescription()">
                            Xem thêm ↓
                        </button>
                    </div>
                }
                else
                {
                    <p class="text-brand-400">Chưa có mô tả.</p>
                }
            </div>
        </div>
    </div>

    <script>
        (function () {
            var images = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(imageList));
            var mainImg = document.getElementById('main-image');
            if (!mainImg) return; // Không có ảnh, thoát
            var current = 0, timer = null;
            var currentLabel = document.getElementById('slide-current');
            var thumbs = document.querySelectorAll('.slide-thumb');
            var prevBtn = document.getElementById('slide-prev');
            var nextBtn = document.getElementById('slide-next');
                window._slideStop = function() { if (timer) { clearInterval(timer); timer = null; } };
                window._slideGoTo = function(i) {
                    if (i < 0) i = images.length - 1;
                    if (i >= images.length) i = 0;
                    current = i;
                    mainImg.style.opacity = '0.5';
                    setTimeout(function () { mainImg.src = images[current]; mainImg.style.opacity = '1'; }, 150);
                    if (currentLabel) currentLabel.textContent = (current + 1);
                    thumbs.forEach(function (t, idx) {
                        t.classList.toggle('border-brand-500', idx === current);
                        t.classList.toggle('border-brand-100', idx !== current);
                    });
                };
                window._slideSetImages = function(newImages) {
                    if (!newImages || newImages.length === 0) return;
                    images = newImages;
                    current = 0;
                    window._slideStop();
                    window._slideGoTo(0);
                    // Cập nhật counter
                    if (currentLabel) {
                        if (newImages.length > 1) {
                            currentLabel.parentElement.classList.remove('hidden');
                            currentLabel.textContent = '1/' + newImages.length;
                        } else {
                            currentLabel.parentElement.classList.add('hidden');
                        }
                    }
                    // Cập nhật thumbnails container
                    var thumbsContainer = document.getElementById('thumbnails-container');
                    if (thumbsContainer) {
                        thumbsContainer.innerHTML = '';
                        if (newImages.length > 1) {
                            thumbsContainer.parentElement.classList.remove('hidden');
                            newImages.forEach(function(src, i) {
                                var btn = document.createElement('button');
                                btn.type = 'button';
                                btn.setAttribute('data-index', i);
                                btn.className = 'slide-thumb w-16 h-16 rounded-xl overflow-hidden border-2 flex-shrink-0 ' + (i === 0 ? 'border-brand-500' : 'border-brand-100') + ' hover:border-brand-300 transition-all cursor-pointer';
                                var img = document.createElement('img');
                                img.src = src;
                                img.alt = '';
                                img.className = 'w-full h-full object-cover';
                                btn.appendChild(img);
                                btn.addEventListener('click', function() { window._slideGoTo(parseInt(this.getAttribute('data-index'))); window._slideStop(); });
                                thumbsContainer.appendChild(btn);
                            });
                            thumbs = document.querySelectorAll('.slide-thumb');
                        } else {
                            thumbsContainer.parentElement.classList.add('hidden');
                        }
                    }
                };
                function goTo(i) { window._slideGoTo(i); }
                function startAuto() { window._slideStop(); timer = setInterval(function () { goTo(current + 1); }, 3000); }
                function stopAuto() { window._slideStop(); }
                thumbs.forEach(function (t) { t.addEventListener('click', function () { goTo(parseInt(this.getAttribute('data-index'))); stopAuto(); }); });
                if (prevBtn) prevBtn.addEventListener('click', function (e) { e.stopPropagation(); goTo(current - 1); stopAuto(); });
                if (nextBtn) nextBtn.addEventListener('click', function (e) { e.stopPropagation(); goTo(current + 1); stopAuto(); });
                document.addEventListener('keydown', function (e) { if (e.key === 'ArrowLeft') { goTo(current - 1); stopAuto(); } if (e.key === 'ArrowRight') { goTo(current + 1); stopAuto(); } });
                startAuto();
            })();
        </script>
    }
    <script>
        function switchTab(tab) {
            document.querySelectorAll('.tab-content').forEach(function (e) { e.classList.add('hidden'); });
            document.querySelectorAll('.tab-btn').forEach(function (e) { e.classList.remove('text-brand-700', 'border-brand-600'); e.classList.add('text-brand-400', 'border-transparent'); });
            document.getElementById('tab-' + tab).classList.remove('hidden');
            var btn = document.getElementById('tab-' + tab + '-btn');
            btn.classList.remove('text-brand-400', 'border-transparent');
            btn.classList.add('text-brand-700', 'border-brand-600');
        }
        function toggleDescription() {
            var content = document.getElementById('desc-content');
            var btn = document.getElementById('desc-toggle');
            if (!content || !btn) return;
            if (content.style.maxHeight === '180px' || content.style.maxHeight === '') {
                content.style.maxHeight = content.scrollHeight + 'px';
                btn.textContent = 'Thu gọn ↑';
            } else {
                content.style.maxHeight = '180px';
                btn.textContent = 'Xem thêm ↓';
            }
        }

        var hasVariants = @JsonSerializer.Serialize(hasVariants, jsonOpts);
        var productDescription = @Html.Raw(JsonSerializer.Serialize(Model.Description ?? "", jsonOpts));
        var allVariantImages = @Html.Raw(allVariantImagesJson);

        if (hasVariants) {
            // ====== VARIANT SELECTOR ======
            var variants = @Html.Raw(variantsJson);
            var allVariantAttrs = @Html.Raw(allVariantAttrsJson);
            var currentVariantIndex = 0;
            var currentVariant = variants[0];

            // DOM elements
            var priceEl = document.getElementById('variant-price');
            var listPriceEl = document.getElementById('variant-list-price');
            var discountBadgeEl = document.getElementById('variant-discount-badge');
            var skuEl = document.getElementById('variant-sku');
            var stockEl = document.getElementById('variant-stock');
            var selectedInfo = document.getElementById('selected-variant-info');
            var selectedName = document.getElementById('selected-variant-name');
            var specRows = document.querySelectorAll('.spec-variant-row');

            function numberFormat(n) {
                return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
            }

            function updateSpecsFromVariant(idx) {
                var attrs = allVariantAttrs[idx];
                if (!attrs) return;
                specRows.forEach(function(row) {
                    var key = row.getAttribute('data-key');
                    var found = attrs.find(function(a) { return a.key === key; });
                    var cell = row.querySelector('.spec-value');
                    if (found && cell) {
                        cell.textContent = found.value;
                    }
                });
            }

            function updateVariantDisplay(v, idx) {
                priceEl.textContent = numberFormat(v.price) + '₫';
                if (v.listPrice && v.listPrice > v.price) {
                    listPriceEl.textContent = numberFormat(v.listPrice) + '₫';
                    listPriceEl.classList.remove('hidden');
                    var pct = Math.round(((v.listPrice - v.price) / v.listPrice) * 100);
                    discountBadgeEl.textContent = '-' + pct + '%';
                    discountBadgeEl.classList.remove('hidden');
                } else {
                    listPriceEl.classList.add('hidden');
                    discountBadgeEl.classList.add('hidden');
                }

                if (skuEl) skuEl.textContent = v.sku || v.name;

                if (stockEl) {
                    stockEl.textContent = v.stockQuantity > 0 ? 'Còn hàng' : 'Hết hàng';
                    stockEl.className = 'font-medium ' + (v.stockQuantity > 0 ? 'text-green-600' : 'text-red-500');
                }

                if (selectedInfo && selectedName) {
                    selectedInfo.classList.remove('hidden');
                    selectedName.textContent = v.name;
                }

                // Cập nhật ảnh chính theo variant (hỗ trợ đa ảnh)
                var mainImg = document.getElementById('main-image');
                if (mainImg && idx !== undefined) {
                    var variantImages = allVariantImages[idx];
                    if (variantImages && variantImages.length > 0) {
                        if (typeof window._slideSetImages === 'function') {
                            window._slideSetImages(variantImages);
                        } else {
                            mainImg.src = variantImages[0];
                        }
                    } else if (v.imageUrl) {
                        if (typeof window._slideSetImages === 'function') {
                            window._slideSetImages([v.imageUrl]);
                        } else {
                            mainImg.src = v.imageUrl;
                        }
                    }
                }

                // Cập nhật thông số kỹ thuật theo variant
                if (specRows.length > 0 && idx !== undefined) {
                    updateSpecsFromVariant(idx);
                }

                // Cập nhật mô tả sản phẩm theo variant — fallback về product description
                var descContent = document.getElementById('desc-content');
                if (descContent) {
                    var newDesc = v.description || productDescription || '';
                    descContent.innerHTML = newDesc || '<p class="text-brand-400">Chưa có mô tả.</p>';
                    descContent.style.maxHeight = '180px';
                    var toggleBtn = document.getElementById('desc-toggle');
                    if (toggleBtn) toggleBtn.textContent = 'Xem thêm ↓';
                }
            }

            // === FLAT CHIP MODE ===
            var flatChips = document.querySelectorAll('.variant-chip');
            if (flatChips.length > 0) {
                updateVariantDisplay(variants[0], 0);
                flatChips.forEach(function(chip) {
                    chip.addEventListener('click', function() {
                        var idx = parseInt(this.getAttribute('data-index'));
                        currentVariant = variants[idx];
                        currentVariantIndex = idx;
                        updateVariantDisplay(currentVariant, idx);
                        flatChips.forEach(function(c) {
                            c.classList.remove('border-brand-500', 'bg-brand-50', 'text-brand-700');
                            c.classList.add('border-brand-200', 'bg-white', 'text-brand-600');
                        });
                        this.classList.remove('border-brand-200', 'bg-white', 'text-brand-600');
                        this.classList.add('border-brand-500', 'bg-brand-50', 'text-brand-700');
                    });
                });
            }

            // === ATTRIBUTE GROUP MODE ===
            var attrChips = document.querySelectorAll('.attr-chip');
            if (attrChips.length > 0) {
                var selectedAttrs = {};

                function findVariantByAttrs() {
                    var keys = Object.keys(selectedAttrs);
                    if (keys.length === 0) return null;
                    for (var i = 0; i < variants.length; i++) {
                        var v = variants[i];
                        if (!v.attributes) continue;
                        var attrs;
                        try { attrs = JSON.parse(v.attributes); } catch(e) { continue; }
                        if (!attrs) continue;
                        var match = keys.every(function(key) {
                            return attrs.some(function(a) { return a.key === key && a.value === selectedAttrs[key]; });
                        });
                        if (match) return { variant: v, index: i };
                    }
                    return null;
                }

                function refreshAttrChips() {
                    attrChips.forEach(function(chip) {
                        var k = chip.getAttribute('data-attr-key');
                        var v = chip.getAttribute('data-attr-value');
                        if (selectedAttrs[k] === v) {
                            chip.classList.remove('border-brand-200', 'bg-white', 'text-brand-600');
                            chip.classList.add('border-brand-500', 'bg-brand-50', 'text-brand-700');
                        } else {
                            chip.classList.remove('border-brand-500', 'bg-brand-50', 'text-brand-700');
                            chip.classList.add('border-brand-200', 'bg-white', 'text-brand-600');
                        }
                    });
                    var result = findVariantByAttrs();
                    if (result) {
                        currentVariant = result.variant;
                        currentVariantIndex = result.index;
                        updateVariantDisplay(currentVariant, result.index);
                    }
                }

                attrChips.forEach(function(chip) {
                    chip.addEventListener('click', function() {
                        var key = this.getAttribute('data-attr-key');
                        var val = this.getAttribute('data-attr-value');
                        if (selectedAttrs[key] === val) {
                            delete selectedAttrs[key];
                        } else {
                            selectedAttrs[key] = val;
                        }
                        refreshAttrChips();
                    });
                });

                // Chọn mặc định giá trị đầu tiên của mỗi nhóm
                var groups = {};
                attrChips.forEach(function(chip) {
                    var k = chip.getAttribute('data-attr-key');
                    if (!groups[k]) groups[k] = chip.getAttribute('data-attr-value');
                });
                Object.keys(groups).forEach(function(k) { selectedAttrs[k] = groups[k]; });
                refreshAttrChips();
            }

            // Apply initial specs update
            if (specRows.length > 0) {
                updateSpecsFromVariant(0);
            }
        }
    </script>
