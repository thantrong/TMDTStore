@model Product

@{
    Layout = "_Layout";
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Product</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CategoryId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CategoryId)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Slug)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Slug)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ListPrice)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ListPrice)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.SalePrice)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.SalePrice)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ShortDescription)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ShortDescription)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class="col-sm-2">Thông số kỹ thuật</dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.TechnicalSpecs))
            {
                var specs = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string,
            string>>>(Model.TechnicalSpecs);
                if (specs != null && specs.Count > 0)
                {
                    <table class="w-full text-sm">
                        <tbody>
                            @foreach (var item in specs)
                            {
                                <tr class="border-b border-gray-100">
                                    <td class="py-2 pr-4 font-medium text-gray-600 w-1/3">@item["key"]</td>
                                    <td class="py-2 text-gray-900">@item["value"]</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-gray-600 whitespace-pre-line">@Model.TechnicalSpecs</p>
                }
            }
            else
            {
                <p class="text-gray-400">---</p>
            }
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ReviewSummary)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ReviewSummary)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ImageUrl)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ImageUrl)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ImageUrls)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ImageUrls)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.BadgeLabels)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.BadgeLabels)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.BrandName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.BrandName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.RatingAvg)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.RatingAvg)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.RatingCount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.RatingCount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.WarrantyMonths)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.WarrantyMonths)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ReturnDays)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ReturnDays)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.IsActive)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.IsActive)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Category)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Category)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Inventory)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Inventory)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.OrderItems)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.OrderItems)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ProductBadges)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductBadges)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ProductEmbeddings)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductEmbeddings)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Reviews)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Reviews)
        </dd>
    </dl>
</div>
<div>
    @Html.ActionLink("Edit", "Edit", new { id = Model.CategoryId }) |
    <a asp-action="Index">Back to List</a>
</div>