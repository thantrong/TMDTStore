@model TMDTStore.Models.Order
@{
    ViewData["Title"] = "Thanh toán đơn hàng";
    var qrUrl = ViewBag.QrImageUrl as string;
    var content = ViewBag.Content as string;
    var expiresAt = Model.ExpiresAt.HasValue ? (Model.ExpiresAt.Value - DateTime.UtcNow).TotalSeconds : 0;
    if (expiresAt < 0) expiresAt = 0;
}

<div class="max-w-4xl mx-auto">
    <nav class="text-sm text-brand-500 mb-6 flex items-center gap-2 flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="hover:text-brand-600">Trang chủ</a>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <a asp-action="Success" asp-route-id="@Model.Id" class="hover:text-brand-600">Đơn hàng</a>
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-brand-700 font-medium">Thanh toán</span>
    </nav>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- ====== TRÁI: QR Code + Bộ đếm ====== -->
        <div class="bg-white rounded-2xl border border-brand-100 p-6 sm:p-8 flex flex-col items-center">
            <h1 class="text-lg font-heading font-bold text-brand-800 mb-1">Quét mã để thanh toán</h1>
            <p class="text-sm text-brand-500 mb-4">Mã đơn: <strong class="text-brand-700">@Model.Id</strong></p>

            <!-- Bộ đếm -->
            <div class="text-center mb-5">
                <p class="text-xs text-brand-400 mb-1">Thời gian còn lại</p>
                <p id="timer" class="text-3xl font-bold font-mono text-red-500">15:00</p>
            </div>

            <!-- QR Code -->
            @if (!string.IsNullOrEmpty(qrUrl))
            {
                <div class="bg-white p-3 rounded-2xl border border-brand-200 shadow-lg mb-2 inline-flex">
                    <img src="@qrUrl" alt="VietQR" class="w-72 object-contain" />
                </div>
            }
        </div>

        <!-- ====== PHẢI: Thông tin giao dịch + Nút xác nhận ====== -->
        <div class="bg-white rounded-2xl border border-brand-100 p-6 sm:p-8 flex flex-col justify-between">
            <div>
                <h2 class="text-base font-bold text-brand-800 mb-4">Thông tin chuyển khoản</h2>
                <div class="bg-brand-50 rounded-xl p-4 space-y-3 text-sm mb-6">
                    <div class="flex items-center justify-between">
                        <span class="text-brand-500">Ngân hàng</span>
                        <span class="font-semibold text-brand-700">VietinBank</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-brand-500">Số tài khoản</span>
                        <span class="font-semibold text-brand-700 font-mono">0775740390</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-brand-500">Chủ tài khoản</span>
                        <span class="font-semibold text-brand-700">THAN VINH TRONG</span>
                    </div>
                    <hr class="border-brand-200" />
                    <div class="flex items-center justify-between">
                        <span class="text-brand-500">Số tiền</span>
                        <span class="text-xl font-bold text-red-500">@Model.TotalPrice.ToString("#,###")₫</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="text-brand-500">Nội dung chuyển khoản</span>
                        <span class="font-semibold text-brand-700 text-right">@content</span>
                    </div>
                </div>

                <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-sm text-amber-800 mb-6">
                    <p class="font-semibold mb-1">⚠️ Hướng dẫn:</p>
                    <p>1. Mở ứng dụng ngân hàng <strong>VietinBank</strong></p>
                    <p>2. Quét mã QR hoặc nhập thông tin bên cạnh</p>
                    <p>3. Xác nhận chuyển khoản</p>
                    <p>4. Nhấn <strong>"Tôi đã thanh toán"</strong> bên dưới</p>
                </div>
            </div>

            <!-- Nút xác nhận -->
            <form asp-action="ConfirmPayment" asp-route-id="@Model.Id" method="post" class="confirm-payment-form">
                @Html.AntiForgeryToken()
                <button type="submit"
                        class="w-full bg-green-500 text-white py-3.5 rounded-xl font-bold text-base hover:bg-green-600 hover:shadow-lg hover:shadow-green-500/25 active:scale-[0.98] transition-all duration-200 cursor-pointer mb-3">
                    <svg class="w-5 h-5 inline mr-2 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                         stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Tôi đã thanh toán
                </button>
            </form>

            <a asp-action="Success" asp-route-id="@Model.Id"
               class="text-center text-sm text-brand-500 hover:text-brand-600 transition-colors">
                ← Quay lại chi tiết đơn hàng
            </a>
        </div>
    </div>
</div>

<script>
    (function () {
        var totalSeconds = @((int)expiresAt);
        var timerEl = document.getElementById('timer');

        function updateTimer() {
            if (totalSeconds <= 0) {
                timerEl.textContent = 'Hết thời gian';
                timerEl.classList.add('text-red-600');
                return;
            }
            var m = Math.floor(totalSeconds / 60);
            var s = totalSeconds % 60;
            timerEl.textContent = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
            totalSeconds--;
        }

        updateTimer();
        setInterval(updateTimer, 1000);
    })();

    // Xác nhận thanh toán
    document.querySelector('.confirm-payment-form')?.addEventListener('submit', function (e) {
        if (!confirm('Xác nhận bạn đã chuyển khoản ' + numberFormat(@((long)Model.TotalPrice)) + '₫?')) {
            e.preventDefault();
        }
    });

    function numberFormat(n) {
        return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    }
</script>
