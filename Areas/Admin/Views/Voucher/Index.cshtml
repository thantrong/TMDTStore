@model List<TMDTStore.Models.Voucher>
@{
    ViewData["Title"] = "Mã giảm giá";
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-admin-800">Mã giảm giá</h1>
        <p class="text-sm text-admin-500 mt-1">Quản lý mã giảm giá và khuyến mãi</p>
    </div>
    <a asp-action="Create"
       class="inline-flex items-center gap-2 bg-brand-600 text-white px-4 py-2.5 rounded-xl font-semibold text-sm hover:bg-brand-700 transition-all duration-200 cursor-pointer">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Thêm mã giảm giá
    </a>
</div>

<!-- Filter Bar -->
<div class="bg-white rounded-xl shadow-sm border border-admin-200 p-4 mb-6">
    <form method="get" class="flex flex-wrap items-end gap-3">
        <div class="flex-1 min-w-[250px]">
            <label class="block text-xs font-medium text-admin-500 mb-1">Tìm kiếm</label>
            <input type="text" name="search" value="@ViewBag.Search"
                   class="w-full px-3 py-2 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                   placeholder="Mã giảm giá..." />
        </div>
        <button type="submit"
                class="px-4 py-2 bg-admin-800 text-white rounded-lg text-sm font-semibold hover:bg-admin-700 transition-all duration-200 cursor-pointer">
            Tìm
        </button>
        <a asp-action="Index"
           class="px-4 py-2 border border-admin-200 text-admin-600 rounded-lg text-sm font-semibold hover:bg-admin-50 transition-all duration-200 cursor-pointer">
            Xoá lọc
        </a>
    </form>
</div>

<!-- Vouchers Table -->
<div class="bg-white rounded-xl shadow-sm border border-admin-200 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-admin-50 border-b border-admin-200">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold text-admin-600">Mã</th>
                    <th class="text-left px-4 py-3 font-semibold text-admin-600">Loại</th>
                    <th class="text-right px-4 py-3 font-semibold text-admin-600">Giá trị</th>
                    <th class="text-right px-4 py-3 font-semibold text-admin-600">Đơn tối thiểu</th>
                    <th class="text-center px-4 py-3 font-semibold text-admin-600">Lượt dùng</th>
                    <th class="text-center px-4 py-3 font-semibold text-admin-600">Hiệu lực</th>
                    <th class="text-center px-4 py-3 font-semibold text-admin-600">Trạng thái</th>
                    <th class="text-center px-4 py-3 font-semibold text-admin-600">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-admin-100">
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="px-4 py-12 text-center text-admin-400">Chưa có mã giảm giá nào.</td>
                    </tr>
                }
                @foreach (var voucher in Model)
                {
                    <tr class="hover:bg-admin-50 transition-colors">
                        <td class="px-4 py-3">
                            <span class="font-mono font-bold text-brand-600 bg-brand-50 px-2.5 py-1 rounded-lg text-xs tracking-wider">@voucher.Code</span>
                        </td>
                        <td class="px-4 py-3">
                            @if (voucher.DiscountType == "percentage")
                            {
                                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-purple-50 text-purple-700">% Giảm theo %</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 text-blue-700">₫ Giảm tiền mặt</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-right font-semibold text-admin-800">
                            @if (voucher.DiscountType == "percentage")
                            {
                                <span>-@voucher.DiscountValue%</span>
                                if (voucher.MaxDiscountAmount.HasValue)
                                {
                                    <span class="text-xs text-admin-400 block">(tối đa @voucher.MaxDiscountAmount?.ToString("#,###")₫)</span>
                                }
                            }
                            else
                            {
                                <span>-@voucher.DiscountValue.ToString("#,###")₫</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-right text-admin-600">
                            @(voucher.MinOrderValue?.ToString("#,###") ?? "—")₫
                        </td>
                        <td class="px-4 py-3 text-center">
                            @if (voucher.UsageLimit.HasValue)
                            {
                                <span>@(voucher.UsedCount ?? 0)/@voucher.UsageLimit</span>
                            }
                            else
                            {
                                <span>@(voucher.UsedCount ?? 0)/∞</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-center text-xs">
                            @if (voucher.EndDate < DateTime.UtcNow)
                            {
                                <span class="text-red-500">Hết hạn</span>
                            }
                            else if (voucher.StartDate > DateTime.UtcNow)
                            {
                                <span class="text-amber-500">Sắp diễn ra</span>
                            }
                            else
                            {
                                <span class="text-emerald-500">Đang diễn ra</span>
                            }
                            <br>
                            <span class="text-admin-400">@voucher.StartDate.ToString("dd/MM") - @voucher.EndDate.ToString("dd/MM/yyyy")</span>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium @(voucher.IsActive == true ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">
                                <span class="w-1.5 h-1.5 rounded-full @(voucher.IsActive == true ? "bg-emerald-500" : "bg-red-500")"></span>
                                @(voucher.IsActive == true ? "Đang chạy" : "Đã tắt")
                            </span>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center justify-center gap-2">
                                <a asp-action="Edit" asp-route-id="@voucher.Id"
                                   class="p-2 text-admin-400 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-all duration-200 cursor-pointer" title="Sửa">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </a>
                                <form asp-action="ToggleStatus" asp-route-id="@voucher.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="p-2 text-admin-400 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-all duration-200 cursor-pointer"
                                            title="@(voucher.IsActive == true ? "Tắt" : "Bật")"
                                            onclick="return confirm('@(voucher.IsActive == true ? "Tắt mã giảm giá này?" : "Bật mã giảm giá này?")')">
                                        @if (voucher.IsActive == true)
                                        {
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                            </svg>
                                        }
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="flex items-center justify-between px-5 py-4 border-t border-admin-100 bg-admin-50/50">
            <p class="text-sm text-admin-500">
                Hiển thị @(Math.Min(ViewBag.TotalItems ?? 0, ((ViewBag.CurrentPage - 1) * 15) + 1))–@(Math.Min(ViewBag.TotalItems ?? 0, ViewBag.CurrentPage * 15))
                trên tổng số @ViewBag.TotalItems mã
            </p>
            <div class="flex items-center gap-1.5">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search"
                       class="px-3.5 py-1.5 rounded-lg text-sm font-medium transition-all duration-200 cursor-pointer
                              @(i == ViewBag.CurrentPage ? "bg-brand-600 text-white shadow-md" : "bg-white text-admin-600 hover:bg-brand-50 border border-admin-200")">
                       @i
                    </a>
                }
            </div>
        </div>
    }
</div>
