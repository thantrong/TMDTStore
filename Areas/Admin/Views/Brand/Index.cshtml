@model TMDTStore.Models.ViewModels.Brand.BrandListViewModel

@{
    ViewData["Title"] = "Thương hiệu";
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-admin-800">Thương hiệu</h1>
        <p class="text-sm text-admin-500 mt-1">Quản lý thương hiệu sản phẩm</p>
    </div>
    <a asp-action="Create"
       class="inline-flex items-center gap-2 bg-brand-600 text-white px-4 py-2.5 rounded-xl font-semibold text-sm hover:bg-brand-700 transition-all duration-200 cursor-pointer">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Thêm thương hiệu
    </a>
</div>

<!-- Filter Bar -->
<div class="bg-white rounded-xl shadow-sm border border-admin-200 p-4 mb-6">
    <form method="get" class="flex flex-wrap items-end gap-3">
        <div class="flex-1 min-w-[250px]">
            <label class="block text-xs font-medium text-admin-500 mb-1">Tìm kiếm</label>
            <input type="text" name="SearchQuery" value="@Model.SearchQuery"
                   class="w-full px-3 py-2 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                   placeholder="Tên thương hiệu..." />
        </div>
        <button type="submit"
                class="px-4 py-2 bg-admin-800 text-white rounded-lg text-sm font-semibold hover:bg-admin-700 transition-all duration-200 cursor-pointer">
            Tìm
        </button>
        <a asp-action="Index"
           class="px-4 py-2 border border-admin-200 text-admin-600 rounded-lg text-sm font-semibold hover:bg-admin-50 transition-all duration-200 cursor-pointer">
            Xoá lọc
        </a>
    </form>
</div>

<div class="bg-white rounded-xl shadow-sm border border-admin-200 overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-admin-50 border-b border-admin-200">
            <tr>
                <th class="text-left px-5 py-4 font-semibold text-admin-600">Thương hiệu</th>
                <th class="text-left px-5 py-4 font-semibold text-admin-600">Slug</th>
                <th class="text-center px-5 py-4 font-semibold text-admin-600">Sản phẩm</th>
                <th class="text-center px-5 py-4 font-semibold text-admin-600">Trạng thái</th>
                <th class="text-center px-5 py-4 font-semibold text-admin-600">Hành động</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-admin-100">
            @if (Model.Brands.Count == 0)
            {
                <tr>
                    <td colspan="5" class="px-5 py-16 text-center text-admin-400">
                        @if (!string.IsNullOrEmpty(Model.SearchQuery))
                        {
                            <span>Không tìm thấy thương hiệu "<strong class="text-admin-500">@Model.SearchQuery</strong>"</span>
                        }
                        else
                        {
                            <span>Chưa có thương hiệu nào.</span>
                        }
                    </td>
                </tr>
            }
            @foreach (var brand in Model.Brands)
            {
                <tr class="hover:bg-admin-50 transition-colors">
                    <td class="px-5 py-4">
                        <div class="flex items-center gap-4">
                            @if (!string.IsNullOrEmpty(brand.LogoUrl))
                            {
                                <img src="@brand.LogoUrl" alt="@brand.Name" class="w-12 h-12 rounded-xl object-contain border border-admin-200 bg-white p-1" />
                            }
                            else
                            {
                                <div class="w-12 h-12 rounded-xl bg-admin-100 flex items-center justify-center text-admin-400 font-bold text-lg border border-admin-200">
                                    @brand.Name[..1].ToUpper()
                                </div>
                            }
                            <div>
                                <p class="font-medium text-admin-800">@brand.Name</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-5 py-4 text-admin-500">@brand.Slug</td>
                    <td class="px-5 py-4 text-center text-admin-600">@brand.Products.Count</td>
                    <td class="px-5 py-4 text-center">
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium @(brand.IsActive == true ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">
                            <span class="w-1.5 h-1.5 rounded-full @(brand.IsActive == true ? "bg-emerald-500" : "bg-red-500")"></span>
                            @(brand.IsActive == true ? "Hoạt động" : "Đã ẩn")
                        </span>
                    </td>
                    <td class="px-5 py-4">
                        <div class="flex items-center justify-center gap-2">
                            <a asp-action="Details" asp-route-id="@brand.Id"
                               class="p-2 text-admin-400 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-all duration-200 cursor-pointer" title="Chi tiết">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </a>
                            <a asp-action="Edit" asp-route-id="@brand.Id"
                               class="p-2 text-admin-400 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-all duration-200 cursor-pointer" title="Sửa">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </a>
                            <form method="post" asp-action="Delete" asp-route-id="@brand.Id"
                                  onsubmit="return confirm('Xoá thương hiệu @brand.Name?')" class="inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="p-2 text-admin-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all duration-200 cursor-pointer"
                                        title="Xoá">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="flex items-center justify-between px-5 py-4 border-t border-admin-100 bg-admin-50/50">
            <p class="text-sm text-admin-500">
                Hiển thị @(Math.Min(Model.TotalItems, (Model.Page - 1) * Model.PageSize + 1))–@(Math.Min(Model.TotalItems, Model.Page * Model.PageSize))
                trên tổng số @Model.TotalItems thương hiệu
            </p>
            <div class="flex items-center gap-1.5">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchQuery="@Model.SearchQuery"
                       class="px-3.5 py-1.5 rounded-lg text-sm font-medium transition-all duration-200 cursor-pointer
                              @(i == Model.Page
                                  ? "bg-brand-600 text-white shadow-md"
                                  : "bg-white text-admin-600 hover:bg-brand-50 border border-admin-200")">
                       @i
                    </a>
                }
            </div>
        </div>
    }
</div>
