@model List<TMDTStore.Models.Brand>

@{
    ViewData["Title"] = "Thương hiệu";
}

<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-admin-800">Thương hiệu</h1>
        <p class="text-sm text-admin-500 mt-1">Quản lý thương hiệu sản phẩm</p>
    </div>
    <a asp-action="Create"
       class="inline-flex items-center gap-2 bg-brand-600 text-white px-4 py-2.5 rounded-xl font-semibold text-sm hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 transition-all duration-200 cursor-pointer">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Thêm thương hiệu
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-admin-200 overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-admin-50 border-b border-admin-200">
            <tr>
                <th class="text-left px-4 py-3 font-semibold text-admin-600">Thương hiệu</th>
                <th class="text-left px-4 py-3 font-semibold text-admin-600">Slug</th>
                <th class="text-center px-4 py-3 font-semibold text-admin-600">Sản phẩm</th>
                <th class="text-center px-4 py-3 font-semibold text-admin-600">Trạng thái</th>
                <th class="text-center px-4 py-3 font-semibold text-admin-600">Hành động</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-admin-100">
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="px-4 py-12 text-center text-admin-400">Chưa có thương hiệu nào.</td>
                </tr>
            }
            @foreach (var brand in Model)
            {
                <tr class="hover:bg-admin-50 transition-colors">
                    <td class="px-4 py-3">
                        <div class="flex items-center gap-3">
                            @if (!string.IsNullOrEmpty(brand.LogoUrl))
                            {
                                <img src="@brand.LogoUrl" alt="@brand.Name" class="w-8 h-8 object-contain rounded" />
                            }
                            <span class="font-medium text-admin-800">@brand.Name</span>
                        </div>
                    </td>
                    <td class="px-4 py-3 text-admin-500">@brand.Slug</td>
                    <td class="px-4 py-3 text-center text-admin-600">@brand.Products.Count</td>
                    <td class="px-4 py-3 text-center">
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium
                            @(brand.IsActive == true ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">
                            <span
                            class="w-1.5 h-1.5 rounded-full @(brand.IsActive == true ? "bg-emerald-500" : "bg-red-500")"></span>
                            @(brand.IsActive == true ? "Hoạt động" : "Đã ẩn")
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex items-center justify-center">
                            <a asp-action="Edit" asp-route-id="@brand.Id"
                               class="p-2 text-admin-400 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-all duration-200 cursor-pointer"
                               title="Sửa">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
