@model TMDTStore.Models.Brand

@{
    ViewData["Title"] = Model.Name;
}

<div class="max-w-3xl">
    <a asp-action="Index"
       class="inline-flex items-center gap-1 text-sm text-admin-500 hover:text-brand-600 mb-6 transition-colors cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại danh sách
    </a>

    <div class="admin-panel overflow-hidden">
        <!-- Header -->
        <div class="p-6 sm:p-8 border-b border-admin-100">
            <div class="flex items-start justify-between gap-4">
                <div class="flex items-center gap-5">
                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                    {
                        <div
                            class="w-24 h-24 rounded-2xl border border-admin-200 overflow-hidden bg-white p-3 flex items-center justify-center flex-shrink-0">
                            <img src="@Model.LogoUrl" alt="@Model.Name" class="w-full h-full object-contain" />
                        </div>
                    }
                    else
                    {
                        <div
                            class="w-24 h-24 rounded-2xl bg-admin-100 flex items-center justify-center text-admin-400 font-bold text-3xl border border-admin-200 flex-shrink-0">
                            @Model.Name[..1].ToUpper()
                        </div>
                    }
                    <div>
                        <h1 class="text-2xl font-bold text-admin-800">@Model.Name</h1>
                        <p class="text-sm text-admin-500 mt-1">Slug: @Model.Slug</p>
                    </div>
                </div>
                <a asp-action="Edit" asp-route-id="@Model.Id"
                   class="inline-flex items-center gap-2 px-4 py-2 bg-brand-600 text-white rounded-xl text-sm font-semibold hover:bg-brand-700 transition-all duration-200 cursor-pointer">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                    Sửa
                </a>
            </div>
        </div>

        <!-- Info -->
        <div class="p-6 sm:p-8 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider mb-3">Thông tin</h3>
                <dl class="space-y-3 text-sm">
                    <div class="flex justify-between py-1 border-b border-admin-100">
                        <dt class="text-admin-500">Trạng thái</dt>
                        <dd>
                            <span
                                class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium @(Model.IsActive == true ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">
                                <span
                                class="w-1.5 h-1.5 rounded-full @(Model.IsActive == true ? "bg-emerald-500" : "bg-red-500")"></span>
                                @(Model.IsActive == true ? "Hoạt động" : "Đã ẩn")
                            </span>
                        </dd>
                    </div>
                    <div class="flex justify-between py-1 border-b border-admin-100">
                        <dt class="text-admin-500">Số sản phẩm</dt>
                        <dd class="font-medium text-admin-800">@(Model.Products?.Count ?? 0)</dd>
                    </div>
                    <div class="flex justify-between py-1 border-b border-admin-100">
                        <dt class="text-admin-500">Ngày tạo</dt>
                        <dd class="font-medium text-admin-800">@Model.CreatedAt?.ToString("dd/MM/yyyy")</dd>
                    </div>
                </dl>
            </div>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div>
                    <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider mb-3">Mô tả</h3>
                    <p class="text-sm text-admin-600 leading-relaxed">@Model.Description</p>
                </div>
            }
        </div>
    </div>
</div>
