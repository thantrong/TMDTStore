@model TMDTStore.Models.Brand

@{
    ViewData["Title"] = "Sửa thương hiệu";
}

<div class="max-w-2xl">
    <a asp-action="Index"
       class="inline-flex items-center gap-1 text-sm text-admin-500 hover:text-brand-600 mb-6 transition-colors cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại
    </a>

    <div class="admin-panel p-6 sm:p-8">
        <h1 class="text-2xl font-bold text-admin-800 mb-8">Sửa thương hiệu</h1>

        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="space-y-5">
            <input type="hidden" asp-for="Id" />

            <div>
                <label asp-for="Name" class="block text-sm font-medium text-admin-700 mb-1"></label>
                <input asp-for="Name"
                       class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition" />
                <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label class="block text-sm font-medium text-admin-700 mb-1">Logo thương hiệu</label>
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <div class="mb-3 p-4 bg-admin-50 rounded-xl border border-admin-200">
                        <p class="text-xs font-medium text-admin-500 mb-2">Logo hiện tại</p>
                        <div class="flex items-center gap-4">
                            <img src="@Model.LogoUrl" alt="@Model.Name"
                                 class="w-20 h-20 rounded-xl object-contain border border-admin-200 bg-white p-2" />
                            <div class="text-sm text-admin-500">
                                <p class="font-medium text-admin-700">@Model.Name</p>
                                <p class="text-xs truncate max-w-[300px]">@Model.LogoUrl</p>
                            </div>
                        </div>
                    </div>
                    <div id="new-logo-area"></div>
                }
                <input type="file" name="LogoFile" id="logo-input" accept="image/jpeg,image/png,image/webp"
                       class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:bg-brand-50 file:text-brand-700 file:text-xs file:font-semibold hover:file:bg-brand-100 transition" />
                <p class="text-xs text-admin-400 mt-1">JPG, PNG, WebP. Chọn file để thay thế logo hiện tại.</p>
            </div>
            <div>
                <label asp-for="Description" class="block text-sm font-medium text-admin-700 mb-1">Mô tả (tuỳ chọn)</label>
                    <textarea asp-for="Description" rows="3"
                              class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"></textarea>
                </div>
                <div>
                    <label class="flex items-center gap-2">
                        <input asp-for="IsActive"
                               class="w-4 h-4 text-brand-600 focus:ring-brand-500 border-admin-300 rounded" />
                        <span class="text-sm font-medium text-admin-700">Đang hoạt động</span>
                    </label>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

                <div class="flex items-center gap-3 pt-4 border-t border-admin-100">
                    <button type="submit"
                            class="px-6 py-2.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 transition-all duration-200 cursor-pointer">
                        Lưu thay đổi
                    </button>
                    <a asp-action="Index"
                       class="px-6 py-2.5 border border-admin-200 text-admin-600 rounded-xl font-semibold text-sm hover:bg-admin-50 transition-all duration-200 cursor-pointer">
                        Huỷ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.getElementById('logo-input')?.addEventListener('change', function(e) {
        var file = e.target.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function(ev) {
            var area = document.getElementById('new-logo-area');
            area.innerHTML = '<div class="mb-3 p-4 bg-amber-50 rounded-xl border border-amber-200">' +
                '<p class="text-xs font-medium text-amber-600 mb-2">Logo mới (sẽ thay thế)</p>' +
                '<img src="' + ev.target.result + '" class="w-24 h-24 rounded-xl object-contain border border-amber-200 bg-white p-2" />' +
                '</div>';
        };
        reader.readAsDataURL(file);
    });
</script>
