@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool Is(string c) => string.Equals(ctrl, c, StringComparison.OrdinalIgnoreCase);
}
<div class="@ViewData["AdminNavClass"]">
    <p class="admin-section-label">Tổng quan</p>
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
       class="admin-nav-link @(Is("Dashboard") ? "is-active" : "")">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        Dashboard
    </a>

    <p class="admin-section-label">Katalog</p>
    <a asp-area="Admin" asp-controller="Product" asp-action="Index"
       class="admin-nav-link @(Is("Product") || Is("Variant") ? "is-active" : "")">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
        </svg>
        Sản phẩm
    </a>
    @if (User.IsInRole("Admin"))
    {
        <a asp-area="Admin" asp-controller="Category" asp-action="Index"
           class="admin-nav-link @(Is("Category") ? "is-active" : "")">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            Danh mục
        </a>
        <a asp-area="Admin" asp-controller="Brand" asp-action="Index"
           class="admin-nav-link @(Is("Brand") ? "is-active" : "")">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
            </svg>
            Thương hiệu
        </a>
        <a asp-area="Admin" asp-controller="Voucher" asp-action="Index"
           class="admin-nav-link @(Is("Voucher") ? "is-active" : "")">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 5H9l-7 7 7 7h6l7-7-7-7zM9 9a1 1 0 100 2 1 1 0 000-2z" />
            </svg>
            Mã giảm giá
        </a>
    }

    <p class="admin-section-label">Vận hành</p>
    <a asp-area="Admin" asp-controller="Order" asp-action="Index"
       class="admin-nav-link @(Is("Order") ? "is-active" : "")">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        Đơn hàng
    </a>
    <a asp-area="Admin" asp-controller="Review" asp-action="Index"
       class="admin-nav-link @(Is("Review") ? "is-active" : "")">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
        </svg>
        Đánh giá
    </a>
    @if (User.IsInRole("Admin"))
    {
        <a asp-area="Admin" asp-controller="User" asp-action="Index"
           class="admin-nav-link @(Is("User") ? "is-active" : "")">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            Người dùng
        </a>
    }

    <p class="admin-section-label">Khác</p>
    <a asp-area="" asp-controller="Home" asp-action="Index"
       class="admin-nav-link">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Về cửa hàng
    </a>
</div>
