@{
    var specsJson = ViewBag.TechnicalSpecsJson as string ?? "[]";
}

<div id="specs-editor" class="space-y-3">
    <label class="block text-sm font-medium text-admin-700 mb-2">Thông số kỹ thuật</label>
    <p class="text-xs text-admin-400 mb-2">Thêm các thông số kỹ thuật của sản phẩm (VD: CPU, RAM, Màn hình...)</p>

    <div id="specs-list" class="space-y-2">
        <!-- Các dòng thông số sẽ được JavaScript render ở đây -->
    </div>

    <button type="button" id="add-spec-btn"
            class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-brand-600 bg-brand-50 rounded-lg hover:bg-brand-100 transition-all duration-200 cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Thêm thông số
    </button>

    <!-- Hidden field để lưu JSON -->
    <input type="hidden" id="TechnicalSpecs" name="TechnicalSpecs" value='@specsJson' />
</div>

<script>
    (function () {
        var specsData = [];
        try {
            specsData = JSON.parse(document.getElementById('TechnicalSpecs')?.value || '[]');
        } catch (e) { specsData = []; }

        var specsList = document.getElementById('specs-list');
        var addBtn = document.getElementById('add-spec-btn');
        var hiddenField = document.getElementById('TechnicalSpecs');

        function renderSpecs() {
            specsList.innerHTML = '';
            specsData.forEach(function (item, index) {
                var row = document.createElement('div');
                row.className = 'flex items-center gap-2';
                row.innerHTML = `
                        <input type="text" value="${escapeHtml(item.key)}"
                               placeholder="Tên thông số (VD: CPU)"
                               class="spec-key flex-1 px-3 py-2 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                               data-index="${index}" />
                        <input type="text" value="${escapeHtml(item.value)}"
                               placeholder="Giá trị (VD: Intel i5-13420H)"
                               class="spec-value flex-[2] px-3 py-2 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                               data-index="${index}" />
                        <button type="button" onclick="removeSpec(${index})"
                                class="p-2 text-red-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all duration-200 cursor-pointer">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    `;
                specsList.appendChild(row);
            });
            updateHiddenField();
            attachInputListeners();
        }

        function escapeHtml(str) {
            var div = document.createElement('div');
            div.textContent = str || '';
            return div.innerHTML;
        }

        function updateHiddenField() {
            var rows = specsList.querySelectorAll('.spec-key');
            var newData = [];
            rows.forEach(function (input, index) {
                var key = input.value.trim();
                var value = document.querySelectorAll('.spec-value')[index]?.value.trim() || '';
                if (key) {
                    newData.push({ key: key, value: value });
                }
            });
            specsData = newData;
            hiddenField.value = JSON.stringify(specsData);
        }

        function attachInputListeners() {
            specsList.querySelectorAll('input').forEach(function (input) {
                input.addEventListener('input', updateHiddenField);
            });
        }

        window.removeSpec = function (index) {
            specsData.splice(index, 1);
            renderSpecs();
        };

        if (addBtn) {
            addBtn.addEventListener('click', function () {
                specsData.push({ key: '', value: '' });
                renderSpecs();
                // Focus vào ô key mới
                var lastKey = specsList.querySelector('.spec-key:last-child');
                if (lastKey) setTimeout(function () { lastKey.focus(); }, 100);
            });
        }

        renderSpecs();
    })();
</script>
