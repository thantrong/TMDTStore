<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Admin TVT PC</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&family=Fira+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <script src="https://cdn.ckeditor.com/ckeditor5/41.0.0/classic/ckeditor.js"></script>
    @await RenderSectionAsync("Styles", required: false)
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#ecfeff',
                            100: '#cffafe',
                            200: '#a5f3fc',
                            300: '#67e8f9',
                            400: '#22d3ee',
                            500: '#06b6d4',
                            600: '#0891b2',
                            700: '#0e7490',
                            800: '#155e75',
                            900: '#164e63',
                        },
                        admin: {
                            50: '#f8fafc',
                            100: '#f1f5f9',
                            200: '#e2e8f0',
                            300: '#cbd5e1',
                            400: '#94a3b8',
                            500: '#64748b',
                            600: '#475569',
                            700: '#334155',
                            800: '#1e293b',
                            900: '#0b1220',
                        }
                    },
                    fontFamily: {
                        sans: ['"Fira Sans"', 'system-ui', 'sans-serif'],
                        mono: ['"Fira Code"', 'ui-monospace', 'monospace'],
                    }
                }
            }
        }
    </script>
</head>
<body class="admin-body flex h-screen overflow-hidden bg-admin-100 font-sans text-admin-800">
    @await Html.PartialAsync("_ToastNotification")

    <!-- Desktop sidebar -->
    <aside class="hidden lg:flex lg:flex-col w-[260px] shrink-0 bg-admin-900 text-admin-100 border-r border-admin-800">
        <div class="h-16 flex items-center px-5 border-b border-white/5">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="flex items-center gap-3 cursor-pointer group">
                <div class="size-9 rounded-lg bg-gradient-to-br from-brand-400 to-brand-700 flex items-center justify-center shadow-lg shadow-brand-600/30">
                    <svg class="size-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                </div>
                <div>
                    <p class="font-semibold text-sm tracking-tight text-white group-hover:text-brand-200 transition-colors">TVT PC</p>
                    <p class="text-[11px] text-admin-400 font-medium">Operations Console</p>
                </div>
            </a>
        </div>

        <nav class="flex-1 overflow-y-auto admin-scroll py-3 px-3 space-y-0.5">
            @{ ViewData["AdminNavClass"] = "space-y-0.5"; }
            @await Html.PartialAsync("_AdminNav")
        </nav>

        <div class="p-3 border-t border-white/5">
            <div class="rounded-xl bg-white/5 px-3 py-3 mb-2">
                <p class="text-[11px] text-admin-400 uppercase tracking-wide">Đăng nhập</p>
                <p class="text-sm font-medium text-admin-100 truncate">@(User.Identity?.Name ?? "Admin")</p>
            </div>
            <a asp-area="" asp-controller="Auth" asp-action="Logout"
               class="admin-nav-link hover:!text-red-300 hover:!bg-red-500/10">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Đăng xuất
            </a>
        </div>
    </aside>

    <!-- Main column -->
    <div class="flex-1 flex flex-col min-w-0">
        <header class="admin-topbar sticky top-0 z-30 h-16 border-b border-admin-200 px-4 sm:px-6 lg:px-8 flex items-center justify-between gap-4">
            <div class="flex items-center gap-3 min-w-0">
                <button id="mobile-sidebar-toggle" type="button"
                        class="lg:hidden p-2 rounded-lg text-admin-500 hover:text-admin-800 hover:bg-admin-100 transition-colors cursor-pointer"
                        aria-label="Mở menu">
                    <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>
                <div class="min-w-0">
                    <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-admin-400">Admin</p>
                    <h1 class="text-base sm:text-lg font-semibold text-admin-900 truncate leading-tight">@ViewData["Title"]</h1>
                </div>
            </div>
            <div class="flex items-center gap-2 sm:gap-3">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-area="Admin" asp-controller="Product" asp-action="Create"
                       class="admin-btn-primary hidden sm:inline-flex">
                        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                        </svg>
                        Thêm SP
                    </a>
                }
                <a asp-area="Admin" asp-controller="Order" asp-action="Index"
                   class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-admin-200 bg-white text-sm font-medium text-admin-700 hover:border-brand-300 hover:text-brand-700 transition-colors cursor-pointer">
                    <svg class="size-4 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    <span class="hidden md:inline">Đơn hàng</span>
                </a>
            </div>
        </header>

        <!-- Mobile drawer -->
        <div id="mobile-sidebar-overlay" class="fixed inset-0 z-40 hidden bg-admin-900/50 backdrop-blur-[2px] lg:hidden"></div>
        <aside id="mobile-sidebar"
               class="fixed top-0 left-0 z-50 h-full w-[280px] bg-admin-900 text-admin-100 -translate-x-full transition-transform duration-300 lg:hidden overflow-y-auto admin-scroll">
            <div class="h-16 flex items-center justify-between px-5 border-b border-white/5">
                <span class="font-semibold text-sm">TVT PC Admin</span>
                <button id="mobile-sidebar-close" type="button"
                        class="p-1.5 rounded-lg text-admin-400 hover:text-white hover:bg-white/5 transition-colors cursor-pointer"
                        aria-label="Đóng menu">
                    <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <nav class="py-3 px-3">
                @{ ViewData["AdminNavClass"] = "space-y-0.5"; }
                @await Html.PartialAsync("_AdminNav")
                <div class="mt-4 pt-3 border-t border-white/5">
                    <a asp-area="" asp-controller="Auth" asp-action="Logout" class="admin-nav-link hover:!text-red-300">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                        Đăng xuất
                    </a>
                </div>
            </nav>
        </aside>

        <main class="flex-1 overflow-y-auto admin-main-scroll">
            <div class="px-4 sm:px-6 lg:px-8 xl:px-10 py-6 w-full max-w-none">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        (function () {
            var toggleBtn = document.getElementById('mobile-sidebar-toggle');
            var closeBtn = document.getElementById('mobile-sidebar-close');
            var sidebar = document.getElementById('mobile-sidebar');
            var overlay = document.getElementById('mobile-sidebar-overlay');
            function openSidebar() {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                document.body.classList.add('overflow-hidden');
            }
            function closeSidebar() {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
                document.body.classList.remove('overflow-hidden');
            }
            toggleBtn && toggleBtn.addEventListener('click', openSidebar);
            closeBtn && closeBtn.addEventListener('click', closeSidebar);
            overlay && overlay.addEventListener('click', closeSidebar);
        })();
    </script>
</body>
</html>
