@model TMDTStore.Models.ViewModels.Category.CategoryEditViewModels

@using TMDTStore.Models

@{
    ViewData["Title"] = "Sửa danh mục";
    var breadcrumb = ViewBag.Breadcrumb as List<Category> ?? new List<Category>();
}

<div class="max-w-2xl">
    <!-- Breadcrumb -->
    @if (breadcrumb.Count > 0)
    {
        <nav class="text-sm text-admin-500 mb-4">
            <a asp-action="Index" class="hover:text-brand-600 transition-colors">Danh mục</a>
            @foreach (var crumb in breadcrumb)
            {
                <span class="mx-1.5">/</span>
                @if (crumb.Id == Model.Id)
                {
                    <span class="text-admin-800 font-medium">@crumb.Name</span>
                }
                else
                {
                    <a asp-action="Edit" asp-route-id="@crumb.Id" class="hover:text-brand-600 transition-colors">@crumb.Name</a>
                }
            }
        </nav>
    }

    <a asp-action="Index"
       class="inline-flex items-center gap-1 text-sm text-admin-500 hover:text-brand-600 mb-4 transition-colors cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại danh sách
    </a>

    <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-6 sm:p-8">
        <h1 class="text-2xl font-bold text-admin-800 mb-8">Sửa danh mục</h1>

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="space-y-5">

            <div>
                <label asp-for="Name" class="block text-sm font-medium text-admin-700 mb-1"></label>
                <input asp-for="Name"
                       class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition" />
                <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label asp-for="ParentId" class="block text-sm font-medium text-admin-700 mb-1">Danh mục cha</label>
                <select asp-for="ParentId"
                        class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition">
                    <option value="">-- Không có --</option>
                    @if (ViewBag.ParentCategories != null)
                    {
                        foreach (var parent in ViewBag.ParentCategories)
                        {
                            <option value="@parent.Id" selected="@(Model.ParentId == parent.Id)">@parent.Name</option>
                        }
                    }
                </select>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div class="flex items-center gap-3 pt-4 border-t border-admin-100">
                <button type="submit"
                        class="px-6 py-2.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 transition-all duration-200 cursor-pointer">
                    Lưu thay đổi
                </button>
                <a asp-action="Index"
                   class="px-6 py-2.5 border border-admin-200 text-admin-600 rounded-xl font-semibold text-sm hover:bg-admin-50 transition-all duration-200 cursor-pointer">
                    Huỷ
                </a>
            </div>
        </form>
    </div>
</div>