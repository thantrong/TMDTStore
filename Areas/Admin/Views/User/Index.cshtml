@model List<TMDTStore.Models.User>
@{
    ViewData["Title"] = "Quản lý người dùng";
    var userRoles = ViewBag.UserRoles as Dictionary<string, List<string>> ?? new();
}

<div class="flex items-center justify-between mb-5 gap-3">
    <p class="text-sm text-admin-500">Quản lý tất cả tài khoản người dùng</p>
</div>

<!-- Search & Filter -->
<div class="admin-panel p-4 mb-6">
    <form method="get" class="flex flex-wrap items-end gap-3">
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs font-medium text-admin-500 mb-1">Tìm kiếm</label>
            <input type="text" name="search" value="@ViewBag.Search"
                   class="w-full px-3 py-2 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                   placeholder="Tên, email, SĐT..." />
        </div>
        <div class="w-44">
            <label class="block text-xs font-medium text-admin-500 mb-1">Vai trò</label>
            <select name="role" class="w-full px-3 py-2 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition">
                <option value="">Tất cả</option>
                @foreach (var r in ViewBag.AllRoles as List<TMDTStore.Models.Role> ?? new())
                {
                    <option value="@r.Name" selected="@(ViewBag.RoleFilter == r.Name)">@r.Name</option>
                }
            </select>
        </div>
        <button type="submit"
                class="px-4 py-2 bg-admin-800 text-white rounded-lg text-sm font-semibold hover:bg-admin-700 transition-all duration-200 cursor-pointer">
            Lọc
        </button>
        <a asp-action="Index"
           class="px-4 py-2 border border-admin-200 text-admin-600 rounded-lg text-sm font-semibold hover:bg-admin-50 transition-all duration-200 cursor-pointer">
            Xoá lọc
        </a>
    </form>
</div>

<!-- Users Table -->
<div class="admin-panel overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-admin-50 border-b border-admin-200">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold text-admin-600">Người dùng</th>
                    <th class="text-left px-4 py-3 font-semibold text-admin-600">Email</th>
                    <th class="text-center px-4 py-3 font-semibold text-admin-600">Vai trò</th>
                    <th class="text-center px-4 py-3 font-semibold text-admin-600">Trạng thái</th>
                    <th class="text-center px-4 py-3 font-semibold text-admin-600">Ngày tham gia</th>
                    <th class="text-center px-4 py-3 font-semibold text-admin-600">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-admin-100">
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="px-4 py-12 text-center text-admin-400">Không tìm thấy người dùng nào.</td>
                    </tr>
                }
                @foreach (var user in Model)
                {
                    var roles = userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : new();
                    <tr class="hover:bg-admin-50 transition-colors">
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-100 to-brand-200 flex items-center justify-center text-brand-700 font-bold text-sm flex-shrink-0 overflow-hidden">
                                    @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                    {
                                        <img src="@user.AvatarUrl" alt="" class="w-full h-full object-cover" />
                                    }
                                    else
                                    {
                                        @user.FullName[..1].ToUpper()
                                    }
                                </div>
                                <div>
                                    <p class="font-medium text-admin-800">@user.FullName</p>
                                    <p class="text-xs text-admin-400">@@@user.UserName</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-4 py-3 text-admin-600">
                            @user.Email
                            @if (user.EmailConfirmed)
                            {
                                <span class="ml-1 text-emerald-500" title="Đã xác nhận">✓</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-center">
                            @foreach (var r in roles)
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium @(r == "Admin" ? "bg-purple-50 text-purple-700 border border-purple-200" : "bg-blue-50 text-blue-700 border border-blue-200")">
                                    @r
                                </span>
                            }
                            @if (roles.Count == 0)
                            {
                                <span class="text-admin-400 text-xs">—</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-center">
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium @(user.IsActive == true ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">
                                <span class="w-1.5 h-1.5 rounded-full @(user.IsActive == true ? "bg-emerald-500" : "bg-red-500")"></span>
                                @(user.IsActive == true ? "Hoạt động" : "Đã khoá")
                            </span>
                        </td>
                        <td class="px-4 py-3 text-center text-admin-500 text-xs">
                            @user.CreatedAt?.ToString("dd/MM/yyyy")
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center justify-center gap-2">
                                <a asp-action="Details" asp-route-id="@user.Id"
                                   class="p-2 text-admin-400 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-all duration-200 cursor-pointer" title="Chi tiết">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                    </svg>
                                </a>
                                <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="p-2 text-admin-400 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-all duration-200 cursor-pointer"
                                            title="@(user.IsActive == true ? "Khoá" : "Mở khoá")"
                                            onclick="return confirm('@(user.IsActive == true ? $"Khoá tài khoản {user.Email}?" : $"Mở khoá tài khoản {user.Email}?")')">
                                        @if (user.IsActive == true)
                                        {
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                            </svg>
                                        }
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <div class="flex items-center justify-between px-5 py-4 border-t border-admin-100 bg-admin-50/50">
            <p class="text-sm text-admin-500">
                Hiển thị @(Math.Min(ViewBag.TotalItems ?? 0, ((ViewBag.CurrentPage - 1) * 15) + 1))–@(Math.Min(ViewBag.TotalItems ?? 0, ViewBag.CurrentPage * 15))
                trên tổng số @ViewBag.TotalItems người dùng
            </p>
            <div class="flex items-center gap-1.5">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@ViewBag.Search"
                       asp-route-role="@ViewBag.RoleFilter"
                       class="px-3.5 py-1.5 rounded-lg text-sm font-medium transition-all duration-200 cursor-pointer
                              @(i == ViewBag.CurrentPage ? "bg-brand-600 text-white shadow-md" : "bg-white text-admin-600 hover:bg-brand-50 border border-admin-200")">
                       @i
                    </a>
                }
            </div>
        </div>
    }
</div>
