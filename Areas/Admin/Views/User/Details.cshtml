@model TMDTStore.Models.User
@{
    ViewData["Title"] = "Chi tiết người dùng";
    var roles = ViewBag.Roles as IList<string> ?? new List<string>();
    var recentOrders = ViewBag.RecentOrders as List<TMDTStore.Models.Order> ?? new();
    var statusLabels = new Dictionary<string, string>
    {
        { "Pending", "Chờ xử lý" }, { "WaitingPayment", "Chờ thanh toán" },
        { "Confirmed", "Đã xác nhận" }, { "Shipping", "Đang giao" },
        { "Delivered", "Đã giao" }, { "Cancelled", "Đã huỷ" }
    };
    var statusColors = new Dictionary<string, string>
    {
        { "Pending", "bg-amber-50 text-amber-700 border-amber-200" },
        { "WaitingPayment", "bg-yellow-50 text-yellow-700 border-yellow-200" },
        { "Confirmed", "bg-blue-50 text-blue-700 border-blue-200" },
        { "Shipping", "bg-purple-50 text-purple-700 border-purple-200" },
        { "Delivered", "bg-emerald-50 text-emerald-700 border-emerald-200" },
        { "Cancelled", "bg-red-50 text-red-700 border-red-200" }
    };
}

<div class="mb-6">
    <a asp-action="Index"
       class="inline-flex items-center gap-1.5 text-sm text-admin-500 hover:text-admin-700 transition-colors mb-4">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại danh sách
    </a>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- LEFT: User Info -->
    <div class="space-y-6">

        <!-- Profile Card -->
        <div class="admin-panel p-5 text-center">
            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-brand-100 to-brand-200 flex items-center justify-center text-3xl font-bold text-brand-700 mx-auto overflow-hidden ring-4 ring-brand-50 shadow-md mb-3">
                @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                {
                    <img src="@Model.AvatarUrl" alt="" class="w-full h-full object-cover" />
                }
                else
                {
                    @Model.FullName[..1].ToUpper()
                }
            </div>
            <h2 class="text-lg font-bold text-admin-800">@Model.FullName</h2>
            <p class="text-sm text-admin-400">@@@Model.UserName</p>
            <div class="flex items-center justify-center gap-2 mt-3">
                @foreach (var r in roles)
                {
                    <span class="px-3 py-1 rounded-full text-xs font-medium @(r == "Admin" ? "bg-purple-50 text-purple-700 border border-purple-200" : "bg-blue-50 text-blue-700 border border-blue-200")">@r</span>
                }
            </div>
            <div class="mt-4 pt-4 border-t border-admin-100">
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium @(Model.IsActive == true ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">
                    <span class="w-2 h-2 rounded-full @(Model.IsActive == true ? "bg-emerald-500" : "bg-red-500")"></span>
                    @(Model.IsActive == true ? "Hoạt động" : "Đã khoá")
                </span>
            </div>

            <!-- Actions -->
            <div class="mt-4 space-y-2">
                <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="w-full py-2 px-4 rounded-xl text-sm font-semibold transition-all duration-200 cursor-pointer
                                   @(Model.IsActive == true ? "bg-red-50 text-red-700 hover:bg-red-100 border border-red-200" : "bg-emerald-50 text-emerald-700 hover:bg-emerald-100 border border-emerald-200")"
                            onclick="return confirm('@(Model.IsActive == true ? $"Khoá tài khoản {Model.Email}?" : $"Mở khoá tài khoản {Model.Email}?")')">
                        @(Model.IsActive == true ? "🔒 Khoá tài khoản" : "🔓 Mở khoá tài khoản")
                    </button>
                </form>
            </div>
        </div>

        <!-- Reset Password -->
        <div class="admin-panel p-5">
            <h3 class="font-bold text-admin-800 mb-3">Đặt lại mật khẩu</h3>
            <form asp-action="ResetPassword" method="post" class="space-y-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="text" name="newPassword" required minlength="6"
                       class="w-full px-3 py-2 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                       placeholder="Nhập mật khẩu mới..." />
                <button type="submit"
                        class="w-full py-2 bg-amber-500 text-white rounded-xl text-sm font-semibold hover:bg-amber-600 transition-all duration-200 cursor-pointer"
                        onclick="return confirm('Đặt lại mật khẩu cho @Model.Email?')">
                    Đặt lại mật khẩu
                </button>
            </form>
        </div>
    </div>

    <!-- RIGHT: Details + Orders -->
    <div class="xl:col-span-2 space-y-6">

        <!-- Thông tin chi tiết -->
        <div class="admin-panel p-5">
            <h3 class="font-bold text-admin-800 mb-4">Thông tin tài khoản</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                <div>
                    <p class="text-admin-400">Email</p>
                    <p class="font-medium text-admin-800">@Model.Email</p>
                </div>
                <div>
                    <p class="text-admin-400">Email xác nhận</p>
                    <p class="font-medium @(Model.EmailConfirmed ? "text-emerald-600" : "text-amber-600")">
                        @(Model.EmailConfirmed ? "Đã xác nhận ✓" : "Chưa xác nhận")
                    </p>
                </div>
                <div>
                    <p class="text-admin-400">Số điện thoại</p>
                    <p class="font-medium text-admin-800">@(Model.PhoneNumber ?? "—")</p>
                </div>
                <div>
                    <p class="text-admin-400">Tên đăng nhập</p>
                    <p class="font-medium text-admin-800">@Model.UserName</p>
                </div>
                <div>
                    <p class="text-admin-400">Ngày tham gia</p>
                    <p class="font-medium text-admin-800">@Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div>
                    <p class="text-admin-400">ID</p>
                    <p class="font-mono text-xs text-admin-500">@Model.Id</p>
                </div>
            </div>
        </div>

        <!-- Thống kê -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="admin-panel p-4 text-center">
                <p class="text-2xl font-bold text-brand-600">@ViewBag.TotalOrders</p>
                <p class="text-sm text-admin-500">Đơn hàng</p>
            </div>
            <div class="admin-panel p-4 text-center">
                <p class="text-2xl font-bold text-brand-600">@ViewBag.TotalReviews</p>
                <p class="text-sm text-admin-500">Đánh giá</p>
            </div>
            <div class="admin-panel p-4 text-center">
                <p class="text-2xl font-bold text-brand-600">@(((decimal)ViewBag.TotalSpent).ToString("#,###"))₫</p>
                <p class="text-sm text-admin-500">Đã chi tiêu</p>
            </div>
        </div>

        <!-- Đơn hàng gần đây -->
        <div class="admin-panel overflow-hidden">
            <div class="flex items-center justify-between px-5 py-4 border-b border-admin-100">
                <h3 class="font-bold text-admin-800">Đơn hàng gần đây</h3>
                <a asp-area="Admin" asp-controller="Order" asp-action="Index" asp-route-search="@Model.Id"
                   class="text-sm font-medium text-brand-600 hover:text-brand-700 transition-colors">Xem tất cả →</a>
            </div>
            @if (recentOrders.Count > 0)
            {
                <div class="divide-y divide-admin-100">
                    @foreach (var order in recentOrders)
                    {
                        var sl = statusLabels.ContainsKey(order.Status) ? statusLabels[order.Status] : order.Status;
                        var sc = statusColors.ContainsKey(order.Status) ? statusColors[order.Status] : "bg-admin-50 text-admin-700";
                        <a asp-area="Admin" asp-controller="Order" asp-action="Details" asp-route-id="@order.Id"
                           class="flex items-center justify-between px-5 py-3 hover:bg-admin-50 transition-colors">
                            <div>
                                <p class="text-sm font-medium text-admin-800">#@order.Id</p>
                                <p class="text-xs text-admin-400 mt-0.5">@order.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-bold text-admin-800">@order.TotalPrice.ToString("#,###")₫</p>
                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border @sc">@sl</span>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="px-5 py-8 text-center text-sm text-admin-400">Chưa có đơn hàng nào.</div>
            }
        </div>
    </div>
</div>
