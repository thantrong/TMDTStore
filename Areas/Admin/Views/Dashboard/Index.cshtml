@{
    ViewData["Title"] = "Tổng quan";
    var statusLabels = new Dictionary<string, string>
    {
        { "Pending", "Chờ xử lý" }, { "WaitingPayment", "Chờ thanh toán" },
        { "Confirmed", "Đã xác nhận" }, { "Shipping", "Đang giao" },
        { "Delivered", "Đã giao" }, { "Cancelled", "Đã huỷ" }
    };
    var statusBgColors = new Dictionary<string, string>
    {
        { "Pending", "bg-amber-50 text-amber-800 border-amber-200" },
        { "WaitingPayment", "bg-yellow-50 text-yellow-800 border-yellow-200" },
        { "Confirmed", "bg-sky-50 text-sky-800 border-sky-200" },
        { "Shipping", "bg-cyan-50 text-cyan-800 border-cyan-200" },
        { "Delivered", "bg-emerald-50 text-emerald-800 border-emerald-200" },
        { "Cancelled", "bg-red-50 text-red-800 border-red-200" }
    };
}

<div class="mb-6 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
    <div>
        <p class="text-sm text-admin-500">Theo dõi doanh thu, tồn kho và đơn cần xử lý trong ngày.</p>
    </div>
    <p class="text-xs font-mono text-admin-400">@(((DateTime?)ViewBag.LocalNow ?? DateTime.Now).ToString("dddd, dd/MM/yyyy HH:mm"))</p>
</div>

<!-- KPI -->
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-6 gap-3 mb-6">
    <div class="admin-kpi">
        <div class="flex items-start gap-3">
            <div class="size-10 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center shrink-0">
                <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div class="min-w-0">
                <p class="text-[11px] font-semibold uppercase tracking-wide text-admin-400">Doanh thu hôm nay</p>
                <p class="text-lg font-bold text-admin-900 tabular-nums">@(((decimal)ViewBag.TodayRevenue).ToString("#,##0"))₫</p>
            </div>
        </div>
    </div>
    <div class="admin-kpi">
        <div class="flex items-start gap-3">
            <div class="size-10 rounded-lg bg-brand-50 text-brand-700 flex items-center justify-center shrink-0">
                <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div class="min-w-0">
                <p class="text-[11px] font-semibold uppercase tracking-wide text-admin-400">Doanh thu tháng</p>
                <p class="text-lg font-bold text-admin-900 tabular-nums">@(((decimal)ViewBag.MonthRevenue).ToString("#,##0"))₫</p>
            </div>
        </div>
    </div>
    <div class="admin-kpi">
        <div class="flex items-start gap-3">
            <div class="size-10 rounded-lg bg-sky-50 text-sky-700 flex items-center justify-center shrink-0">
                <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div class="min-w-0">
                <p class="text-[11px] font-semibold uppercase tracking-wide text-admin-400">Đơn hôm nay</p>
                <p class="text-lg font-bold text-admin-900 tabular-nums">@ViewBag.OrdersToday</p>
            </div>
        </div>
    </div>
    <div class="admin-kpi">
        <div class="flex items-start gap-3">
            <div class="size-10 rounded-lg bg-admin-100 text-admin-700 flex items-center justify-center shrink-0">
                <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
            </div>
            <div class="min-w-0">
                <p class="text-[11px] font-semibold uppercase tracking-wide text-admin-400">Sản phẩm</p>
                <p class="text-lg font-bold text-admin-900 tabular-nums">@ViewBag.TotalProducts</p>
            </div>
        </div>
    </div>
    <div class="admin-kpi">
        <div class="flex items-start gap-3">
            <div class="size-10 rounded-lg bg-amber-50 text-amber-700 flex items-center justify-center shrink-0">
                <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            </div>
            <div class="min-w-0">
                <p class="text-[11px] font-semibold uppercase tracking-wide text-admin-400">Người dùng</p>
                <p class="text-lg font-bold text-admin-900 tabular-nums">@ViewBag.TotalUsers</p>
            </div>
        </div>
