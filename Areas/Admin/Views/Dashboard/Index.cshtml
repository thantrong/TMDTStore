    <div class="admin-kpi @(ViewBag.LowStockVariants > 0 ? "border-red-200" : "")">
        <div class="flex items-start gap-3">
            <div class="size-10 rounded-lg @(ViewBag.LowStockVariants > 0 ? "bg-red-50 text-red-600" : "bg-admin-100 text-admin-500") flex items-center justify-center shrink-0">
                <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
            </div>
            <div class="min-w-0">
                <p class="text-[11px] font-semibold uppercase tracking-wide text-admin-400">Tồn kho thấp</p>
                <p class="text-lg font-bold @(ViewBag.LowStockVariants > 0 ? "text-red-600" : "text-admin-900")">
                    @(ViewBag.LowStockVariants > 0 ? ViewBag.LowStockVariants + " biến thể" : "Ổn định")
                </p>
                @if (ViewBag.OutOfStock > 0)
                {
                    <p class="text-xs text-red-500 mt-0.5">@ViewBag.OutOfStock hết hàng</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Revenue chart + table -->
@{
    var dailyRev = ViewBag.DailyRevenue as IList<TMDTStore.Models.ViewModels.Admin.DailyRevenueItem>
        ?? new List<TMDTStore.Models.ViewModels.Admin.DailyRevenueItem>();
    var weekRevenue = dailyRev.Sum(x => x.Revenue);
    var weekDelivered = dailyRev.Sum(x => x.DeliveredCount);
    var weekOrders = dailyRev.Sum(x => x.OrderCount);
}
<div class="admin-panel mb-6">
    <div class="admin-panel-head">
        <div>
            <h2 class="font-semibold text-admin-900">Doanh thu 7 ngày</h2>
            <p class="text-xs text-admin-400 mt-0.5">Chỉ tính đơn đã giao · theo giờ Việt Nam</p>
        </div>
        <div class="text-right">
            <p class="text-sm font-bold text-admin-900 tabular-nums">@weekRevenue.ToString("#,##0")₫</p>
            <p class="text-[11px] text-admin-400">@weekDelivered giao / @weekOrders đơn</p>
        </div>
    </div>
    <div class="p-5">
        <div class="h-64 sm:h-72">
            <canvas id="revenueChart" aria-label="Biểu đồ doanh thu 7 ngày" role="img"></canvas>
        </div>
        <div class="overflow-x-auto mt-5 border-t border-admin-100 pt-4">
            <table class="w-full text-sm admin-table">
                <thead class="bg-admin-50/80">
                    <tr>
                        <th class="text-left px-3 py-2">Ngày</th>
                        <th class="text-right px-3 py-2">Doanh thu (đã giao)</th>
                        <th class="text-right px-3 py-2">Đơn đã giao</th>
                        <th class="text-right px-3 py-2">Tổng đơn</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-admin-100">
                    @foreach (var item in dailyRev)
                    {
                        <tr>
                            <td class="px-3 py-2.5 font-medium text-admin-800">@item.Date</td>
                            <td class="px-3 py-2.5 text-right font-semibold text-admin-900 tabular-nums">
                                @(item.Revenue > 0 ? item.Revenue.ToString("#,###") + "₫" : "—")
                            </td>
                            <td class="px-3 py-2.5 text-right tabular-nums text-admin-700">@item.DeliveredCount</td>
                            <td class="px-3 py-2.5 text-right tabular-nums text-admin-500">@item.OrderCount</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-admin-50/60 border-t border-admin-200">
                    <tr>
                        <td class="px-3 py-2.5 font-semibold text-admin-800">Cộng 7 ngày</td>
                        <td class="px-3 py-2.5 text-right font-bold text-brand-700 tabular-nums">@weekRevenue.ToString("#,##0")₫</td>
                        <td class="px-3 py-2.5 text-right font-semibold tabular-nums">@weekDelivered</td>
                        <td class="px-3 py-2.5 text-right font-semibold tabular-nums">@weekOrders</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyRev.Select(x => x.Date)));
            var revenues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyRev.Select(x => x.Revenue)));
            var delivered = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyRev.Select(x => x.DeliveredCount)));
            var canvas = document.getElementById('revenueChart');
            if (!canvas || typeof Chart === 'undefined') return;

            var fmtVnd = function (v) {
                if (v == null || v === 0) return '0₫';
                return Number(v).toLocaleString('vi-VN') + '₫';
            };

            new Chart(canvas, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            type: 'bar',
                            label: 'Doanh thu',
                            data: revenues,
                            backgroundColor: 'rgba(8, 145, 178, 0.75)',
                            hoverBackgroundColor: 'rgba(14, 116, 144, 0.9)',
                            borderRadius: 6,
                            borderSkipped: false,
                            yAxisID: 'y',
                            order: 2
                        },
                        {
                            type: 'line',
                            label: 'Đơn đã giao',
                            data: delivered,
                            borderColor: '#f59e0b',
                            backgroundColor: 'rgba(245, 158, 11, 0.15)',
                            pointBackgroundColor: '#f59e0b',
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            tension: 0.3,
                            yAxisID: 'y1',
                            order: 1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: {
                            position: 'top',
                            align: 'end',
                            labels: { boxWidth: 12, usePointStyle: true, pointStyle: 'rectRounded' }
                        },
                        tooltip: {
                            callbacks: {
                                label: function (ctx) {
                                    if (ctx.dataset.yAxisID === 'y') {
                                        return ' Doanh thu: ' + fmtVnd(ctx.parsed.y);
                                    }
                                    return ' Đơn đã giao: ' + ctx.parsed.y;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { color: '#64748b', font: { size: 11 } }
                        },
                        y: {
                            position: 'left',
                            beginAtZero: true,
                            grid: { color: 'rgba(148, 163, 184, 0.2)' },
                            ticks: {
                                color: '#64748b',
                                font: { size: 11 },
                                callback: function (v) {
                                    if (v >= 1e6) return (v / 1e6).toFixed(v % 1e6 === 0 ? 0 : 1) + 'tr';
                                    if (v >= 1e3) return (v / 1e3).toFixed(0) + 'k';
                                    return v;
                                }
                            }
                        },
                        y1: {
                            position: 'right',
                            beginAtZero: true,
                            grid: { drawOnChartArea: false },
                            ticks: {
                                color: '#b45309',
                                font: { size: 11 },
                                precision: 0
                            }
                        }
                    }
                }
            });
        })();
    </script>
}

<div class="grid grid-cols-1 xl:grid-cols-3 gap-4 mb-6">
    <div class="xl:col-span-2 admin-panel">
        <div class="admin-panel-head">
            <h2 class="font-semibold text-admin-900">Đơn hàng gần đây</h2>
            <a asp-area="Admin" asp-controller="Order" asp-action="Index"
               class="text-sm font-medium text-brand-700 hover:text-brand-800 cursor-pointer transition-colors">Xem tất cả</a>
        </div>
        @{
            var recentOrders = ViewBag.RecentOrders as List<TMDTStore.Models.Order> ?? new();
        }
        @if (recentOrders.Count > 0)
        {
            <div class="overflow-x-auto">
                <table class="w-full text-sm admin-table">
                    <thead class="bg-admin-50/80">
                        <tr>
                            <th class="text-left px-4 py-2.5">Mã đơn</th>
                            <th class="text-left px-4 py-2.5">Khách</th>
                            <th class="text-right px-4 py-2.5">Tổng</th>
                            <th class="text-center px-4 py-2.5">Trạng thái</th>
                            <th class="text-right px-4 py-2.5">Ngày</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-admin-100">
                        @foreach (var order in recentOrders)
                        {
                            var sl = statusLabels.ContainsKey(order.Status) ? statusLabels[order.Status] : order.Status;
                            var sb = statusBgColors.ContainsKey(order.Status) ? statusBgColors[order.Status] : "bg-admin-50 text-admin-700 border-admin-200";
                            <tr>
                                <td class="px-4 py-3">
                                    <a asp-area="Admin" asp-controller="Order" asp-action="Details" asp-route-id="@order.Id"
                                       class="font-mono text-xs font-medium text-brand-700 hover:underline cursor-pointer">@order.Id</a>
                                </td>
                                <td class="px-4 py-3 text-admin-700">@order.FullName</td>
                                <td class="px-4 py-3 text-right font-semibold text-admin-900 tabular-nums">@order.TotalPrice.ToString("#,###")₫</td>
                                <td class="px-4 py-3 text-center">
                                    <span class="admin-chip border @sb">@sl</span>
                                </td>
                                <td class="px-4 py-3 text-right text-admin-400 text-xs font-mono">@order.CreatedAt?.ToString("dd/MM HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="px-5 py-10 text-center text-sm text-admin-400">Chưa có đơn hàng nào.</div>
        }
    </div>

    <div class="admin-panel p-0">
        <div class="admin-panel-head">
            <h2 class="font-semibold text-admin-900">Theo trạng thái</h2>
        </div>
        @{
            var statusCounts = ViewBag.StatusCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
            var totalForStats = (int)ViewBag.TotalOrdersForStats;
            var orderStatuses = new[] { "Delivered", "Shipping", "Confirmed", "WaitingPayment", "Pending", "Cancelled" };
            var statusDisplay = new Dictionary<string, string>
            {
                { "Delivered", "Đã giao" }, { "Shipping", "Đang giao" },
                { "Confirmed", "Đã xác nhận" }, { "WaitingPayment", "Chờ thanh toán" },
                { "Pending", "Chờ xử lý" }, { "Cancelled", "Đã huỷ" }
            };
            var statusBarColors = new Dictionary<string, string>
            {
                { "Delivered", "bg-emerald-500" }, { "Shipping", "bg-cyan-500" },
                { "Confirmed", "bg-sky-500" }, { "WaitingPayment", "bg-yellow-500" },
                { "Pending", "bg-amber-500" }, { "Cancelled", "bg-red-500" }
            };
        }
        <div class="p-5 space-y-3">
            @foreach (var s in orderStatuses)
            {
                var count = statusCounts.ContainsKey(s) ? statusCounts[s] : 0;
                var pct = totalForStats > 0 ? (int)Math.Round((double)count / totalForStats * 100) : 0;
                var barColor = statusBarColors.ContainsKey(s) ? statusBarColors[s] : "bg-admin-400";
                var displayName = statusDisplay.ContainsKey(s) ? statusDisplay[s] : s;
                <div>
                    <div class="flex items-center justify-between text-sm mb-1">
                        <span class="text-admin-600">@displayName</span>
                        <span class="font-semibold text-admin-900 tabular-nums">@count <span class="text-admin-400 font-normal">(@pct%)</span></span>
                    </div>
                    <div class="h-2 bg-admin-100 rounded-full overflow-hidden">
                        <div class="h-full @barColor rounded-full transition-all duration-500" style="width:@pct%"></div>
                    </div>
                </div>
            }
            <div class="pt-3 border-t border-admin-100 text-center text-xs text-admin-400">
                Tổng <strong class="text-admin-700">@totalForStats</strong> đơn
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-2 gap-4 mb-6">
    <div class="admin-panel">
        <div class="admin-panel-head">
            <h2 class="font-semibold text-admin-900">Top bán chạy</h2>
        </div>
        @{
            var topProducts = ViewBag.TopProducts as IList<TMDTStore.Models.ViewModels.Admin.TopProductItem>
                ?? new List<TMDTStore.Models.ViewModels.Admin.TopProductItem>();
        }
        @if (topProducts.Count > 0)
        {
            <div class="divide-y divide-admin-100">
                @foreach (var p in topProducts)
                {
                    <div class="flex items-center gap-3 px-5 py-3 hover:bg-admin-50/80 transition-colors">
                        <div class="size-10 rounded-lg bg-admin-100 overflow-hidden shrink-0 border border-admin-200">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="" loading="lazy" class="w-full h-full object-cover" />
                            }
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-admin-800 truncate">@p.Name</p>
                        </div>
                        <div class="text-right shrink-0">
                            <p class="text-sm font-bold text-brand-700 tabular-nums">@p.TotalSold</p>
                            <p class="text-[11px] text-admin-400">đã bán</p>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="px-5 py-10 text-center text-sm text-admin-400">Chưa có dữ liệu bán.</div>
        }
    </div>

    <div class="admin-panel">
        <div class="admin-panel-head">
            <h2 class="font-semibold text-admin-900">Cần xử lý</h2>
            <span class="admin-chip bg-amber-50 text-amber-800 border-amber-200">@ViewBag.PendingOrders đơn</span>
        </div>
        @{
            var waitingOrders = ViewBag.WaitingOrders as List<TMDTStore.Models.Order> ?? new();
        }
        @if (waitingOrders.Count > 0)
        {
            <div class="divide-y divide-admin-100">
                @foreach (var order in waitingOrders)
                {
                    var sl = statusLabels.ContainsKey(order.Status) ? statusLabels[order.Status] : order.Status;
                    var sb = statusBgColors.ContainsKey(order.Status) ? statusBgColors[order.Status] : "bg-admin-50 text-admin-700 border-admin-200";
                    <a asp-area="Admin" asp-controller="Order" asp-action="Details" asp-route-id="@order.Id"
                       class="flex items-center justify-between px-5 py-3 hover:bg-admin-50/80 transition-colors cursor-pointer">
                        <div class="min-w-0">
                            <p class="text-sm font-medium text-admin-900 font-mono">#@order.Id</p>
                            <p class="text-xs text-admin-400 mt-0.5 truncate">@order.FullName · @order.Phone</p>
                        </div>
                        <div class="text-right shrink-0 ml-3">
                            <p class="text-sm font-bold text-admin-900 tabular-nums">@order.TotalPrice.ToString("#,###")₫</p>
                            <span class="admin-chip border @sb mt-1">@sl</span>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="px-5 py-10 text-center text-sm text-emerald-700">
                <svg class="size-10 mx-auto text-emerald-300 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Không còn đơn chờ xử lý.
            </div>
        }
    </div>
</div>

<div class="admin-panel">
    <div class="admin-panel-head">
        <h2 class="font-semibold text-admin-900">Truy cập nhanh</h2>
    </div>
    <div class="p-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
        <a asp-area="Admin" asp-controller="Product" asp-action="Index"
           class="flex items-center gap-3 p-3.5 rounded-xl border border-admin-200 bg-admin-50/50 hover:border-brand-300 hover:bg-brand-50/40 transition-colors cursor-pointer">
            <div class="size-9 rounded-lg bg-brand-100 text-brand-700 flex items-center justify-center">
                <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-900">Sản phẩm</p>
                <p class="text-xs text-admin-500">Katalog & tồn kho</p>
            </div>
        </a>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index"
