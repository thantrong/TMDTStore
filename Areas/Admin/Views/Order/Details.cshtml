@model TMDTStore.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng";

    var statusColors = new Dictionary<string, string>
    {
        { "Pending", "bg-gray-100 text-gray-800" },
        { "WaitingPayment", "bg-yellow-100 text-yellow-800" },
        { "Confirmed", "bg-blue-100 text-blue-800" },
        { "Shipping", "bg-purple-100 text-purple-800" },
        { "Delivered", "bg-emerald-100 text-emerald-800" },
        { "Cancelled", "bg-red-100 text-red-800" }
    };
    var statusLabels = new Dictionary<string, string>
    {
        { "Pending", "Chờ xử lý" },
        { "WaitingPayment", "Chờ thanh toán" },
        { "Confirmed", "Đã xác nhận" },
        { "Shipping", "Đang giao" },
        { "Delivered", "Đã giao" },
        { "Cancelled", "Đã huỷ" }
    };

    // Available status transitions for current status
    // Key: current status, Value: list of (targetStatus, buttonLabel, cssClass)
    var allTransitions = new Dictionary<string, List<string[]>>
    {
        { "Pending", new() { new[] { "Confirmed", "Xác nhận đơn hàng", "bg-blue-600 hover:bg-blue-700" }, new[] { "Cancelled", "Huỷ đơn", "bg-red-600 hover:bg-red-700" } } },
        { "WaitingPayment", new() { new[] { "Confirmed", "Xác nhận đã thanh toán", "bg-blue-600 hover:bg-blue-700" }, new[] { "Cancelled", "Huỷ đơn", "bg-red-600 hover:bg-red-700" } } },
        { "Confirmed", new() { new[] { "Shipping", "Chuyển sang giao hàng", "bg-purple-600 hover:bg-purple-700" }, new[] { "Cancelled", "Huỷ đơn", "bg-red-600 hover:bg-red-700" } } },
        { "Shipping", new() { new[] { "Delivered", "Xác nhận đã giao", "bg-emerald-600 hover:bg-emerald-700" }, new[] { "Cancelled", "Huỷ đơn", "bg-red-600 hover:bg-red-700" } } },
        { "Delivered", new() { } },
        { "Cancelled", new() { } }
    };
    var currentTransitions = allTransitions.ContainsKey(Model.Status) ? allTransitions[Model.Status] : new List<string[]>();
}

<div class="mb-6">
    <a asp-action="Index"
       class="inline-flex items-center gap-1.5 text-sm text-admin-500 hover:text-admin-700 transition-colors mb-4">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại danh sách
    </a>
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-admin-800">Đơn hàng #@Model.Id</h1>
            <p class="text-sm text-admin-500 mt-1">Đặt ngày @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
        <div class="flex items-center gap-3">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-semibold @(statusColors.ContainsKey(Model.Status) ? statusColors[Model.Status] : "bg-gray-100 text-gray-800")">
                <span class="w-2 h-2 rounded-full @(Model.Status == "Cancelled" ? "bg-red-500" : Model.Status == "Delivered" ? "bg-emerald-500" : Model.Status == "Shipping" ? "bg-purple-500" : Model.Status == "Confirmed" ? "bg-blue-500" : Model.Status == "WaitingPayment" ? "bg-yellow-500" : "bg-gray-500")"></span>
                @(statusLabels.ContainsKey(Model.Status) ? statusLabels[Model.Status] : Model.Status)
            </span>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- LEFT: Order Info + Items -->
    <div class="xl:col-span-2 space-y-6">

        <!-- Customer Info -->
        <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-5">
            <h2 class="font-bold text-admin-800 mb-4">Thông tin giao hàng</h2>
            <div class="grid grid-cols-2 gap-4 text-sm">
                <div>
                    <p class="text-admin-400">Người nhận</p>
                    <p class="font-medium text-admin-800">@Model.FullName</p>
                </div>
                <div>
                    <p class="text-admin-400">Số điện thoại</p>
                    <p class="font-medium text-admin-800">@Model.Phone</p>
                </div>
                <div class="col-span-2">
                    <p class="text-admin-400">Địa chỉ</p>
                    <p class="font-medium text-admin-800">@Model.Address</p>
                </div>
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div class="col-span-2">
                        <p class="text-admin-400">Ghi chú</p>
                        <p class="font-medium text-admin-800">@Model.Note</p>
                    </div>
                }
            </div>
        </div>

        <!-- Payment Info -->
        <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-5">
            <h2 class="font-bold text-admin-800 mb-4">Thông tin thanh toán</h2>
            <div class="grid grid-cols-2 gap-4 text-sm">
                <div>
                    <p class="text-admin-400">Phương thức</p>
                    <p class="font-medium text-admin-800">@(Model.PaymentMethod == "Banking" ? "Chuyển khoản" : Model.PaymentMethod == "COD" ? "COD" : "—")</p>
                </div>
                @if (Model.DiscountAmount.HasValue && Model.DiscountAmount > 0)
                {
                    <div>
                        <p class="text-admin-400">Mã giảm giá</p>
                        <p class="font-medium text-green-600">@(Model.Voucher?.Code ?? "")</p>
                    </div>
                    <div>
                        <p class="text-admin-400">Giảm giá</p>
                        <p class="font-medium text-red-500">-@Model.DiscountAmount?.ToString("#,###")₫</p>
                    </div>
                }
                <div>
                    <p class="text-admin-400">Tổng tiền</p>
                    <p class="font-bold text-lg text-admin-800">@Model.TotalPrice.ToString("#,###")₫</p>
                </div>
            </div>
        </div>

        <!-- Customer Link -->
        @if (Model.User != null)
        {
            <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-5">
                <h2 class="font-bold text-admin-800 mb-4">Thông tin tài khoản</h2>
                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div>
                        <p class="text-admin-400">Email</p>
                        <p class="font-medium text-admin-800">@Model.User.Email</p>
                    </div>
                    <div>
                        <p class="text-admin-400">Tên đăng nhập</p>
                        <p class="font-medium text-admin-800">@Model.User.UserName</p>
                    </div>
                </div>
            </div>
        }

        <!-- Order Items -->
        <div class="bg-white rounded-xl shadow-sm border border-admin-200 overflow-hidden">
            <div class="px-5 py-4 border-b border-admin-100">
                <h2 class="font-bold text-admin-800">Sản phẩm đã đặt</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-admin-50">
                        <tr>
                            <th class="text-left px-5 py-3 font-semibold text-admin-600">Sản phẩm</th>
                            <th class="text-center px-5 py-3 font-semibold text-admin-600">Đơn giá</th>
                            <th class="text-center px-5 py-3 font-semibold text-admin-600">Số lượng</th>
                            <th class="text-right px-5 py-3 font-semibold text-admin-600">Tạm tính</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-admin-100">
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td class="px-5 py-3">
                                    <div class="flex items-center gap-3">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Name" class="w-12 h-12 rounded-lg object-cover border border-admin-100" />
                                        }
                                        else
                                        {
                                            <div class="w-12 h-12 rounded-lg bg-admin-100 flex items-center justify-center text-admin-400">
                                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                                </svg>
                                            </div>
                                        }
                                        <div>
                                            <p class="font-medium text-admin-800">@item.Name</p>
                                            @if (!string.IsNullOrEmpty(item.VariantName))
                                            {
                                                <p class="text-xs text-admin-400">@item.VariantName</p>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td class="px-5 py-3 text-center text-admin-700">@item.UnitPrice.ToString("#,###")₫</td>
                                <td class="px-5 py-3 text-center text-admin-700">@item.Quantity</td>
                                <td class="px-5 py-3 text-right font-semibold text-admin-800">@((item.UnitPrice * item.Quantity).ToString("#,###"))₫</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-admin-50 border-t border-admin-200">
                        <tr>
                            <td colspan="3" class="px-5 py-3 text-right font-semibold text-admin-600">Tổng cộng</td>
                            <td class="px-5 py-3 text-right font-bold text-lg text-admin-800">@Model.TotalPrice.ToString("#,###")₫</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- RIGHT: Actions + Status History -->
    <div class="space-y-6">

        <!-- Actions -->
        @if (currentTransitions.Count > 0)
        {
            <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-5">
                <h2 class="font-bold text-admin-800 mb-4">Thao tác</h2>
                <div class="space-y-3">
                    @foreach (var t in currentTransitions)
                    {
                        var transStatus = t[0];
                        var transLabel = t[1];
                        var transColor = t[2];
                        <form asp-action="UpdateStatus" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="status" value="@transStatus" />
                            <button type="submit"
                                    class="w-full py-2.5 px-4 rounded-xl text-sm font-semibold text-white transition-all duration-200 cursor-pointer @transColor"
                                    onclick="return confirm('@($"Chuyển đơn hàng sang trạng thái \"{(transStatus == "Cancelled" ? "Đã huỷ" : transStatus == "Confirmed" ? "Đã xác nhận" : transStatus == "Shipping" ? "Đang giao" : "Đã giao")}\"?")')">
                                @transLabel
                            </button>
                        </form>
                    }
                </div>
            </div>
        }

        <!-- Status History -->
        <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-5">
            <h2 class="font-bold text-admin-800 mb-4">Lịch sử trạng thái</h2>
            @if (Model.OrderStatusHistories.Count == 0)
            {
                <p class="text-sm text-admin-400">Chưa có lịch sử.</p>
            }
            else
            {
                <div class="relative">
                    <!-- Timeline line -->
                    <div class="absolute left-[7px] top-2 bottom-2 w-0.5 bg-admin-200"></div>
                    <ul class="space-y-4">
                        @foreach (var history in Model.OrderStatusHistories)
                        {
                            var hStatusLabel = statusLabels.ContainsKey(history.Status) ? statusLabels[history.Status] : history.Status;
                            <li class="relative pl-8">
                                <!-- Dot -->
                                <div class="absolute left-0 top-1.5 w-[15px] h-[15px] rounded-full border-2 border-white shadow-sm @(history.Status == "Cancelled" ? "bg-red-500" : history.Status == "Delivered" ? "bg-emerald-500" : history.Status == "Shipping" ? "bg-purple-500" : history.Status == "Confirmed" ? "bg-blue-500" : "bg-gray-400")"></div>
                                <div>
                                    <p class="text-sm font-medium text-admin-800">@hStatusLabel</p>
                                    @if (!string.IsNullOrEmpty(history.Reason))
                                    {
                                        <p class="text-xs text-admin-500">@history.Reason</p>
                                    }
                                    <p class="text-xs text-admin-400 mt-0.5">@history.ChangedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>
</div>
