@model TMDTStore.Models.ViewModels.Product.ProductCreatViewModels

@{
    ViewData["Title"] = "Thêm sản phẩm";
}

<div class="max-w-4xl">
    <a asp-action="Index"
       class="inline-flex items-center gap-1 text-sm text-admin-500 hover:text-brand-600 mb-6 transition-colors cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại danh sách
    </a>

    <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-6 sm:p-8">
        <h1 class="text-2xl font-bold text-admin-800 mb-8">Thêm sản phẩm mới</h1>

        <form asp-action="Create" method="post" enctype="multipart/form-data" class="space-y-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Name" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="Name"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: Bàn phím cơ ASUS ROG" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="BrandId" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <select asp-for="BrandId"
                            class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition">
                        <option value="">-- Chọn thương hiệu --</option>
                        @foreach (var brand in Model.Brands)
                        {
                            <option value="@brand.Id">@brand.Name</option>
                        }
                    </select>
                    <span asp-validation-for="BrandId" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="CategoryId" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <select asp-for="CategoryId"
                            class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition">
                        <option value="">-- Chọn danh mục --</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                    <span asp-validation-for="CategoryId" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="Price" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="Price"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: 1500000" />
                    <span asp-validation-for="Price" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="Quantity" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="Quantity"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: 100" />
                    <span asp-validation-for="Quantity" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    @{
                        ViewBag.ImageFieldName = "ImageFile";
                        ViewBag.ExistingImageUrlsJson = "[]";
                    }
                    @await Html.PartialAsync("_ImageUploader")
                </div>
                <div>
                    <label asp-for="ListPrice" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="ListPrice"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: 19990000" />
                    <span asp-validation-for="ListPrice" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="SalePrice" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="SalePrice"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: 12990000" />
                    <span asp-validation-for="SalePrice" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="WarrantyMonths" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="WarrantyMonths"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: 12" />
                    <span asp-validation-for="WarrantyMonths" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="ReturnDays" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="ReturnDays"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: 30" />
                    <span asp-validation-for="ReturnDays" class="text-red-500 text-xs"></span>
                </div>
            </div>

            <div>
                <label asp-for="ShortDescription" class="block text-sm font-medium text-admin-700 mb-1"></label>
                <textarea asp-for="ShortDescription" rows="2"
                          class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                          placeholder="Mô tả ngắn hiển thị trên card sản phẩm..."></textarea>
                <span asp-validation-for="ShortDescription" class="text-red-500 text-xs"></span>
            </div>

            <div>
                @await Html.PartialAsync("_TechnicalSpecsEditor")
            </div>

            <div>
                <label asp-for="Description" class="block text-sm font-medium text-admin-700 mb-1"></label>
                <textarea asp-for="Description" rows="4"
                          class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                          placeholder="Mô tả sản phẩm..."></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-xs"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div class="flex items-center gap-3 pt-4 border-t border-admin-100">
                <button type="submit"
                        class="px-6 py-2.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 transition-all duration-200 cursor-pointer">
                    Tạo sản phẩm
                </button>
                <a asp-action="Index"
                   class="px-6 py-2.5 border border-admin-200 text-admin-600 rounded-xl font-semibold text-sm hover:bg-admin-50 transition-all duration-200 cursor-pointer">
                    Huỷ
                </a>
            </div>
        </form>
    </div>
</div>