@model TMDTStore.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="max-w-4xl">
    <a asp-action="Index"
       class="inline-flex items-center gap-1 text-sm text-admin-500 hover:text-brand-600 mb-6 transition-colors cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại danh sách
    </a>

    <div class="bg-white rounded-xl shadow-sm border border-admin-200 overflow-hidden">
        <!-- Header -->
        <div class="p-6 sm:p-8 border-b border-admin-100">
            <div class="flex items-start justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="w-16 h-16 rounded-xl bg-admin-100 overflow-hidden flex-shrink-0">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center text-admin-400">
                                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                                          d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                        }
                    </div>
                    <div>
                        <h1 class="text-xl font-bold text-admin-800">@Model.Name</h1>
                        <p class="text-sm text-admin-500">ID: @Model.Id</p>
                    </div>
                </div>
                <a asp-action="Edit" asp-route-id="@Model.Id"
                   class="inline-flex items-center gap-2 px-4 py-2 bg-brand-600 text-white rounded-xl text-sm font-semibold hover:bg-brand-700 transition-all duration-200 cursor-pointer">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                    Sửa
                </a>
            </div>
        </div>

        <!-- Info Grid -->
        <div class="p-6 sm:p-8 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider mb-3">Thông tin cơ bản</h3>
                <dl class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <dt class="text-admin-500">Danh mục</dt>
                        <dd class="font-medium text-admin-800">@Model.Category?.Name ?? "---"</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-admin-500">Thương hiệu</dt>
                        <dd class="font-medium text-admin-800">@Model.BrandName ?? "---"</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-admin-500">Giá bán</dt>
                        <dd class="font-medium text-admin-800">@Model.Price.ToString("#,###")₫</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-admin-500">Giá niêm yết</dt>
                        <dd class="font-medium text-admin-800">@(Model.ListPrice?.ToString("#,###") ?? "---")₫</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-admin-500">Trạng thái</dt>
                        <dd>
                            <span
                                class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium @(Model.IsActive == true ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">
                                <span
                                class="w-1.5 h-1.5 rounded-full @(Model.IsActive == true ? "bg-emerald-500" : "bg-red-500")"></span>
                                @(Model.IsActive == true ? "Đang bán" : "Đã ẩn")
                            </span>
                        </dd>
                    </div>
                </dl>
            </div>
            <div>
                <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider mb-3">Tồn kho & Đánh giá</h3>
                <dl class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <dt class="text-admin-500">Tồn kho</dt>
                        <dd class="font-medium text-admin-800">@(Model.Inventory?.StockQuantity ?? 0)</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-admin-500">Đã đặt trước</dt>
                        <dd class="font-medium text-admin-800">@(Model.Inventory?.ReservedQuantity ?? 0)</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-admin-500">Đánh giá TB</dt>
                        <dd class="font-medium text-admin-800">@Model.RatingAvg.ToString("F1") ⭐ (@Model.RatingCount)
                        </dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-admin-500">Bảo hành</dt>
                        <dd class="font-medium text-admin-800">@(Model.WarrantyMonths?.ToString() ?? "0") tháng</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-admin-500">Đổi trả</dt>
                        <dd class="font-medium text-admin-800">@(Model.ReturnDays?.ToString() ?? "0") ngày</dd>
                    </div>
                    <div class="flex justify-between">
                        <dt class="text-admin-500">Ngày tạo</dt>
                        <dd class="font-medium text-admin-800">@Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</dd>
                    </div>
                </dl>
            </div>
        </div>

        <!-- Description -->
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="px-6 sm:px-8 pb-6 sm:pb-8">
                <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider mb-3">Mô tả</h3>
                <p class="text-sm text-admin-600 leading-relaxed whitespace-pre-line">@Model.Description</p>
            </div>
        }

        <!-- Badges -->
        @if (Model.ProductBadges.Count > 0)
        {
            <div class="px-6 sm:px-8 pb-6 sm:pb-8">
                <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider mb-3">Badge</h3>
                <div class="flex flex-wrap gap-2">
                    @foreach (var badge in Model.ProductBadges)
                    {
                        <span
                        class="px-3 py-1 rounded-lg bg-amber-50 text-amber-700 text-xs font-medium border border-amber-200">@badge.Label</span>
                    }
                </div>
            </div>
        }
    </div>
</div>