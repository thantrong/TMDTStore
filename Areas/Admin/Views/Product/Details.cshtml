@model TMDTStore.Models.Product

@{
    ViewData["Title"] = Model.Name;
    var imageList = new List<string>();
    if (!string.IsNullOrEmpty(Model.ImageUrls))
    {
        try { imageList = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.ImageUrls); } catch { }
    }
    if (!string.IsNullOrEmpty(Model.ImageUrl) && !imageList.Contains(Model.ImageUrl))
    {
        imageList.Insert(0, Model.ImageUrl);
    }
    var hasMultipleImages = imageList.Count > 1;
}

<!-- Breadcrumb -->
<nav class="text-sm text-admin-400 mb-4 flex items-center gap-1.5 flex-wrap">
    <a asp-action="Index" class="hover:text-brand-600 transition-colors">Sản phẩm</a>
    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
    <span class="text-admin-700 font-medium truncate max-w-[300px]">@Model.Name</span>
</nav>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

    <!-- ====== LEFT COLUMN: Image + Actions ====== -->
    <div class="xl:col-span-1 space-y-4">

        <!-- Image Gallery with Auto Slideshow -->
        <div class="bg-white rounded-xl shadow-sm border border-admin-200 overflow-hidden">
            <div class="aspect-square bg-admin-50 relative group">
                @if (imageList.Count > 0)
                {
                    <!-- Main display -->
                    <img id="main-image" src="@imageList[0]" alt="@Model.Name"
                         class="w-full h-full object-contain p-4 transition-all duration-300" />

                    <!-- Counter badge -->
                    <div
                        class="absolute top-3 right-3 bg-black/50 text-white text-xs font-medium px-2.5 py-1 rounded-full backdrop-blur-sm">
                        <span id="slide-current">1</span>/@imageList.Count
                    </div>

                    <!-- Prev / Next arrows -->
                    @if (hasMultipleImages)
                    {
                        <button type="button" id="slide-prev"
                                class="absolute left-2 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white/80 backdrop-blur-sm shadow-lg flex items-center justify-center text-admin-600 hover:bg-white hover:text-admin-800 transition-all opacity-0 group-hover:opacity-100 cursor-pointer">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                            </svg>
                        </button>
                        <button type="button" id="slide-next"
                                class="absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white/80 backdrop-blur-sm shadow-lg flex items-center justify-center text-admin-600 hover:bg-white hover:text-admin-800 transition-all opacity-0 group-hover:opacity-100 cursor-pointer">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                            </svg>
                        </button>

                        <!-- Pause indicator -->
                        <div id="slide-pause-indicator"
                             class="absolute bottom-3 left-3 bg-black/50 text-white text-[10px] px-2 py-1 rounded-full backdrop-blur-sm hidden">
                            ⏸ Đã tạm dừng
                        </div>
                    }
                }
                else
                {
                    <div class="w-full h-full flex flex-col items-center justify-center text-admin-300">
                        <svg class="w-20 h-20 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        <span class="text-sm">Chưa có ảnh</span>
                    </div>
                }
            </div>

            @if (hasMultipleImages)
            {
                <!-- Thumbnails -->
                <div class="flex gap-2 p-3 border-t border-admin-100 overflow-x-auto" id="thumbnails-container">
                    @for (int i = 0; i < imageList.Count; i++)
                    {
                        <button type="button" data-index="@i"
                                class="slide-thumb w-14 h-14 rounded-lg overflow-hidden border border-admin-200 flex-shrink-0 @(i == 0 ? "ring-2 ring-brand-500" : "") hover:ring-2 hover:ring-brand-300 transition-all cursor-pointer">
                            <img src="@imageList[i]" alt="" class="w-full h-full object-cover" />
                        </button>
                    }
                </div>
            }
        </div>

        @if (hasMultipleImages)
        {
            <script>
                        (function () {
                            var images = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(imageList));
                            var current = 0;
                            var timer = null;
                            var interval = 3000;

                            var mainImg = document.getElementById('main-image');
                            var currentLabel = document.getElementById('slide-current');
                            var thumbs = document.querySelectorAll('.slide-thumb');
                            var prevBtn = document.getElementById('slide-prev');
                            var nextBtn = document.getElementById('slide-next');
                            var pauseIndicator = document.getElementById('slide-pause-indicator');

                            function goTo(index) {
                                if (index < 0) index = images.length - 1;
                                if (index >= images.length) index = 0;
                                current = index;
                                mainImg.style.opacity = '0.5';
                                setTimeout(function () {
                                    mainImg.src = images[current];
                                    mainImg.style.opacity = '1';
                                }, 150);
                                if (currentLabel) currentLabel.textContent = (current + 1);
                                thumbs.forEach(function (t, i) {
                                    t.classList.toggle('ring-2', i === current);
                                    t.classList.toggle('ring-brand-500', i === current);
                                    t.classList.toggle('ring-0', i !== current);
                                });
                            }

                            function startAuto() {
                                stopAuto();
                                timer = setInterval(function () {
                                    goTo(current + 1);
                                }, interval);
                                if (pauseIndicator) pauseIndicator.classList.add('hidden');
                            }

                            function stopAuto() {
                                if (timer) { clearInterval(timer); timer = null; }
                                if (pauseIndicator) pauseIndicator.classList.remove('hidden');
                            }

                            function toggleAuto() {
                                if (timer) stopAuto(); else startAuto();
                            }

                            // Click thumbnails
                            thumbs.forEach(function (t) {
                                t.addEventListener('click', function () {
                                    var idx = parseInt(this.getAttribute('data-index'));
                                    goTo(idx);
                                    stopAuto();
                                });
                            });

                            // Prev / Next
                            if (prevBtn) prevBtn.addEventListener('click', function (e) { e.stopPropagation(); goTo(current - 1); stopAuto(); });
                            if (nextBtn) nextBtn.addEventListener('click', function (e) { e.stopPropagation(); goTo(current + 1); stopAuto(); });

                            // Click image to toggle auto
                            mainImg.addEventListener('click', toggleAuto);

                            // Keyboard
                            document.addEventListener('keydown', function (e) {
                                if (e.key === 'ArrowLeft') { goTo(current - 1); stopAuto(); }
                                if (e.key === 'ArrowRight') { goTo(current + 1); stopAuto(); }
                            });

                            // Start slideshow
                            startAuto();
                        })();
            </script>
        }

        <!-- Quick Actions -->
        <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-4 space-y-3">
            <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider">Thao tác</h3>
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="flex items-center gap-3 w-full px-4 py-2.5 bg-brand-600 text-white rounded-xl text-sm font-semibold hover:bg-brand-700 hover:shadow-lg hover:shadow-brand-600/25 transition-all duration-200 cursor-pointer">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                Chỉnh sửa sản phẩm
            </a>
            <a asp-area="Admin" asp-controller="Variant" asp-action="Index" asp-route-productId="@Model.Id"
               class="flex items-center gap-3 w-full px-4 py-2.5 border border-admin-200 text-admin-600 rounded-xl text-sm font-semibold hover:bg-admin-50 transition-all duration-200 cursor-pointer">
                <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
                Quản lý biến thể
            </a>
            <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post">
                <button type="submit"
                        class="flex items-center gap-3 w-full px-4 py-2.5 border border-admin-200 text-admin-600 rounded-xl text-sm font-semibold hover:bg-admin-50 transition-all duration-200 cursor-pointer"
                        onclick="return confirm('@(Model.IsActive == true ? "Ẩn sản phẩm này?" : "Hiển thị sản phẩm này?")')">
                    @if (Model.IsActive == true)
                    {
                        <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                             stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                        </svg>
                    }
                    else
                    {
                        <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                             stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                    }
                    @(Model.IsActive == true ? "Ẩn sản phẩm" : "Hiện sản phẩm")
                </button>
            </form>
        </div>

    </div>

    <!-- ====== RIGHT COLUMN: Product Info ====== -->
    <div class="xl:col-span-2 space-y-4">

        <!-- Header Card -->
        <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-6">
            <div class="flex items-start justify-between gap-4 mb-4">
                <div>
                    <h1 class="text-xl font-bold text-admin-800 leading-tight">@Model.Name</h1>
                    <div class="flex items-center gap-3 mt-2 text-sm text-admin-400">
                        <span>SKU: <span class="font-mono font-medium text-admin-600">@Model.Id</span></span>
                        @if (!string.IsNullOrEmpty(Model.Slug))
                        {
                            <span class="hidden sm:inline">|</span>
                            <span class="hidden sm:inline">Slug: <span class="text-admin-600">@Model.Slug</span></span>
                        }
                    </div>
                </div>
                <span
                    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium flex-shrink-0 @(Model.IsActive == true ? "bg-emerald-50 text-emerald-700 border border-emerald-200" : "bg-red-50 text-red-700 border border-red-200")">
                    <span
                    class="w-2 h-2 rounded-full @(Model.IsActive == true ? "bg-emerald-500" : "bg-red-500")"></span>
                    @(Model.IsActive == true ? "Đang bán" : "Đã ẩn")
                </span>
            </div>

            <!-- Price Row -->
            <div class="flex flex-wrap items-baseline gap-3 p-4 bg-admin-50 rounded-xl">
                @if (Model.Price.HasValue)
                {
                    <span class="text-2xl font-bold text-red-500">@Model.Price.Value.ToString("#,###")₫</span>
                }
                else
                {
                    <span class="text-2xl font-bold text-admin-500">Liên hệ</span>
                }
                @{
                    var hasListPrice = Model.Price.HasValue && Model.ListPrice.HasValue && Model.ListPrice > Model.Price.Value;
                    var hasSalePrice = Model.Price.HasValue && Model.SalePrice.HasValue && Model.SalePrice < Model.Price.Value;
                    var discountPercent = hasListPrice ? (int)(((Model.ListPrice.Value - Model.Price.Value) /
                Model.ListPrice.Value) * 100) : 0;
                }
                @if (hasListPrice)
                {
                    <span class="text-sm text-admin-400 line-through">@Model.ListPrice?.ToString("#,###")₫</span>
                    <span class="text-xs font-semibold text-green-600 bg-green-50 px-2 py-0.5 rounded-full">
                        -@discountPercent%
                    </span>
                }
                @if (hasSalePrice)
                {
                    <span class="text-sm font-semibold text-orange-600 bg-orange-50 px-2 py-0.5 rounded-full">
                        KM: @Model.SalePrice?.ToString("#,###")₫
                    </span>
                }
            </div>
        </div>

        <!-- Info Grid: 2 columns -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

            <!-- Basic Info -->
            <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-5">
                <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider mb-4 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Thông tin cơ bản
                </h3>
                <dl class="space-y-2.5 text-sm">
                    <div class="flex justify-between py-1 border-b border-admin-100 last:border-0">
                        <dt class="text-admin-500">Danh mục</dt>
                        <dd class="font-medium text-admin-800">@(Model.Category?.Name ?? "---")</dd>
                    </div>
                    <div class="flex justify-between py-1 border-b border-admin-100 last:border-0">
                        <dt class="text-admin-500">Thương hiệu</dt>
                        <dd class="font-medium text-admin-800">@(Model.Brand?.Name ?? "---")</dd>
                    </div>
                    <div class="flex justify-between py-1 border-b border-admin-100 last:border-0">
                        <dt class="text-admin-500">Bảo hành</dt>
                        <dd class="font-medium text-admin-800">@(Model.WarrantyMonths.HasValue? Model.WarrantyMonths +
                                                                  " tháng" : "---")</dd>
                        </div>
                        <div class="flex justify-between py-1 border-b border-admin-100 last:border-0">
                            <dt class="text-admin-500">Đổi trả</dt>
                            <dd class="font-medium text-admin-800">@(Model.ReturnDays.HasValue ? Model.ReturnDays + " ngày"                           : "---")</dd>
                        </div>
                        <div class="flex justify-between py-1 border-b border-admin-100 last:border-0">
                            <dt class="text-admin-500">Ngày tạo</dt>
                            <dd class="font-medium text-admin-800">
                                @{
                                    var vnTime = Model.CreatedAt.HasValue
                                        ? TimeZoneInfo.ConvertTimeFromUtc(Model.CreatedAt.Value,
                                TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time")).ToString("dd/MM/yyyy HH:mm")
                                        : "---";
                                }
                                @vnTime
                            </dd>
                        </div>
                    </dl>
                </div>

                <!-- Inventory & Rating -->
                <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-5">
                    <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider mb-4 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                        Tồn kho & Đánh giá
                    </h3>
                    <dl class="space-y-2.5 text-sm">
                        <div class="flex justify-between py-1 border-b border-admin-100 last:border-0">
                            <dt class="text-admin-500">Tồn kho</dt>
                            <dd class="font-medium">
                                <span
                                    class="@(Model.Inventory?.StockQuantity > 10 ? "text-emerald-600" : Model.Inventory?.StockQuantity > 0 ? "text-amber-600" : "text-red-500")">
                                    @(Model.Inventory?.StockQuantity ?? 0)
                                </span>
                            </dd>
                        </div>
                        <div class="flex justify-between py-1 border-b border-admin-100 last:border-0">
                            <dt class="text-admin-500">Đã đặt trước</dt>
                            <dd class="font-medium text-admin-800">@(Model.Inventory?.ReservedQuantity ?? 0)</dd>
                        </div>
                        <div class="flex justify-between py-1 border-b border-admin-100 last:border-0">
                            <dt class="text-admin-500">Đánh giá TB</dt>
                            <dd class="font-medium text-admin-800">
                                <span class="text-yellow-500">★</span> @Model.RatingAvg.ToString("F1")
                                <span class="text-admin-400 font-normal">(@Model.RatingCount)</span>
                            </dd>
                        </div>
                        <div class="flex justify-between py-1 border-b border-admin-100 last:border-0">
                            <dt class="text-admin-500">Badge</dt>
                            <dd>
                                @if (Model.ProductBadges.Count > 0)
                                {
                                    <div class="flex flex-wrap gap-1 justify-end">
                                        @foreach (var badge in Model.ProductBadges)
                                        {
                                            <span
                                            class="px-2 py-0.5 rounded-md bg-amber-50 text-amber-700 text-xs font-medium border border-amber-200">@badge.Label</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-admin-400">---</span>
                                }
                            </dd>
                        </div>
                    </dl>
                </div>

            </div>

            <!-- Short Description -->
            @if (!string.IsNullOrEmpty(Model.ShortDescription))
            {
                <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-5">
                    <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Mô tả ngắn
                    </h3>
                    <p class="text-sm text-admin-600 leading-relaxed">@Model.ShortDescription</p>
                </div>
            }

            <!-- Technical Specs -->
            @if (!string.IsNullOrEmpty(Model.TechnicalSpecs))
            {
                <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-5">
                    <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider mb-4 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Thông số kỹ thuật
                    </h3>
                    @{
                        var specs = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string,
                string>>>(Model.TechnicalSpecs);
                    }
                    @if (specs != null && specs.Count > 0)
                    {
                        <div class="bg-admin-50 rounded-xl overflow-hidden">
                            <table class="w-full text-sm">
                                <tbody>
                                    @foreach (var item in specs)
                                    {
                                        <tr class="border-b border-admin-200 last:border-0 hover:bg-admin-100/50 transition-colors">
                                            <td class="py-2.5 px-4 font-medium text-admin-500 w-1/3 bg-admin-50/50">@item["key"]</td>
                                            <td class="py-2.5 px-4 text-admin-800">@item["value"]</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-sm text-admin-600 whitespace-pre-line">@Model.TechnicalSpecs</p>
                    }
                </div>
            }

            <!-- Description with Xem thêm -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-5">
                    <h3 class="text-xs font-semibold text-admin-400 uppercase tracking-wider mb-3 flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
                        </svg>
                        Mô tả sản phẩm
                    </h3>
                    <div>
                        <div id="desc-content"
                             class="text-sm text-admin-600 leading-relaxed bg-admin-50 rounded-xl p-4 overflow-hidden transition-all duration-300"
                             style="max-height: 150px;">
                            @Html.Raw(Model.Description)
                        </div>
                        <button id="desc-toggle" type="button"
                                class="mt-2 text-sm font-medium text-brand-600 hover:text-brand-700 transition-colors cursor-pointer"
                                onclick="toggleDescription()">
                            Xem thêm ↓
                        </button>
                    </div>
                </div>

                <script>
                    function toggleDescription() {
                        var content = document.getElementById('desc-content');
                        var btn = document.getElementById('desc-toggle');
                        if (content.style.maxHeight === '150px' || content.style.maxHeight === '') {
                            content.style.maxHeight = content.scrollHeight + 'px';
                            btn.textContent = 'Thu gọn ↑';
                        } else {
                            content.style.maxHeight = '150px';
                            btn.textContent = 'Xem thêm ↓';
                        }
                    }
                </script>
            }

        </div>
    </div>