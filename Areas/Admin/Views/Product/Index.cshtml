@model TMDTStore.Models.ViewModels.Product.ProductListViewModels
@{
    ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="flex items-center justify-between mb-5 gap-3">
    <p class="text-sm text-admin-500">@Model.TotalItems sản phẩm · lọc theo danh mục / thương hiệu</p>
    <a asp-action="Create" class="admin-btn-primary sm:hidden">
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
        Thêm
    </a>
</div>

<div class="admin-panel p-4 mb-5">
    <form method="get" class="flex flex-wrap items-end gap-3">
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs font-medium text-admin-500 mb-1" for="SearchQuery">Tìm kiếm</label>
            <input id="SearchQuery" type="text" name="SearchQuery" value="@Model.SearchQuery"
                   class="admin-input" placeholder="Tên sản phẩm..." />
        </div>
        <div class="w-40">
            <label class="block text-xs font-medium text-admin-500 mb-1" for="CategoryId">Danh mục</label>
            <select id="CategoryId" name="CategoryId" class="admin-select">
                <option value="">Tất cả</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                }
            </select>
        </div>
        <div class="w-40">
            <label class="block text-xs font-medium text-admin-500 mb-1" for="BrandName">Thương hiệu</label>
            <select id="BrandName" name="BrandName" class="admin-select">
                <option value="">Tất cả</option>
                @if (ViewBag.Brands != null)
                {
                    @foreach (var brand in ViewBag.Brands as List<TMDTStore.Models.Brand>)
                    {
                        <option value="@brand.Name" selected="@(Model.BrandName == brand.Name)">@brand.Name</option>
                    }
                }
            </select>
        </div>
        <button type="submit"
                class="px-4 py-2.5 bg-admin-900 text-white rounded-lg text-sm font-semibold hover:bg-admin-800 transition-colors cursor-pointer">
            Lọc
        </button>
        <a asp-action="Index"
           class="px-4 py-2.5 border border-admin-200 text-admin-600 rounded-lg text-sm font-semibold hover:bg-admin-50 transition-colors cursor-pointer">
            Xoá lọc
        </a>
    </form>
</div>

<div class="admin-panel">
    <div class="overflow-x-auto">
        <table class="w-full text-sm admin-table">
            <thead class="bg-admin-50 border-b border-admin-200">
                <tr>
                    <th class="text-left px-4 py-3">Sản phẩm</th>
                    <th class="text-left px-4 py-3">Danh mục</th>
                    <th class="text-left px-4 py-3">Thương hiệu</th>
                    <th class="text-right px-4 py-3">Giá</th>
                    <th class="text-center px-4 py-3">Tồn kho</th>
                    <th class="text-center px-4 py-3">Trạng thái</th>
                    <th class="text-center px-4 py-3">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-admin-100">
                @if (Model.Products.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="px-4 py-12 text-center text-admin-400">Chưa có sản phẩm nào.</td>
                    </tr>
                }
                @foreach (var product in Model.Products)
                {
                    var pHasVariants = product.ProductVariants != null && product.ProductVariants.Count > 0;
                    // Giá: ưu tiên variant rẻ nhất nếu product không có giá
                    var displayPrice = product.Price.HasValue ? product.Price.Value.ToString("#,###") + "₫" :
                        (pHasVariants ? product.ProductVariants.Min(v => v.Price).ToString("#,###") + "₫" : "Liên hệ");
                    // Ảnh: lấy từ variant rẻ nhất nếu product không có ảnh
                    var displayImage = product.ImageUrl;
                    if (string.IsNullOrEmpty(displayImage) && pHasVariants)
                    {
                        var cheapestWithImg = product.ProductVariants.Where(v => !string.IsNullOrEmpty(v.ImageUrl)).OrderBy(v =>
                v.Price).FirstOrDefault();
                        if (cheapestWithImg != null) displayImage = cheapestWithImg.ImageUrl;
                    }
                    // Tồn kho: tổng từ variants nếu có, nếu không thì từ Inventory
                    var totalStock = pHasVariants
                        ? product.ProductVariants.Sum(v => v.StockQuantity)
                        : (product.Inventory?.StockQuantity ?? 0);

                    <tr class="hover:bg-admin-50 transition-colors">
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-lg bg-admin-100 overflow-hidden flex-shrink-0">
                                    @if (!string.IsNullOrEmpty(displayImage))
                                    {
                                        <img src="@displayImage" alt="" loading="lazy" class="w-full h-full object-cover" />
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center text-admin-400">
                                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                                                      d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                            </svg>
                                        </div>
                                    }
                                </div>
                                <div>
                                    <p class="font-medium text-admin-800 max-w-[250px] truncate">@product.Name</p>
                                    <p class="text-xs text-admin-400">ID: @product.Id</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-4 py-3 text-admin-600">@product.Category?.Name</td>
                        <td class="px-4 py-3 text-admin-600">@(product.Brand?.Name ?? product.BrandName)</td>
                        <td class="px-4 py-3 text-right font-semibold text-admin-800">@displayPrice</td>
                        <td class="px-4 py-3 text-center">
                            <span
                                class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium @(totalStock > 0 ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">
                                @(totalStock > 0 ? "Còn " + totalStock : "Hết hàng")
                            </span>
                        </td>
                        <td class="px-4 py-3 text-center">
                            <span
                                class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium
                                @(product.IsActive == true ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">
                                <span
                                class="w-1.5 h-1.5 rounded-full @(product.IsActive == true ? "bg-emerald-500" : "bg-red-500")"></span>
                                @(product.IsActive == true ? "Đang bán" : "Đã ẩn")
                            </span>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center justify-center gap-2">
                                <a asp-action="Details" asp-route-id="@product.Id"
                                   class="p-2 text-admin-400 hover:text-brand-600 hover:bg-brand-50 rounded-lg transition-all duration-200 cursor-pointer"
                                   title="Chi tiết">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                         stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                    </svg>
                                </a>
                                <a asp-action="Edit" asp-route-id="@product.Id"
                                   class="p-2 text-admin-400 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-all duration-200 cursor-pointer"
                                   title="Sửa">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                         stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </a>
                                <form asp-action="ToggleStatus" asp-route-id="@product.Id" method="post">
                                    <button type="submit"
                                            class="p-2 text-admin-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all duration-200 cursor-pointer"
                                            title="@(product.IsActive == true ? "Ẩn" : "Hiện")"
                                            onclick="return confirm('@(product.IsActive == true ? "Ẩn sản phẩm này?" : "Hiển thị sản phẩm này?")')">
                                        @if (product.IsActive == true)
                                        {
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                                 stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                                 stroke-width="2">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                            </svg>
                                        }
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @{
        var prodTotalPages = (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize);
    }
    @if (prodTotalPages > 1)
    {
        <div class="flex items-center justify-between px-5 py-4 border-t border-admin-100 bg-admin-50/50">
            <p class="text-sm text-admin-500">
                Hiển thị @(Math.Min(Model.TotalItems, (Model.Page - 1) * Model.PageSize + 1))–@(Math.Min(Model.TotalItems, Model.Page * Model.PageSize))
                trên tổng số @Model.TotalItems sản phẩm
            </p>
            <div class="flex items-center gap-1.5">
                @for (int i = 1; i <= prodTotalPages; i++)
                {
                    <a asp-action="Index"
                       asp-route-page="@i"
                       asp-route-searchQuery="@Model.SearchQuery"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-brandName="@Model.BrandName"
                       class="px-3.5 py-1.5 rounded-lg text-sm font-medium transition-all duration-200 cursor-pointer
                              @(i == Model.Page
                                  ? "bg-brand-600 text-white shadow-md"
                                  : "bg-white text-admin-600 hover:bg-brand-50 border border-admin-200")">
                       @i
                    </a>
                }
            </div>
        </div>
    }
</div>
