@model TMDTStore.Models.ViewModels.Variant.VariantCreateViewModel

@{
    var product = ViewBag.Product as TMDTStore.Models.Product;
    ViewData["Title"] = "Thêm biến thể";
}

<div class="max-w-2xl">
    <a asp-action="Index" asp-route-productId="@Model.ProductId"
       class="inline-flex items-center gap-1 text-sm text-admin-500 hover:text-brand-600 mb-6 transition-colors cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại biến thể
    </a>

    <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-6 sm:p-8">
        <h1 class="text-2xl font-bold text-admin-800 mb-2">Thêm biến thể</h1>
        <p class="text-sm text-admin-500 mb-8">Sản phẩm: <span class="font-medium text-admin-700">@product?.Name</span>
        </p>

        <form asp-action="Create" method="post" enctype="multipart/form-data" class="space-y-5">
            <input type="hidden" asp-for="ProductId" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                    <label asp-for="Name" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="Name"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: 1TB Xám" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="Sku" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="Sku"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="Để trống để tự động sinh" />
                </div>
                <div>
                    <label asp-for="Price" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="Price"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: 5490000" />
                    <span asp-validation-for="Price" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="ListPrice" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="ListPrice"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: 7990000" />
                </div>
                <div>
                    <label asp-for="StockQuantity" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="StockQuantity"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: 50" />
                </div>
                <div>
                    <label asp-for="SortOrder" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="SortOrder"
                           class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"
                           placeholder="VD: 1" />
                </div>
            </div>

            <div>
                @{
                    ViewBag.ImageFieldName = "ImageFile";
                    ViewBag.ExistingImageUrlsJson = "[]";
                }
                @await Html.PartialAsync("_ImageUploader")
            </div>

            <div>
                @await Html.PartialAsync("_AttributesEditor")
            </div>

            <div>
                <label asp-for="Description" class="block text-sm font-medium text-admin-700 mb-1"></label>
                <textarea asp-for="Description" rows="10" class="w-full" placeholder="Mô tả biến thể..."></textarea>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div class="flex items-center gap-3 pt-4 border-t border-admin-100">
                <button type="submit"
                        class="px-6 py-2.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 transition-all duration-200 cursor-pointer">
                    Tạo biến thể
                </button>
                <a asp-action="Index" asp-route-productId="@Model.ProductId"
                   class="px-6 py-2.5 border border-admin-200 text-admin-600 rounded-xl font-semibold text-sm hover:bg-admin-50 transition-all duration-200 cursor-pointer">
                    Huỷ
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        ClassicEditor.create(document.querySelector('#Description'), {
            toolbar: ['bold', 'italic', 'underline', 'strikethrough', '|', 'bulletedList', 'numberedList', '|', 'undo', 'redo'],
            heading: { options: [{ model: 'paragraph', title: 'Paragraph' }] }
        }).catch(error => console.error(error));

        // Tự động sinh SKU từ tên biến thể
        function removeAccents(str) {
            return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        }

        function generateSku(name) {
            return removeAccents(name)
                .toUpperCase()
                .replace(/[^A-Z0-9]+/g, '-')
                .replace(/^-+|-+$/g, '');
        }

        var nameInput = document.querySelector('#Name');
        var skuInput = document.querySelector('#Sku');

        nameInput.addEventListener('input', function () {
            if (!skuInput._userModified) {
                skuInput.value = generateSku(nameInput.value);
            }
        });

        skuInput.addEventListener('input', function () {
            skuInput._userModified = skuInput.value.trim() !== '';
        });

        // Reset lại nếu user xoá hết SKU
        skuInput.addEventListener('blur', function () {
            if (skuInput.value.trim() === '') {
                skuInput._userModified = false;
                skuInput.value = generateSku(nameInput.value);
            }
        });
    </script>
}
