@model TMDTStore.Models.ProductVariant

@{
    ViewData["Title"] = "Sửa biến thể";
}

<div class="max-w-2xl">
    <a asp-action="Index" asp-route-productId="@Model.ProductId"
       class="inline-flex items-center gap-1 text-sm text-admin-500 hover:text-brand-600 mb-6 transition-colors cursor-pointer">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quay lại
    </a>

    <div class="bg-white rounded-xl shadow-sm border border-admin-200 p-6 sm:p-8">
        <h1 class="text-2xl font-bold text-admin-800 mb-8">Sửa biến thể</h1>

        <form asp-action="Edit" method="post" class="space-y-5">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ProductId" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                    <label asp-for="Name" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="Name" class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
                </div>
                <div>
                    <label asp-for="Sku" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="Sku" class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition" />
                </div>
                <div>
                    <label asp-for="Price" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="Price" class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition" />
                </div>
                <div>
                    <label asp-for="ListPrice" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="ListPrice" class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition" />
                </div>
                <div>
                    <label asp-for="StockQuantity" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="StockQuantity" class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition" />
                </div>
                <div>
                    <label asp-for="SortOrder" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="SortOrder" class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition" />
                </div>
                <div class="sm:col-span-2">
                    <label asp-for="ImageUrl" class="block text-sm font-medium text-admin-700 mb-1"></label>
                    <input asp-for="ImageUrl" class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition" />
                </div>
                <div class="sm:col-span-2">
                    <label asp-for="Attributes" class="block text-sm font-medium text-admin-700 mb-1">Thuộc tính (JSON)</label>
                    <textarea asp-for="Attributes" rows="3" class="w-full px-3 py-2.5 border border-admin-200 rounded-lg text-sm focus:ring-2 focus:ring-brand-500 focus:border-transparent outline-none transition"></textarea>
                </div>
                <div>
                    <label class="inline-flex items-center gap-2">
                        <input asp-for="IsActive" class="h-4 w-4 text-brand-600 focus:ring-brand-500 border-admin-300 rounded" />
                        <span class="text-sm text-admin-700">Hoạt động</span>
                    </label>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div class="flex items-center gap-3 pt-4 border-t border-admin-100">
                <button type="submit" class="px-6 py-2.5 bg-brand-600 text-white rounded-xl font-semibold text-sm hover:bg-brand-700 transition-all duration-200 cursor-pointer">
                    Lưu thay đổi
                </button>
                <a asp-action="Index" asp-route-productId="@Model.ProductId" class="px-6 py-2.5 border border-admin-200 text-admin-600 rounded-xl font-semibold text-sm hover:bg-admin-50 transition-all duration-200 cursor-pointer">
                    Huỷ
                </a>
            </div>
        </form>
    </div>
</div>
